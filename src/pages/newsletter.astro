---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Newsletter ASETEMYT — Reporte Mensual de Software de Cronometraje" description="Suscríbete al newsletter mensual de ASETEMYT y recibe un reporte con los nuevos programas de cronometraje industrial incorporados al directorio. 50€/año.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="mb-8 text-sm text-steel-500">
      <a href="/" class="hover:text-accent-600">Inicio</a>
      <span class="mx-2">/</span>
      <span class="text-steel-700">Newsletter</span>
    </nav>

    <!-- Hero -->
    <div class="bg-gradient-to-br from-primary-900 via-primary-800 to-steel-800 rounded-2xl p-8 md:p-12 text-white mb-10">
      <div class="max-w-2xl">
        <span class="bg-accent-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4 inline-block">Newsletter</span>
        <h1 class="text-3xl md:text-4xl font-extrabold mb-4 leading-tight">
          Mantente al día con el <span class="text-accent-400">software especializado</span> en cronometraje industrial
        </h1>
        <p class="text-steel-300 text-lg leading-relaxed mb-6">
          Recibe cada mes un reporte con los nuevos programas incorporados al directorio ASETEMYT: descripción detallada, funciones clave, datos de contacto y enlaces directos.
        </p>
        <div class="flex flex-wrap gap-4">
          <div class="flex items-center gap-2 text-sm text-steel-200">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Reporte mensual
          </div>
          <div class="flex items-center gap-2 text-sm text-steel-200">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Software filtrado y verificado
          </div>
          <div class="flex items-center gap-2 text-sm text-steel-200">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Datos de contacto incluidos
          </div>
        </div>
      </div>
    </div>

    <!-- Pricing + Form -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- What you get -->
      <div>
        <h2 class="text-xl font-bold text-primary-800 mb-5">¿Qué incluye?</h2>
        <div class="space-y-4">
          <div class="flex gap-3">
            <div class="w-8 h-8 bg-accent-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-primary-800">Reporte mensual por email</h3>
              <p class="text-sm text-steel-500">Cada mes recibirás un email con todos los nuevos programas de software especializado añadidos al directorio.</p>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 bg-accent-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-primary-800">Descripción detallada</h3>
              <p class="text-sm text-steel-500">Cada programa incluye descripción, especialidades, plataforma y datos de contacto del proveedor.</p>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 bg-accent-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-primary-800">Estadísticas del sector</h3>
              <p class="text-sm text-steel-500">Cada reporte incluye datos actualizados: total de programas, nuevos este mes y tendencias del sector.</p>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 bg-accent-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-primary-800">Acceso prioritario</h3>
              <p class="text-sm text-steel-500">Los suscriptores reciben la información antes de que se publique en la web.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Subscription Form -->
      <div>
        <div class="bg-white rounded-2xl shadow-lg border border-steel-200 p-6 sticky top-24">
          <div class="text-center mb-6">
            <p class="text-4xl font-extrabold text-primary-800">50€</p>
            <p class="text-steel-500 text-sm">/año + IVA</p>
          </div>

          <form id="newsletter-form" class="space-y-4">
            <div>
              <label for="nl-email" class="block text-sm font-medium text-steel-700 mb-1">Email corporativo *</label>
              <input type="email" id="nl-email" name="email" required placeholder="empresa@ejemplo.com"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none" />
            </div>
            <div>
              <label for="nl-company" class="block text-sm font-medium text-steel-700 mb-1">Empresa</label>
              <input type="text" id="nl-company" name="company" placeholder="Nombre de tu empresa"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none" />
            </div>

            <!-- Coupon -->
            <div>
              <label for="nl-coupon" class="block text-sm font-medium text-steel-700 mb-1">Cupón de descuento</label>
              <div class="flex gap-2">
                <input type="text" id="nl-coupon" name="couponCode" placeholder="CÓDIGO"
                  class="flex-1 border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none uppercase" />
                <button type="button" id="validate-coupon"
                  class="bg-steel-100 hover:bg-steel-200 text-steel-700 font-semibold px-4 py-2.5 rounded-lg transition-colors text-sm whitespace-nowrap">
                  Validar
                </button>
              </div>
              <p id="coupon-status" class="text-xs mt-1"></p>
            </div>

            <button type="submit" id="submit-btn"
              class="w-full bg-accent-500 hover:bg-accent-600 text-white font-bold py-3 rounded-lg transition-colors text-lg">
              Suscribirse — 50€/año
            </button>

            <p id="form-status" class="text-sm text-center"></p>

            <p class="text-xs text-steel-400 text-center">
              Pago seguro con Stripe. Cancela cuando quieras.<br>
              Al suscribirte aceptas recibir emails mensuales de ASETEMYT.
            </p>
          </form>

          <!-- Success state -->
          <div id="success-state" class="hidden text-center py-8">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="text-xl font-bold text-primary-800 mb-2">¡Suscripción activa!</h3>
            <p class="text-steel-500 text-sm">Recibirás tu primer reporte el próximo mes. Revisa tu email para confirmar.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('newsletter-form');
    const submitBtn = document.getElementById('submit-btn');
    const formStatus = document.getElementById('form-status');
    const couponStatus = document.getElementById('coupon-status');
    const validateBtn = document.getElementById('validate-coupon');

    let appliedCoupon = null;

    // Check if returning from Stripe success
    const params = new URLSearchParams(window.location.search);
    if (params.get('success') === '1') {
      form.classList.add('hidden');
      document.getElementById('success-state').classList.remove('hidden');
    }

    // Validate coupon
    validateBtn?.addEventListener('click', async () => {
      const code = document.getElementById('nl-coupon').value.trim();
      if (!code) {
        couponStatus.textContent = 'Introduce un código.';
        couponStatus.className = 'text-xs mt-1 text-red-500';
        return;
      }

      validateBtn.textContent = 'Validando...';
      validateBtn.disabled = true;

      try {
        const res = await fetch(`/api/coupon/validate?code=${encodeURIComponent(code)}`);
        const data = await res.json();
        if (data.valid) {
          appliedCoupon = data;
          couponStatus.textContent = `✓ ${data.description}`;
          couponStatus.className = 'text-xs mt-1 text-green-600';

          if (data.type === 'free') {
            submitBtn.textContent = 'Activar gratis con cupón';
          } else if (data.type === 'discount') {
            const discounted = Math.round(50 * (1 - data.value / 100));
            submitBtn.textContent = `Suscribirse — ${discounted}€/año`;
          } else if (data.type === 'trial') {
            submitBtn.textContent = `Suscribirse — ${data.value} meses gratis`;
          }
        } else {
          appliedCoupon = null;
          couponStatus.textContent = data.error || 'Cupón no válido.';
          couponStatus.className = 'text-xs mt-1 text-red-500';
          submitBtn.textContent = 'Suscribirse — 50€/año';
        }
      } catch {
        couponStatus.textContent = 'Error validando cupón.';
        couponStatus.className = 'text-xs mt-1 text-red-500';
      }

      validateBtn.textContent = 'Validar';
      validateBtn.disabled = false;
    });

    // Submit form
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('nl-email').value;
      const company = document.getElementById('nl-company').value;
      const couponCode = appliedCoupon?.code || '';

      submitBtn.textContent = 'Procesando...';
      submitBtn.disabled = true;
      formStatus.textContent = '';
      formStatus.className = 'text-sm text-center';

      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, company, couponCode }),
        });
        const data = await res.json();

        if (res.ok && data.free) {
          form.classList.add('hidden');
          document.getElementById('success-state').classList.remove('hidden');
        } else if (data.url) {
          window.location.href = data.url;
        } else {
          formStatus.textContent = data.error || 'Error.';
          formStatus.className = 'text-sm text-center text-red-600';
          submitBtn.textContent = 'Suscribirse — 50€/año';
          submitBtn.disabled = false;
        }
      } catch {
        formStatus.textContent = 'Error de conexión.';
        formStatus.className = 'text-sm text-center text-red-600';
        submitBtn.textContent = 'Suscribirse — 50€/año';
        submitBtn.disabled = false;
      }
    });
  </script>
</Layout>
