---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const SITE = 'https://asetemyt.com';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Sobre ASETEMYT', item: `${SITE}/sobre` },
  ],
};

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Sobre ASETEMYT',
  description: 'ASETEMYT es el directorio verificado de profesionales, consultores y empresas especializadas en cronometraje industrial e ingeniería de métodos y tiempos.',
  url: `${SITE}/sobre`,
  mainEntity: { '@id': `${SITE}#organization` },
};
---

<Layout
  title="Sobre ASETEMYT — Directorio de Cronometraje Industrial"
  description="ASETEMYT es el directorio verificado de profesionales, consultores y empresas de cronometraje industrial, MTM, MOST, OEE y Lean Manufacturing. Conoce al equipo, NAP y misión."
  canonical={`${SITE}/sobre`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav aria-label="Migas" class="mb-4 text-sm text-steel-500">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/" class="hover:text-accent-600">Inicio</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-primary-800 font-semibold">Sobre ASETEMYT</li>
      </ol>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-extrabold text-primary-800 mb-3">Sobre ASETEMYT</h1>
      <p class="text-steel-500 text-lg">
        Directorio verificado de profesionales, consultores y empresas especializadas en
        cronometraje industrial e ingeniería de métodos y tiempos. Ayudamos a empresas
        manufactureras a encontrar especialistas en MTM, MOST, Work Sampling, OEE y
        Lean Manufacturing en España y Latinoamérica.
      </p>
    </header>

    <article class="prose prose-steel max-w-none">
      <h2 class="text-2xl font-bold text-primary-800 mt-0 mb-3">Nuestra misión</h2>
      <p>
        Conectar a las plantas de producción con los mejores profesionales de la
        ingeniería de métodos y tiempos, eliminando el ruido de Internet. Todas las
        fichas del directorio pasan por un proceso de verificación manual.
      </p>

      <h2 class="text-2xl font-bold text-primary-800 mt-8 mb-3">¿Qué es el cronometraje industrial?</h2>
      <p>
        El cronometraje industrial es una técnica de la ingeniería de métodos y tiempos
        que permite medir el trabajo de operarios, máquinas y procesos para establecer
        tiempos estándar y optimizar la productividad. Los sistemas normalizados más
        extendidos son MTM (Methods-Time Measurement), MOST (Maynard Operation
        Sequence Technique) y Work Sampling.
      </p>

      <h2 class="text-2xl font-bold text-primary-800 mt-8 mb-3">Datos de contacto (NAP)</h2>
      <address class="not-italic">
        <strong>ASETEMYT</strong><br />
        Calle Serrano 21, 28001 Madrid, España<br />
        <a href="mailto:hola@asetemyt.com" class="text-accent-600 hover:underline">hola@asetemyt.com</a><br />
        Tel. <a href="tel:+34900000000" class="text-accent-600 hover:underline">+34 900 000 000</a>
      </address>

      <h2 class="text-2xl font-bold text-primary-800 mt-8 mb-3">Equipo</h2>
      <p>
        ASETEMYT es operado por un equipo de ingenieros industriales y profesionales
        del marketing digital con experiencia en la cadena de suministro. Si quieres
        saber más o colaborar, escríbenos a
        <a href="mailto:hola@asetemyt.com" class="text-accent-600 hover:underline">hola@asetemyt.com</a>.
      </p>
    </article>
  </section>
</Layout>
