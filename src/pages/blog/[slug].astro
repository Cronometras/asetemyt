---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

export function getStaticPaths() {
  try {
    const data = readFileSync(join(process.cwd(), 'public', 'data', 'articles.json'), 'utf-8');
    const articles = JSON.parse(data);
    return articles
      .filter((a: any) => a.status === 'published')
      .map((article: any) => ({
        params: { slug: article.slug },
      }));
  } catch (e) {
    console.error('Error loading articles for static paths:', e);
    return [];
  }
}
---

<Layout title="Artículo - ASETEMYT">
  <div id="loading" class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
      <p class="mt-4 text-steel-400">Cargando artículo...</p>
    </div>
  </div>

  <div id="error" class="hidden py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-2xl font-bold text-primary-900 mb-4">Artículo no encontrado</h1>
      <p class="text-steel-500 mb-6">El artículo que buscas no existe o ha sido eliminado.</p>
      <a href="/blog" class="inline-block px-6 py-3 bg-accent-600 text-white rounded-lg hover:bg-accent-700 transition-colors">
        Volver al blog
      </a>
    </div>
  </div>

  <article id="article-content" class="hidden py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <a href="/blog" class="text-accent-600 hover:text-accent-700 text-sm font-medium flex items-center gap-1 mb-8 group">
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver al Blog
      </a>

      <header class="mb-10">
        <div id="article-tags" class="flex gap-2 mb-4 flex-wrap"></div>
        <h1 id="article-title" class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-primary-900 leading-tight mb-4"></h1>
        <p id="article-excerpt" class="text-xl text-steel-500 leading-relaxed mb-6 hidden"></p>
        <div id="article-meta" class="flex items-center gap-4 text-sm text-steel-400 border-b border-steel-200 pb-6"></div>
      </header>

      <div id="article-image-container" class="hidden mb-10 rounded-xl overflow-hidden shadow-lg">
        <img id="article-image" src="" alt="" class="w-full h-auto" loading="lazy" />
      </div>

      <div id="article-body" class="prose prose-lg prose-slate max-w-none prose-headings:text-primary-800 prose-a:text-accent-600 prose-p:leading-relaxed prose-p:my-4 prose-li:my-1.5 prose-h2:mt-10 prose-h2:mb-3 prose-h3:mt-8 prose-h3:mb-2"></div>

      <footer class="mt-12 pt-8 border-t border-steel-200">
        <!-- Share -->
        <div id="share-section" class="mb-8">
          <p class="text-sm font-medium text-steel-500 mb-3">Compartir artículo</p>
          <div class="flex gap-3 flex-wrap" id="share-buttons"></div>
        </div>
        <a href="/blog" class="text-accent-600 hover:text-accent-700 font-semibold flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Ver más artículos
        </a>
      </footer>
    </div>
  </article>
</Layout>

<script>
  import { marked } from 'marked';

  marked.setOptions({ breaks: true, gfm: true });

  // Get slug from URL path (handle trailing slash)
  const pathParts = window.location.pathname.split('/').filter(Boolean);
  const slug = pathParts[pathParts.length - 1];

  function formatDate(dateStr: string | null) {
    if (!dateStr) return 'Sin fecha';
    const date = new Date(dateStr);
    return date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function convertToHtml(content: string): string {
    // Remove first H1 to avoid duplicate with the page title
    const text = content.replace(/^#\s+.+$/m, '').trim();
    return marked.parse(text) as string;
  }

  async function loadArticle() {
    const loading = document.getElementById('loading')!;
    const error = document.getElementById('error')!;
    const content = document.getElementById('article-content')!;

    if (!slug) {
      loading.classList.add('hidden');
      error.classList.remove('hidden');
      return;
    }

    try {
      const resp = await fetch('/data/articles.json');
      if (!resp.ok) throw new Error('Failed to fetch articles');
      const articles = await resp.json();
      const article = articles.find((a: any) => a.slug === slug);

      loading.classList.add('hidden');

      if (!article || article.status !== 'published') {
        error.classList.remove('hidden');
        return;
      }

      document.title = `${article.title} - ASETEMYT`;

      // Tags
      if (article.tags && article.tags.length > 0) {
        const tagsEl = document.getElementById('article-tags')!;
        tagsEl.innerHTML = article.tags.map((tag: string) =>
          `<span class="text-xs bg-primary-100 text-primary-700 px-2.5 py-1 rounded-full font-medium">${tag}</span>`
        ).join('');
      }

      document.getElementById('article-title')!.textContent = article.title;

      // Excerpt
      if (article.excerpt) {
        const excerptEl = document.getElementById('article-excerpt')!;
        excerptEl.textContent = article.excerpt;
        excerptEl.classList.remove('hidden');
      }

      // Meta
      const meta = document.getElementById('article-meta')!;
      const formattedDate = formatDate(article.publishedAt);
      meta.innerHTML = `
        ${article.author ? `<span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          ${article.author}
        </span>` : ''}
        <span>${formattedDate}</span>
      `;

      // Cover Image
      if (article.coverImage) {
        const imgContainer = document.getElementById('article-image-container')!;
        const img = document.getElementById('article-image') as HTMLImageElement;
        img.src = article.coverImage;
        img.alt = article.title;
        imgContainer.classList.remove('hidden');
      }

      // Content
      const body = document.getElementById('article-body')!;
      body.innerHTML = convertToHtml(article.content);

      // Style internal links
      body.querySelectorAll('a').forEach(a => {
        const href = a.getAttribute('href') || '';
        a.setAttribute('target', '_blank');
        a.setAttribute('rel', 'noopener noreferrer');
        if (href.includes('asetemyt.com') || href.startsWith('/')) {
          a.className = 'inline-flex items-center gap-1.5 px-4 py-2 my-2 bg-accent-50 text-accent-700 rounded-lg font-semibold text-sm border border-accent-200 hover:bg-accent-100 hover:border-accent-300 transition-colors no-underline';
        }
        else if (href.includes('cronometras.com') || href.includes('induly.com') || href.includes('worksamp.com')) {
          a.className = 'inline-flex items-center gap-1 px-3 py-1.5 my-1 bg-primary-50 text-primary-700 rounded-md font-medium text-sm border border-primary-200 hover:bg-primary-100 transition-colors no-underline';
        }
      });

      // Share buttons
      const shareUrl = encodeURIComponent(window.location.href);
      const shareTitle = encodeURIComponent(article.title);
      const shares = [
        { name: 'LinkedIn', bg: 'bg-[#0077b5]', hover: 'hover:bg-[#00669c]', icon: '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>', url: `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}` },
        { name: 'X', bg: 'bg-black', hover: 'hover:bg-gray-800', icon: '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>', url: `https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareTitle}` },
        { name: 'WhatsApp', bg: 'bg-[#25d366]', hover: 'hover:bg-[#1fba59]', icon: '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>', url: `https://wa.me/?text=${shareTitle}%20${shareUrl}` },
        { name: 'Facebook', bg: 'bg-[#1877f2]', hover: 'hover:bg-[#166fe5]', icon: '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>', url: `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}` },
      ];
      const shareButtons = document.getElementById('share-buttons')!;
      shareButtons.innerHTML = shares.map(s => `
        <a href="${s.url}" target="_blank" rel="noopener noreferrer" title="Compartir en ${s.name}"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg ${s.bg} ${s.hover} text-white text-sm font-medium transition-colors">
          ${s.icon}<span>${s.name}</span>
        </a>
      `).join('');

      content.classList.remove('hidden');
    } catch (err) {
      console.error('Error loading article:', err);
      loading.classList.add('hidden');
      error.classList.remove('hidden');
    }
  }

  loadArticle();
</script>
