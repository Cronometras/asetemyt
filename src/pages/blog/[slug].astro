---
import Layout from '../../layouts/Layout.astro';
import { getArticles, getArticleBySlug } from '../../lib/firebase';
import { marked } from 'marked';

export async function getStaticPaths() {
  let articles: any[] = [];
  try {
    articles = await getArticles();
  } catch (e) {
    console.error('Error fetching articles for static paths:', e);
  }

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;

if (!article) {
  return Astro.redirect('/blog');
}

const htmlContent = article.content ? await marked.parse(article.content) : '';
---

<Layout title={article.title} description={article.excerpt}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <header class="mb-10">
      <a href="/blog" class="text-accent-600 hover:text-accent-700 text-sm font-medium flex items-center gap-1 mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver al Blog
      </a>

      <div class="flex gap-2 mb-4 flex-wrap">
        {article.tags?.map((tag: string) => (
          <span class="text-xs bg-primary-100 text-primary-700 px-2.5 py-1 rounded-full font-medium">
            {tag}
          </span>
        ))}
      </div>

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-primary-900 leading-tight mb-4">
        {article.title}
      </h1>

      {article.excerpt && (
        <p class="text-xl text-steel-500 leading-relaxed mb-6">{article.excerpt}</p>
      )}

      <div class="flex items-center gap-4 text-sm text-steel-400 border-b border-steel-200 pb-6">
        {article.author && (
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            {article.author}
          </span>
        )}
        <span>
          {article.publishedAt?.toDate?.()?.toLocaleDateString('es-ES', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          }) || 'Sin fecha'}
        </span>
      </div>
    </header>

    <!-- Cover Image -->
    {article.coverImage && (
      <img
        src={article.coverImage}
        alt={article.title}
        class="w-full rounded-xl mb-10 shadow-lg"
        loading="lazy"
      />
    )}

    <!-- Content -->
    <div class="prose prose-lg prose-slate max-w-none prose-headings:text-primary-800 prose-a:text-accent-600">
      <div set:html={htmlContent} />
    </div>

    <!-- Footer -->
    <footer class="mt-12 pt-8 border-t border-steel-200">
      <a href="/blog" class="text-accent-600 hover:text-accent-700 font-semibold flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver al Blog
      </a>
    </footer>
  </article>
</Layout>
