---
// BLOQUE 1 — Blog estático: render de tarjetas en build-time, sin lecturas runtime.
// Las tarjetas se emiten como HTML estático desde articles.json (build-time).
// Búsqueda y paginación operan en cliente sobre un JSON embebido, sin fetches.
// ===============================
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

interface Article {
  title: string;
  slug: string;
  excerpt?: string;
  content?: string;
  coverImage?: string;
  author?: string;
  publishedAt?: string;
  tags?: string[];
  status?: string;
}

function loadArticles(): Article[] {
  try {
    const data = readFileSync(join(process.cwd(), 'public', 'data', 'articles.json'), 'utf-8');
    const all: Article[] = JSON.parse(data);
    return all
      .filter((a) => a.status === 'published')
      .sort((a, b) => {
        const da = new Date(a.publishedAt || 0).getTime();
        const db = new Date(b.publishedAt || 0).getTime();
        return db - da;
      });
  } catch (e) {
    console.error('[blog/index] Error loading articles.json:', e);
    return [];
  }
}

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}

function truncateText(text: string, maxLength: number): string {
  const clean = (text || '').replace(/[#*_`~\[\]>|]/g, '').replace(/\n+/g, ' ').trim();
  if (clean.length <= maxLength) return clean;
  return clean.substring(0, maxLength) + '...';
}

const articles = loadArticles();
const ARTICLES_PER_PAGE = 9;
// Build-time solo emitimos la primera página; el resto se pagina en cliente.
const initialArticles = articles.slice(0, ARTICLES_PER_PAGE);
---

<Layout title="Blog — Cronometraje Industrial" description="Artículos, guías y novedades sobre cronometraje industrial, ingeniería de métodos y tiempos, MTM, MOST y optimización de procesos.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-primary-800 mb-3">
        Blog — Cronometraje Industrial
      </h1>
      <p class="text-steel-500 text-lg">
        Artículos, guías y novedades sobre ingeniería de métodos y tiempos.
      </p>
    </div>

    <!-- Search Bar -->
    <div class="mb-8">
      <div class="relative max-w-xl">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-steel-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input
          type="text"
          id="search-input"
          placeholder="Buscar artículos por título, tema o etiqueta..."
          class="block w-full pl-10 pr-4 py-3 border border-steel-200 rounded-xl bg-white text-steel-700 placeholder-steel-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 shadow-sm"
        />
        <button
          id="search-clear"
          class="absolute inset-y-0 right-0 pr-3 flex items-center text-steel-400 hover:text-steel-600 hidden"
          onclick="clearSearch()"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <p id="search-results-count" class="mt-2 text-sm text-steel-400 hidden"></p>
    </div>

    <!-- Articles Grid (build-time: primera página) -->
    {initialArticles.length > 0 ? (
      <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {initialArticles.map((article) => {
          const excerpt = article.excerpt || truncateText(article.content || '', 150);
          return (
            <a
              href={`/blog/${article.slug}`}
              class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1 group"
            >
              {article.coverImage && (
                <div class="overflow-hidden">
                  <img
                    src={article.coverImage}
                    alt={article.title}
                    class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="flex gap-2 mb-3 flex-wrap">
                  {(article.tags || []).slice(0, 3).map((tag) => (
                    <span class="text-xs bg-primary-100 text-primary-700 px-2.5 py-1 rounded-full font-medium">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="text-xl font-bold text-primary-800 group-hover:text-accent-600 transition-colors mb-2">
                  {article.title}
                </h2>
                <p class="text-steel-500 text-sm line-clamp-3">{excerpt}</p>
                <div class="flex items-center justify-between mt-4 pt-4 border-t border-steel-100">
                  <span class="text-sm text-steel-400">{article.author || 'ASETEMYT'}</span>
                  <span class="text-xs text-steel-400">{formatDate(article.publishedAt)}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-20 bg-white rounded-xl shadow">
        <p class="text-steel-400 text-lg">No hay artículos publicados todavía.</p>
        <p class="text-steel-300 mt-2">Vuelve pronto para leer las últimas novedades.</p>
      </div>
    )}

    <!-- No Results (hidden, shown by client when search yields 0) -->
    <div id="no-results" class="hidden text-center py-20 bg-white rounded-xl shadow">
      <svg class="mx-auto h-12 w-12 text-steel-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="text-steel-400 text-lg">No se encontraron artículos</p>
      <p class="text-steel-300 mt-2">Prueba con otros términos de búsqueda.</p>
    </div>

    <!-- Pagination -->
    <div id="pagination" class="hidden mt-10 flex items-center justify-center gap-2">
      <button id="prev-btn" class="px-4 py-2 rounded-lg border border-steel-200 bg-white text-steel-600 hover:bg-primary-50 hover:border-primary-300 hover:text-primary-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors font-medium text-sm" onclick="prevPage()" disabled>
        ← Anterior
      </button>
      <div id="page-numbers" class="flex gap-1"></div>
      <button id="next-btn" class="px-4 py-2 rounded-lg border border-steel-200 bg-white text-steel-600 hover:bg-primary-50 hover:border-primary-300 hover:text-primary-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors font-medium text-sm" onclick="nextPage()">
        Siguiente →
      </button>
    </div>
  </section>
</Layout>

<!-- Embed the full articles list as JSON for client-side search & pagination.
     No runtime fetch needed: the data is in the HTML payload, ~15KB gzipped. -->
<script id="articles-data" type="application/json" set:html={JSON.stringify(articles)} />

<script>
  // Read articles from the embedded JSON (no fetch needed).
  const dataEl = document.getElementById('articles-data') as HTMLScriptElement | null;
  const allArticles: any[] = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];
  let filteredArticles: any[] = [...allArticles];
  let currentPage = 1;
  const ARTICLES_PER_PAGE = 9;

  function formatDate(dateStr: string | null): string {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    return d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function truncateText(text: string, maxLength: number): string {
    const clean = (text || '').replace(/[#*_`~\[\]>|]/g, '').replace(/\n+/g, ' ').trim();
    if (clean.length <= maxLength) return clean;
    return clean.substring(0, maxLength) + '...';
  }

  function buildSearchIndex(article: any): string {
    const parts = [
      article.title || '',
      article.excerpt || '',
      ...(article.tags || []),
    ];
    return parts.join(' ').toLowerCase();
  }

  function renderCard(article: any): string {
    const excerpt = article.excerpt || truncateText(article.content || '', 150);
    return `
      <a href="/blog/${article.slug}" class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1 group">
        ${article.coverImage ? `<div class="overflow-hidden"><img src="${article.coverImage}" alt="${article.title}" class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /></div>` : ''}
        <div class="p-6">
          <div class="flex gap-2 mb-3 flex-wrap">
            ${(article.tags || []).slice(0, 3).map((tag: string) => `<span class="text-xs bg-primary-100 text-primary-700 px-2.5 py-1 rounded-full font-medium">${tag}</span>`).join('')}
          </div>
          <h2 class="text-xl font-bold text-primary-800 group-hover:text-accent-600 transition-colors mb-2">${article.title}</h2>
          <p class="text-steel-500 text-sm line-clamp-3">${excerpt}</p>
          <div class="flex items-center justify-between mt-4 pt-4 border-t border-steel-100">
            <span class="text-sm text-steel-400">${article.author || 'ASETEMYT'}</span>
            <span class="text-xs text-steel-400">${formatDate(article.publishedAt)}</span>
          </div>
        </div>
      </a>
    `;
  }

  function renderPage() {
    const grid = document.getElementById('articles-grid')!;
    const noResults = document.getElementById('no-results')!;
    const pagination = document.getElementById('pagination')!;
    const searchCount = document.getElementById('search-results-count')!;
    const searchInput = document.getElementById('search-input') as HTMLInputElement;

    const totalPages = Math.ceil(filteredArticles.length / ARTICLES_PER_PAGE);
    const start = (currentPage - 1) * ARTICLES_PER_PAGE;
    const pageArticles = filteredArticles.slice(start, start + ARTICLES_PER_PAGE);

    if (searchInput.value.trim()) {
      searchCount.textContent = `${filteredArticles.length} artículo${filteredArticles.length !== 1 ? 's' : ''} encontrado${filteredArticles.length !== 1 ? 's' : ''}`;
      searchCount.classList.remove('hidden');
    } else {
      searchCount.classList.add('hidden');
    }

    if (filteredArticles.length === 0 && searchInput.value.trim()) {
      noResults.classList.remove('hidden');
      grid.classList.add('hidden');
      pagination.classList.add('hidden');
      return;
    }

    noResults.classList.add('hidden');
    grid.classList.remove('hidden');
    grid.innerHTML = pageArticles.map(renderCard).join('');

    if (totalPages > 1) {
      pagination.classList.remove('hidden');
      const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
      const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;

      const pageNumbers = document.getElementById('page-numbers')!;
      pageNumbers.innerHTML = '';
      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.textContent = String(i);
        btn.className = `w-10 h-10 rounded-lg text-sm font-medium transition-colors ${
          i === currentPage
            ? 'bg-primary-600 text-white'
            : 'bg-white border border-steel-200 text-steel-600 hover:bg-primary-50 hover:border-primary-300'
        }`;
        btn.onclick = () => goToPage(i);
        pageNumbers.appendChild(btn);
      }
    } else {
      pagination.classList.add('hidden');
    }
  }

  function filterArticles(query: string) {
    if (!query.trim()) {
      filteredArticles = [...allArticles];
    } else {
      const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
      filteredArticles = allArticles.filter((article: any) => {
        const index = buildSearchIndex(article);
        return terms.every((term: string) => index.includes(term));
      });
    }
    currentPage = 1;
    renderPage();
  }

  function clearSearch() {
    const input = document.getElementById('search-input') as HTMLInputElement;
    input.value = '';
    filterArticles('');
    document.getElementById('search-clear')!.classList.add('hidden');
    document.getElementById('search-results-count')!.classList.add('hidden');
  }

  function goToPage(page: number) {
    currentPage = page;
    renderPage();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function prevPage() {
    if (currentPage > 1) goToPage(currentPage - 1);
  }

  function nextPage() {
    const totalPages = Math.ceil(filteredArticles.length / ARTICLES_PER_PAGE);
    if (currentPage < totalPages) goToPage(currentPage + 1);
  }

  (window as any).clearSearch = clearSearch;
  (window as any).prevPage = prevPage;
  (window as any).nextPage = nextPage;

  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('search-input') as HTMLInputElement;
    const clearBtn = document.getElementById('search-clear')!;
    let debounce: ReturnType<typeof setTimeout>;
    input.addEventListener('input', () => {
      clearTimeout(debounce);
      clearBtn.classList.toggle('hidden', !input.value.trim());
      debounce = setTimeout(() => filterArticles(input.value), 200);
    });
  });
</script>