---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Empleo en Ingeniería de Métodos y Tiempos" description="Ofertas de trabajo en cronometraje industrial, ingeniería de métodos, Lean Manufacturing y optimización de procesos. Job board especializado.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <nav class="mb-4 text-sm text-steel-500">
        <a href="/" class="hover:text-accent-600" data-field="home">Inicio</a>
        <span class="mx-2">/</span>
        <span data-field="navJobs">Empleo</span>
      </nav>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-primary-800 mb-3" data-field="jobsTitle">Empleo en Ingeniería de Métodos</h1>
          <p class="text-steel-500 text-lg" data-field="jobsDesc">Ofertas de trabajo en cronometraje industrial, Lean Manufacturing y optimización de procesos.</p>
        </div>
        <button id="open-post-job"
          class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm whitespace-nowrap">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          <span data-field="postJob">Publicar oferta</span>
        </button>
      </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-md p-4 mb-6 flex flex-wrap gap-3">
      <select id="filter-type" class="border border-steel-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-accent-500 outline-none bg-white">
        <option value="" data-field="allTypes">Todos los tipos</option>
        <option value="full-time" data-field="fullTime">Tiempo completo</option>
        <option value="part-time" data-field="partTime">Tiempo parcial</option>
        <option value="contract" data-field="contract">Contrato</option>
        <option value="freelance" data-field="freelanceType">Freelance</option>
      </select>
      <input type="text" id="filter-location" data-field-placeholder="filterLocation" placeholder="Filtrar por ubicación..."
        class="border border-steel-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-accent-500 outline-none flex-1 min-w-[200px]" />
    </div>

    <!-- Jobs list -->
    <div id="jobs-list" class="space-y-4">
      <div class="text-center py-10">
        <div class="inline-block w-8 h-8 border-4 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
        <p class="mt-3 text-steel-400" data-field="loadingJobs">Cargando ofertas...</p>
      </div>
    </div>

    <!-- Post Job Modal -->
    <div id="post-job-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-xl max-w-xl w-full max-h-[90vh] overflow-y-auto p-6 sm:p-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-primary-800" data-field="publishJob">Publicar oferta de empleo</h2>
          <button id="close-modal" class="text-steel-400 hover:text-steel-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <form id="job-form" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobTitle">Puesto *</label>
              <input type="text" name="title" required maxlength="200" placeholder="Ingeniero de Métodos"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobCompany">Empresa *</label>
              <input type="text" name="company" required maxlength="200" placeholder="Tu empresa"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobLocation">Ubicación</label>
              <input type="text" name="location" maxlength="200" placeholder="Madrid, España"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobType">Tipo *</label>
              <select name="type" required class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none bg-white">
                <option value="full-time" data-field="fullTime">Tiempo completo</option>
                <option value="part-time" data-field="partTime">Tiempo parcial</option>
                <option value="contract" data-field="contract">Contrato</option>
                <option value="freelance" data-field="freelanceType">Freelance</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobSalary">Rango salarial</label>
            <input type="text" name="salary" maxlength="100" placeholder="30.000€ - 45.000€ brutos/año"
              class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobDescription">Descripción *</label>
            <textarea name="description" required rows="4" maxlength="3000"
              placeholder="Describe las responsabilidades, el equipo y el entorno de trabajo..."
              class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none resize-y"></textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobRequirements">Requisitos</label>
            <textarea name="requirements" rows="3" maxlength="2000"
              placeholder="Experiencia en cronometraje, conocimiento de MTM, etc."
              class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none resize-y"></textarea>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobContactEmail">Email de contacto *</label>
              <input type="email" name="contactEmail" required placeholder="rrhh@empresa.com"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none" />
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-700 mb-1" data-field="jobContactUrl">URL de contacto</label>
              <input type="url" name="contactUrl" placeholder="https://empresa.com/careers"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none" />
            </div>
          </div>
          <div class="flex items-center gap-4 pt-2">
            <button type="submit" class="bg-accent-500 hover:bg-accent-600 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors">
              <span data-field="publishBtn">Publicar oferta</span>
            </button>
            <span id="job-status" class="text-sm"></span>
          </div>
        </form>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 bg-gradient-to-r from-primary-800 to-primary-900 rounded-2xl p-8 text-white text-center">
      <h2 class="text-xl md:text-2xl font-bold mb-3" data-field="jobsCtaTitle">¿Buscas profesionales del sector?</h2>
      <p class="text-steel-300 mb-5" data-field="jobsCtaDesc">Publica tu oferta gratuita y llega a ingenieros de métodos y tiempos cualificados.</p>
    </div>
  </section>

  <script>
    import { t, getLang, type Lang } from '../lib/firebase';

    let lang: Lang = getLang();

    function updateLabels() {
      document.querySelectorAll('[data-field]').forEach((el) => {
        const key = (el as HTMLElement).dataset.field!;
        const label = t(key, lang);
        if (label && label !== key) el.textContent = label;
      });
      document.querySelectorAll('[data-field-placeholder]').forEach((el) => {
        const key = (el as HTMLElement).dataset.fieldPlaceholder!;
        const label = t(key, lang);
        if (label && label !== key) (el as HTMLInputElement).placeholder = label;
      });
    }

    const typeLabels: Record<string, string> = {
      'full-time': 'Tiempo completo',
      'part-time': 'Tiempo parcial',
      'contract': 'Contrato',
      'freelance': 'Freelance'
    };
    const typeColors: Record<string, string> = {
      'full-time': 'bg-green-100 text-green-700',
      'part-time': 'bg-blue-100 text-blue-700',
      'contract': 'bg-amber-100 text-amber-700',
      'freelance': 'bg-purple-100 text-purple-700'
    };

    // Update type labels based on current lang
    function getTypeLabel(type: string): string {
      const key = type === 'full-time' ? 'fullTime' : type === 'part-time' ? 'partTime' : type === 'contract' ? 'contract' : 'freelanceType';
      return t(key, lang) || typeLabels[type] || type;
    }

    async function loadJobs() {
      try {
        const res = await fetch('/api/jobs');
        if (!res.ok) {
          const errData = await res.json().catch(() => ({}));
          console.error('Jobs API error:', res.status, errData);
          renderJobs([]);
          return;
        }
        const data = await res.json();
        renderJobs(data.jobs || []);
      } catch (e) {
        console.error('Error loading jobs:', e);
        renderJobs([]);
      }
    }

    function renderJobs(jobs: any[]) {
      const list = document.getElementById('jobs-list')!;
      if (jobs.length === 0) {
        list.innerHTML = `
          <div class="text-center py-16 bg-white rounded-xl shadow-sm">
            <svg class="w-16 h-16 mx-auto text-steel-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <p class="text-steel-400 text-lg">${t('noJobs', lang)}</p>
            <p class="text-steel-400 text-sm mt-1">${t('noJobsHint', lang)}</p>
          </div>
        `;
        return;
      }

      list.innerHTML = jobs.map((j: any) => `
        <div class="bg-white rounded-xl shadow-sm border border-steel-100 p-5 hover:shadow-md transition-shadow">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <h3 class="text-lg font-bold text-primary-800">${escapeHtml(j.title)}</h3>
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full ${typeColors[j.type] || 'bg-steel-100 text-steel-600'}">${getTypeLabel(j.type)}</span>
              </div>
              <p class="text-steel-600 font-medium text-sm mb-2">${escapeHtml(j.company)}${j.location ? ` · 📍 ${escapeHtml(j.location)}` : ''}</p>
              ${j.salary ? `<p class="text-green-700 text-sm font-medium mb-2">💰 ${escapeHtml(j.salary)}</p>` : ''}
              <p class="text-steel-500 text-sm line-clamp-3">${escapeHtml(j.description)}</p>
              ${j.requirements ? `<p class="text-steel-400 text-xs mt-2 line-clamp-2"><strong>${t('jobRequirements', lang)}:</strong> ${escapeHtml(j.requirements)}</p>` : ''}
            </div>
            <div class="flex-shrink-0">
              <a href="${j.contactUrl || `mailto:${j.contactEmail}?subject=Job: ${encodeURIComponent(j.title)}`}"
                ${j.contactUrl ? 'target="_blank" rel="noopener"' : ''}
                class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-white font-semibold px-4 py-2 rounded-lg transition-colors text-sm whitespace-nowrap">
                ${t('contactBtn', lang)}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            </div>
          </div>
          <p class="text-xs text-steel-400 mt-3">${t('publishedOn', lang)} ${new Date(j.createdAt).toLocaleDateString(lang === 'en' ? 'en-US' : 'es-ES')}</p>
        </div>
      `).join('');
    }

    function escapeHtml(str: string) {
      const d = document.createElement('div');
      d.textContent = str || '';
      return d.innerHTML;
    }

    // Modal
    document.getElementById('open-post-job')?.addEventListener('click', () => {
      document.getElementById('post-job-modal')?.classList.remove('hidden');
    });
    document.getElementById('close-modal')?.addEventListener('click', () => {
      document.getElementById('post-job-modal')?.classList.add('hidden');
    });

    // Submit
    document.getElementById('job-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const statusEl = document.getElementById('job-status')!;
      statusEl.textContent = t('publishing', lang);
      statusEl.className = 'text-sm text-steel-500';

      const payload = {
        title: (f.elements.namedItem('title') as HTMLInputElement).value,
        company: (f.elements.namedItem('company') as HTMLInputElement).value,
        location: (f.elements.namedItem('location') as HTMLInputElement).value,
        type: (f.elements.namedItem('type') as HTMLSelectElement).value,
        salary: (f.elements.namedItem('salary') as HTMLInputElement).value,
        description: (f.elements.namedItem('description') as HTMLTextAreaElement).value,
        requirements: (f.elements.namedItem('requirements') as HTMLTextAreaElement).value,
        contactEmail: (f.elements.namedItem('contactEmail') as HTMLInputElement).value,
        contactUrl: (f.elements.namedItem('contactUrl') as HTMLInputElement).value,
      };

      try {
        const res = await fetch('/api/jobs', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (res.ok) {
          statusEl.textContent = t('publishedOk', lang);
          statusEl.className = 'text-sm text-green-600';
          f.reset();
          document.getElementById('post-job-modal')?.classList.add('hidden');
          loadJobs();
        } else {
          statusEl.textContent = data.error;
          statusEl.className = 'text-sm text-red-600';
        }
      } catch {
        statusEl.textContent = lang === 'en' ? 'Connection error.' : 'Error de conexión.';
        statusEl.className = 'text-sm text-red-600';
      }
    });

    // Filters
    document.getElementById('filter-type')?.addEventListener('change', async () => {
      const type = (document.getElementById('filter-type') as HTMLSelectElement).value;
      const loc = (document.getElementById('filter-location') as HTMLInputElement).value;
      let url = '/api/jobs?';
      if (type) url += `type=${type}&`;
      if (loc) url += `location=${encodeURIComponent(loc)}`;
      const res = await fetch(url);
      const data = await res.json();
      renderJobs(data.jobs || []);
    });

    window.addEventListener('langChange', ((e: CustomEvent) => {
      lang = e.detail;
      updateLabels();
      loadJobs(); // Re-render jobs with new lang labels
    }) as EventListener);

    updateLabels();
    loadJobs();
  </script>
</Layout>
