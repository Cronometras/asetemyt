---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Directorio de Software de Cronometraje Industrial" description="Software profesional para cronometraje industrial, MTM, MOST, balanceo de líneas, OEE y Lean Manufacturing.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div id="software-content">
      <!-- Skeleton loader -->
      <div class="mb-10">
        <div class="h-10 w-96 bg-steel-200 rounded animate-pulse mb-3"></div>
        <div class="h-5 w-[32rem] bg-steel-100 rounded animate-pulse"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[1,2,3,4,5,6].map(() => (
          <div class="bg-white rounded-xl shadow-md p-6">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-14 h-14 bg-steel-200 rounded-lg animate-pulse"></div>
              <div class="flex-1">
                <div class="h-5 w-32 bg-steel-200 rounded animate-pulse mb-2"></div>
                <div class="h-5 w-20 bg-steel-100 rounded-full animate-pulse"></div>
              </div>
            </div>
            <div class="h-4 w-full bg-steel-100 rounded animate-pulse mb-2"></div>
            <div class="h-4 w-3/4 bg-steel-100 rounded animate-pulse mb-3"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    import { db, t, getLang, type Lang, COLLECTION_SOFTWARE } from '../../lib/firebase';
    import { collection, getDocs, query, orderBy } from 'firebase/firestore';

    let lang: Lang = getLang();

    async function load() {
      const tr = (k: string) => t(k, lang);

      const softwareSnap = await getDocs(query(collection(db, COLLECTION_SOFTWARE), orderBy('createdAt', 'desc')));
      let software = softwareSnap.docs.map((d) => ({ id: d.id, ...d.data() })) as any[];

      // Sort: destacado first
      software.sort((a, b) => (b.destacado ? 1 : 0) - (a.destacado ? 1 : 0));

      const paises = [...new Set(software.map((e: any) => e.ubicacion?.pais).filter(Boolean))].sort();
      const especialidades = ['cronometraje', 'mtm', 'most', 'oee', 'lean'];

      const container = document.getElementById('software-content')!;

      container.innerHTML = `
        <div class="mb-10">
          <nav class="mb-4 text-sm text-steel-500">
            <a href="/" class="hover:text-accent-600">${tr('home')}</a>
            <span class="mx-2">/</span>
            <span class="text-steel-700">Software</span>
          </nav>
          <h1 class="text-3xl md:text-4xl font-extrabold text-primary-800 mb-3">${lang === 'es' ? 'Directorio de Software Especializado' : 'Specialized Software Directory'}</h1>
          <p class="text-steel-500 text-lg">${lang === 'es' ? 'Software profesional para cronometraje, MTM, balanceo de líneas, OEE, lean manufacturing y más.' : 'Professional software for time study, MTM, line balancing, OEE, lean manufacturing and more.'}</p>
          <div class="mt-4">
            <a href="/comparador" class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
              ${lang === 'es' ? 'Comparar software' : 'Compare software'}
            </a>
          </div>
        </div>

        <!-- Filters -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-8" id="filters-container">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${tr('search')}</label>
              <input type="text" id="search-input" placeholder="${lang === 'es' ? 'Nombre, función...' : 'Name, feature...'}"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${tr('specialty')}</label>
              <select id="filter-especialidad" class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none bg-white">
                <option value="">${tr('allSpec')}</option>
                ${especialidades.map((esp) => `<option value="${esp}">${esp.toUpperCase()}</option>`).join('')}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${tr('country')}</label>
              <select id="filter-ubicacion" class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none bg-white">
                <option value="">${tr('allCountries')}</option>
                ${paises.map((p) => `<option value="${(p as string).toLowerCase()}">${p}</option>`).join('')}
              </select>
            </div>
          </div>
        </div>

        <p class="text-steel-500 mb-4" id="results-count">
          ${software.length} ${software.length === 1 ? tr('result') : tr('results')}
        </p>

        ${software.length === 0 ? `
          <div class="text-center py-20 bg-white rounded-xl shadow">
            <svg class="w-16 h-16 mx-auto text-steel-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <p class="text-steel-400 text-lg">${lang === 'es' ? 'No hay software en el directorio todavía.' : 'No software in the directory yet.'}</p>
            <a href="/anadir" class="inline-block mt-4 text-accent-600 hover:text-accent-700 font-semibold">${tr('addFirst')}</a>
          </div>
        ` : `
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="directory-grid">
            ${software.map((entry: any) => `
              <a href="/directorio/${entry.slug}" class="software-card relative bg-white rounded-xl shadow-md hover:shadow-xl transition-all hover:-translate-y-1 p-6 group ${entry.destacado ? 'ring-2 ring-amber-400 border-amber-300' : ''}"
                data-name="${(entry.nombre || '').toLowerCase()}"
                data-especialidades="${(entry.especialidades || []).join(',').toLowerCase()}"
                data-ubicacion="${`${entry.ubicacion?.pais || ''} ${entry.ubicacion?.ciudad || ''}`.toLowerCase()}">
                ${entry.destacado ? '<span class="absolute top-3 right-3 text-amber-500" title="Destacado">⭐</span>' : ''}
                <div class="flex items-start gap-4 mb-4">
                  ${entry.logo
                    ? `<img src="${entry.logo}" alt="${entry.nombre}" class="w-14 h-14 rounded-lg object-cover shadow-sm" />`
                    : `<div class="w-14 h-14 rounded-lg bg-accent-100 flex items-center justify-center text-accent-700 font-bold text-xl">💻</div>`
                  }
                  <div class="flex-1 min-w-0">
                    <h3 class="text-lg font-bold text-primary-800 group-hover:text-accent-600 transition-colors truncate">${entry.nombre}</h3>
                    ${entry.verificado ? '<span class="inline-flex items-center gap-1 text-xs font-semibold text-green-700 bg-green-100 px-2 py-0.5 rounded-full mt-1">✓ Verificado</span>' : ''}
                  </div>
                </div>
                ${entry.descripcion ? `<p class="text-steel-500 text-sm line-clamp-2 mb-3">${entry.descripcion}</p>` : ''}
                <div class="flex flex-wrap gap-1.5 mb-3">
                  ${(entry.especialidades || []).slice(0, 4).map((esp: string) => `<span class="text-xs bg-accent-50 text-accent-700 px-2 py-0.5 rounded font-medium">${esp}</span>`).join('')}
                </div>
                <div class="flex items-center text-sm text-steel-400">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  ${[entry.ubicacion?.ciudad, entry.ubicacion?.pais].filter(Boolean).join(', ') || tr('noLocation')}
                </div>
              </a>
            `).join('')}
          </div>
        `}
      `;

      // Client-side filtering
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const filterEsp = document.getElementById('filter-especialidad') as HTMLSelectElement;
      const filterLoc = document.getElementById('filter-ubicacion') as HTMLSelectElement;
      const cards = document.querySelectorAll('.software-card') as NodeListOf<HTMLElement>;
      const countEl = document.getElementById('results-count');

      function applyFilters() {
        const search = searchInput?.value?.toLowerCase() || '';
        const esp = filterEsp?.value?.toLowerCase() || '';
        const loc = filterLoc?.value?.toLowerCase() || '';

        let visible = 0;
        cards.forEach((card) => {
          const name = card.dataset.name || '';
          const cardEsp = card.dataset.especialidades || '';
          const cardLoc = card.dataset.ubicacion || '';

          const matchSearch = !search || name.includes(search) || cardEsp.includes(search);
          const matchEsp = !esp || cardEsp.includes(esp);
          const matchLoc = !loc || cardLoc.includes(loc);

          const show = matchSearch && matchEsp && matchLoc;
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (countEl) {
          countEl.textContent = `${visible} ${visible === 1 ? tr('result') : tr('results')}`;
        }
      }

      searchInput?.addEventListener('input', applyFilters);
      filterEsp?.addEventListener('change', applyFilters);
      filterLoc?.addEventListener('change', applyFilters);

      // Apply URL params
      const params = new URLSearchParams(window.location.search);
      if (params.get('especialidad') && filterEsp) filterEsp.value = params.get('especialidad')!;
      if (params.get('ubicacion') && filterLoc) filterLoc.value = params.get('ubicacion')!;
      if (params.toString()) applyFilters();
    }

    window.addEventListener('langChange', ((e: CustomEvent) => {
      lang = e.detail;
      load();
    }) as EventListener);

    load();
  </script>
</Layout>
