---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import RoiCalculator from '../components/RoiCalculator.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';
import { getDirectoryEntries } from '../lib/firebase';

const SITE = 'https://asetemyt.com';

let entries: any[] = [];
let articles: any[] = [];

try {
  entries = await getDirectoryEntries();
} catch (e) {
  console.error('Home: failed to fetch directory entries', e);
}

try {
  const file = join(process.cwd(), 'public', 'data', 'articles.json');
  if (existsSync(file)) {
    articles = (JSON.parse(readFileSync(file, 'utf-8')) as any[])
      .filter((a) => a.status !== 'draft')
      .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime())
      .slice(0, 6);
  }
} catch (e) {
  console.error('Home: failed to read articles.json', e);
}

const consultants = entries.filter((e) => e.seccion !== 'software');
const softwareEntries = entries.filter((e) => e.seccion === 'software');
const stats = {
  total: entries.length,
  empresas: consultants.filter((e) => e.tipo === 'empresa').length,
  consultores: consultants.filter((e) => e.tipo === 'consultor').length,
  software: softwareEntries.length,
};

const featured = entries
  .filter((e) => e.slug && e.destacado)
  .slice(0, 6);
if (featured.length < 6) {
  const ids = new Set(featured.map((e) => e.slug));
  for (const e of entries) {
    if (featured.length >= 6) break;
    if (!ids.has(e.slug) && e.slug) featured.push(e);
  }
}

const latestArticles = articles.slice(0, 3);

function toSlug(s: string): string {
  return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE}#website`,
  name: 'ASETEMYT',
  url: SITE,
  description: 'Directorio de técnicos, consultores y empresas de cronometraje industrial e ingeniería de métodos y tiempos.',
  inLanguage: 'es-ES',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE}/directorio?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
  publisher: { '@id': `${SITE}#organization` },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es el cronometraje industrial?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El cronometraje industrial es una técnica de ingeniería de métodos que consiste en medir el tiempo que un trabajador cualificado tarda en realizar una tarea específica, con el objetivo de determinar el tiempo estándar para esa operación.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué es el sistema MTM?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'MTM (Methods-Time Measurement) es un sistema de predeterminación de tiempos que asigna tiempos estándar a movimientos básicos. MTM2 es una versión simplificada ideal para análisis más rápidos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo puedo aparecer en el directorio ASETEMYT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Para aparecer en el directorio ASETEMYT, accede a la sección "Añadir Empresa", completa el formulario con tus datos profesionales, especialidades y servicios. Tu ficha será revisada por nuestro equipo y publicada en un plazo de 24-48 horas. Es completamente gratuito.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué servicios ofrecen los profesionales del directorio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Los profesionales registrados en ASETEMYT ofrecen servicios de cronometraje industrial, análisis de métodos y tiempos (MTM, MOST), consultoría Lean Manufacturing, cálculo de OEE, diseño de sistemas de incentivos, auditorías ergonómicas y formación.',
      },
    },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'ASETEMYT — Profesionales destacados',
  itemListElement: featured.slice(0, 10).map((e, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: e.nombre,
    url: `${SITE}/directorio/${e.slug}`,
  })),
};
---

<Layout
  title="ASETEMYT — Directorio de Cronometraje Industrial e Ingeniería de Métodos y Tiempos"
  description="Encuentra técnicos, consultores y empresas especializadas en cronometraje industrial, time study, MTM2, MOST y optimización de procesos productivos. Añade tu perfil gratis."
  canonical={SITE}
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-primary-900 via-primary-800 to-steel-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <div class="absolute top-10 left-10 w-72 h-72 bg-accent-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-primary-500 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="text-accent-400 font-semibold tracking-wide uppercase text-sm mb-3">Directorio industrial</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          Cronometraje industrial
          <span class="block text-accent-400">a un clic</span>
        </h1>
        <p class="text-lg md:text-xl text-steel-200 mb-8 leading-relaxed">
          Conecta con los mejores profesionales, consultores y empresas especializadas
          en MTM, MOST, OEE y Lean Manufacturing de España y Latinoamérica.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/directorio" class="inline-flex items-center justify-center bg-accent-500 hover:bg-accent-600 text-white px-8 py-3.5 rounded-lg font-semibold text-lg transition-all hover:shadow-lg hover:shadow-accent-500/25">
            Explorar directorio
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/anadir" class="inline-flex items-center justify-center border-2 border-steel-400 hover:border-accent-400 text-white px-8 py-3.5 rounded-lg font-semibold text-lg transition-all hover:bg-white/5" rel="nofollow">
            Añadir mi empresa
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <a href="/directorio" class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-accent-500 hover:shadow-xl hover:-translate-y-1 transition-all group">
        <p class="text-3xl md:text-4xl font-extrabold text-primary-800 group-hover:text-accent-600 transition-colors">{stats.total}</p>
        <p class="text-steel-500 font-medium mt-1 group-hover:text-accent-500 transition-colors">Total profesionales</p>
      </a>
      <a href="/directorio?tipo=empresa" class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-primary-500 hover:shadow-xl hover:-translate-y-1 transition-all group">
        <p class="text-3xl md:text-4xl font-extrabold text-primary-800 group-hover:text-primary-600 transition-colors">{stats.empresas}</p>
        <p class="text-steel-500 font-medium mt-1 group-hover:text-primary-500 transition-colors">Empresas</p>
      </a>
      <a href="/directorio?tipo=consultor" class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-green-500 hover:shadow-xl hover:-translate-y-1 transition-all group">
        <p class="text-3xl md:text-4xl font-extrabold text-primary-800 group-hover:text-green-600 transition-colors">{stats.consultores}</p>
        <p class="text-steel-500 font-medium mt-1 group-hover:text-green-500 transition-colors">Consultores</p>
      </a>
      <a href="/software" class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-orange-500 hover:shadow-xl hover:-translate-y-1 transition-all group">
        <p class="text-3xl md:text-4xl font-extrabold text-primary-800 group-hover:text-orange-600 transition-colors">{stats.software}</p>
        <p class="text-steel-500 font-medium mt-1 group-hover:text-orange-500 transition-colors">Software</p>
      </a>
    </div>
  </section>

  <!-- Specialties -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-primary-800 mb-8">Especialidades</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {[
        { name: 'Cronometraje', icon: '⏱️', slug: 'cronometraje' },
        { name: 'MTM', icon: '📋', slug: 'mtm' },
        { name: 'MOST', icon: '⚡', slug: 'most' },
        { name: 'OEE', icon: '📊', slug: 'oee' },
        { name: 'Lean Manufacturing', icon: '🏭', slug: 'lean' },
      ].map((cat) => (
        <a
          href={`/directorio/especialidad/${cat.slug}`}
          class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-all hover:-translate-y-1 text-center group"
        >
          <span class="text-3xl mb-3 block" aria-hidden="true">{cat.icon}</span>
          <h3 class="font-semibold text-primary-800 group-hover:text-accent-600 transition-colors">{cat.name}</h3>
        </a>
      ))}
    </div>
  </section>

  <!-- What is Time Study? (SEO content) -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-primary-800 mb-6">¿Qué es el Cronometraje Industrial?</h2>
        <div class="prose prose-lg text-steel-600 space-y-4 max-w-none">
          <p>
            El <strong>cronometraje industrial</strong> es una técnica fundamental de la
            <strong>ingeniería de métodos y tiempos</strong> que consiste en medir con
            precisión el tiempo que un operario cualificado tarda en ejecutar cada
            elemento de una tarea definida. Su objetivo es establecer el
            <strong>tiempo estándar</strong> necesario para realizar esa operación bajo
            condiciones normales de trabajo.
          </p>
          <p>
            Estas técnicas, junto con sistemas de predeterminación de tiempos como
            <strong>MTM</strong>, <strong>MOST</strong> y <strong>Maynard</strong>, son la
            base para la <strong>optimización de procesos productivos</strong>, el diseño
            de <strong>sistemas de incentivos</strong> justos y la mejora continua en
            entornos de fabricación, logística y servicios.
          </p>
          <p>
            En <strong>ASETEMYT</strong> conectamos empresas que necesitan estos
            servicios con los mejores <strong>consultores, técnicos y empresas
            especializadas</strong> en cronometraje, estudio de tiempos y Lean
            Manufacturing en España y Latinoamérica.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Listings (SSR) -->
  {featured.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-primary-800">Profesionales destacados</h2>
        <a href="/directorio" class="text-accent-600 hover:text-accent-700 font-semibold flex items-center gap-1">
          Ver todos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured.map((entry: any) => (
          <a href={`/directorio/${entry.slug}`} class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-all hover:-translate-y-1 group border border-steel-100">
            <div class="flex items-start gap-4">
              {entry.logo ? (
                <img
                  src={entry.logo}
                  alt={`Logo de ${entry.nombre}`}
                  class="w-14 h-14 rounded-lg object-cover flex-shrink-0"
                  width="56"
                  height="56"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="w-14 h-14 bg-primary-100 rounded-lg flex items-center justify-center text-primary-600 font-bold text-xl flex-shrink-0" aria-hidden="true">
                  {(entry.nombre || '?')[0].toUpperCase()}
                </div>
              )}
              <div class="min-w-0">
                <h3 class="font-bold text-primary-800 group-hover:text-accent-600 transition-colors truncate">{entry.nombre}</h3>
                <span class="text-xs font-medium text-accent-600 uppercase">{entry.tipo === 'empresa' ? 'Empresa' : 'Consultor'}</span>
                {entry.ubicacion?.pais && (
                  <p class="text-sm text-steel-500 mt-1 truncate">📍 {[entry.ubicacion.ciudad, entry.ubicacion.pais].filter(Boolean).join(', ')}</p>
                )}
              </div>
            </div>
            {entry.descripcion && <p class="text-sm text-steel-500 mt-3 line-clamp-2">{entry.descripcion}</p>}
            {entry.especialidades?.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {entry.especialidades.slice(0, 3).map((esp: string) => (
                  <span class="text-xs bg-steel-100 text-steel-600 px-2 py-0.5 rounded-full">{esp}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- FAQ Section (SSR for SEO) -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-primary-800 mb-8 text-center">Preguntas Frecuentes</h2>
      <div class="space-y-4">
        {[
          { q: '¿Qué es el cronometraje industrial?', a: 'Es una técnica de ingeniería de métodos que mide el tiempo que un trabajador cualificado tarda en realizar una tarea específica, para determinar el tiempo estándar y optimizar la productividad.' },
          { q: '¿Qué diferencia hay entre MTM y cronometraje?', a: 'El cronometraje mide tiempos observando operaciones en marcha. MTM (Methods-Time Measurement) predetermina tiempos asignando valores a movimientos básicos sin necesidad de observación directa, ideal para la planificación de nuevos métodos.' },
          { q: '¿Cómo puedo contratar a un consultor del directorio?', a: 'Explora el directorio filtrando por especialidad y ubicación, y contacta directamente con el profesional que mejor se adapte a tus necesidades. Todos los perfiles incluyen información de contacto.' },
          { q: '¿Es gratuito aparecer en ASETEMYT?', a: 'Sí, añadir tu perfil o empresa al directorio es completamente gratuito. Solo necesitas completar el formulario y nuestro equipo revisará tu solicitud antes de publicarla.' },
        ].map((faq) => (
          <details class="bg-steel-50 rounded-xl group">
            <summary class="cursor-pointer p-5 font-semibold text-primary-800 flex items-center justify-between hover:text-accent-600 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-steel-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-5 pb-5 text-steel-600">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Articles (SSR) -->
  {latestArticles.length > 0 && (
    <section class="bg-white py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-bold text-primary-800">Últimos artículos</h2>
          <a href="/blog" class="text-accent-600 hover:text-accent-700 font-semibold flex items-center gap-1">
            Ver todos
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestArticles.map((article: any) => (
            <a href={`/blog/${article.slug}`} class="bg-steel-50 rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1 group">
              {article.coverImage && (
                <img
                  src={article.coverImage}
                  alt={article.title}
                  class="w-full h-48 object-cover"
                  width="400"
                  height="192"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="p-5">
                {(article.tags || []).slice(0, 2).length > 0 && (
                  <div class="flex gap-2 mb-3">
                    {(article.tags || []).slice(0, 2).map((tag: string) => (
                      <span class="text-xs bg-primary-100 text-primary-700 px-2 py-1 rounded-full font-medium">{tag}</span>
                    ))}
                  </div>
                )}
                <h3 class="text-lg font-bold text-primary-800 group-hover:text-accent-600 transition-colors mb-2">{article.title}</h3>
                <p class="text-steel-500 text-sm line-clamp-2">{article.excerpt}</p>
                <p class="text-xs text-steel-400 mt-3">
                  <time datetime={new Date(article.publishedAt).toISOString()}>
                    {new Date(article.publishedAt).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ROI Calculator -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-primary-800 mb-3">Calcula tu Ahorro</h2>
      <p class="text-steel-500 max-w-2xl mx-auto">Descubre cuánto puede ahorrar tu empresa con un estudio de tiempos profesional</p>
    </div>
    <div class="max-w-4xl mx-auto">
      <RoiCalculator />
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-gradient-to-r from-accent-500 to-accent-600 rounded-2xl p-6 md:p-8 text-white flex flex-col md:flex-row items-center justify-between gap-4">
      <div>
        <h3 class="text-xl font-bold mb-1">📊 Newsletter ASETEMYT</h3>
        <p class="text-white/80 text-sm">Recibe cada mes un reporte con el nuevo software especializado incorporado al directorio.</p>
      </div>
      <a href="/newsletter" class="inline-flex items-center bg-white text-accent-600 hover:bg-steel-100 px-6 py-2.5 rounded-lg font-semibold transition-colors text-sm whitespace-nowrap">
        Suscribirse →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-gradient-to-r from-primary-800 to-primary-900 rounded-2xl p-8 md:p-12 text-white text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">¿Ofreces servicios de cronometraje industrial?</h2>
      <p class="text-steel-300 mb-6 max-w-2xl mx-auto">Añade tu perfil al directorio y conecta con cientos de empresas que buscan tu experiencia.</p>
      <a href="/anadir" class="inline-flex items-center bg-accent-500 hover:bg-accent-600 text-white px-8 py-3.5 rounded-lg font-semibold text-lg transition-all" rel="nofollow">
        Añadir mi empresa
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      </a>
    </div>
  </section>
</Layout>
