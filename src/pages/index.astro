---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
  <div id="app"></div>

  <script>
    import { db, t, getLang, type Lang, translations } from '../lib/firebase';
    import { collection, getDocs, query, orderBy, where, limit } from 'firebase/firestore';

    let lang: Lang = getLang();

    async function load() {
      const snapshot = await getDocs(
        query(collection(db, 'directorio_asetemyt'), orderBy('createdAt', 'desc'))
      );
      const entries = snapshot.docs.map((d) => d.data());

      const artSnap = await getDocs(
        query(
          collection(db, 'articulos_asetemyt'),
          where('status', '==', 'published'),
          orderBy('publishedAt', 'desc'),
          limit(6)
        )
      );
      const articles = artSnap.docs.map((d) => d.data());

      render(entries, articles);
    }

    function render(entries: any[], articles: any[]) {
      const tr = (k: string) => t(k, lang);
      const stats = {
        total: entries.length,
        empresas: entries.filter((e: any) => e.tipo === 'empresa').length,
        consultores: entries.filter((e: any) => e.tipo === 'consultor').length,
        freelancers: entries.filter((e: any) => e.tipo === 'freelance').length,
      };

      const specialties = [
        { name: lang === 'es' ? 'Cronometraje' : 'Time Study', icon: '⏱️', slug: 'cronometraje' },
        { name: 'MTM', icon: '📋', slug: 'mtm' },
        { name: 'MOST', icon: '⚡', slug: 'most' },
        { name: 'OEE', icon: '📊', slug: 'oee' },
        { name: lang === 'es' ? 'Lean Manufacturing' : 'Lean Manufacturing', icon: '🏭', slug: 'lean' },
      ];

      const app = document.getElementById('app')!;
      app.innerHTML = `
        <!-- Hero -->
        <section class="relative bg-gradient-to-br from-primary-900 via-primary-800 to-steel-800 text-white overflow-hidden">
          <div class="absolute inset-0 opacity-10">
            <div class="absolute top-10 left-10 w-72 h-72 bg-accent-500 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-96 h-96 bg-primary-500 rounded-full blur-3xl"></div>
          </div>
          <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
            <div class="max-w-3xl">
              <p class="text-accent-400 font-semibold tracking-wide uppercase text-sm mb-3">${tr('industrialDirectory')}</p>
              <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
                ${tr('heroTitle1')}
                <span class="block text-accent-400">${tr('heroTitle2')}</span>
              </h1>
              <p class="text-lg md:text-xl text-steel-200 mb-8 leading-relaxed">${tr('heroDesc')}</p>
              <div class="flex flex-col sm:flex-row gap-4">
                <a href="/directorio" class="inline-flex items-center justify-center bg-accent-500 hover:bg-accent-600 text-white px-8 py-3.5 rounded-lg font-semibold text-lg transition-all hover:shadow-lg hover:shadow-accent-500/25">
                  ${tr('exploreDirectory')}
                  <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <a href="/anadir" class="inline-flex items-center justify-center border-2 border-steel-400 hover:border-accent-400 text-white px-8 py-3.5 rounded-lg font-semibold text-lg transition-all hover:bg-white/5">
                  ${tr('addMyCompany')}
                </a>
              </div>
            </div>
          </div>
        </section>

        <!-- Stats -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-accent-500">
              <p class="text-3xl md:text-4xl font-extrabold text-primary-800">${stats.total}</p>
              <p class="text-steel-500 font-medium mt-1">${tr('totalEntries')}</p>
            </div>
            <div class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-primary-500">
              <p class="text-3xl md:text-4xl font-extrabold text-primary-800">${stats.empresas}</p>
              <p class="text-steel-500 font-medium mt-1">${tr('companies')}</p>
            </div>
            <div class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-green-500">
              <p class="text-3xl md:text-4xl font-extrabold text-primary-800">${stats.consultores}</p>
              <p class="text-steel-500 font-medium mt-1">${tr('consultants')}</p>
            </div>
            <div class="bg-white rounded-xl shadow-lg p-6 text-center border-t-4 border-purple-500">
              <p class="text-3xl md:text-4xl font-extrabold text-primary-800">${stats.freelancers}</p>
              <p class="text-steel-500 font-medium mt-1">${tr('freelancers')}</p>
            </div>
          </div>
        </section>

        <!-- Categories -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
          <h2 class="text-2xl md:text-3xl font-bold text-primary-800 mb-8">${tr('specialties')}</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
            ${specialties.map((cat) => `
              <a href="/directorio?especialidad=${cat.slug}" class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-all hover:-translate-y-1 text-center group">
                <span class="text-3xl mb-3 block">${cat.icon}</span>
                <h3 class="font-semibold text-primary-800 group-hover:text-accent-600 transition-colors">${cat.name}</h3>
              </a>
            `).join('')}
          </div>
        </section>

        <!-- Latest Articles -->
        ${articles.length > 0 ? `
        <section class="bg-white py-16">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between mb-8">
              <h2 class="text-2xl md:text-3xl font-bold text-primary-800">${tr('latestArticles')}</h2>
              <a href="/blog" class="text-accent-600 hover:text-accent-700 font-semibold flex items-center gap-1">
                ${tr('viewAll')}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              ${articles.slice(0, 3).map((article: any) => `
                <a href="/blog/${article.slug}" class="bg-steel-50 rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1 group">
                  ${article.coverImage ? `<img src="${article.coverImage}" alt="${article.title}" class="w-full h-48 object-cover" loading="lazy" />` : ''}
                  <div class="p-5">
                    <div class="flex gap-2 mb-3">
                      ${(article.tags || []).slice(0, 2).map((tag: string) => `<span class="text-xs bg-primary-100 text-primary-700 px-2 py-1 rounded-full font-medium">${tag}</span>`).join('')}
                    </div>
                    <h3 class="text-lg font-bold text-primary-800 group-hover:text-accent-600 transition-colors mb-2">${article.title}</h3>
                    <p class="text-steel-500 text-sm line-clamp-2">${article.excerpt}</p>
                    <p class="text-xs text-steel-400 mt-3">${article.publishedAt?.toDate?.()?.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US') || ''}</p>
                  </div>
                </a>
              `).join('')}
            </div>
          </div>
        </section>
        ` : ''}

        <!-- CTA -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
          <div class="bg-gradient-to-r from-primary-800 to-primary-900 rounded-2xl p-8 md:p-12 text-white text-center">
            <h2 class="text-2xl md:text-3xl font-bold mb-4">${tr('ctaTitle')}</h2>
            <p class="text-steel-300 mb-6 max-w-2xl mx-auto">${tr('ctaDesc')}</p>
            <a href="/anadir" class="inline-flex items-center bg-accent-500 hover:bg-accent-600 text-white px-8 py-3.5 rounded-lg font-semibold text-lg transition-all">
              ${tr('addMyCompany')}
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </a>
          </div>
        </section>
      `;
    }

    // Listen for language changes
    window.addEventListener('langChange', ((e: CustomEvent) => {
      lang = e.detail;
      load();
    }) as EventListener);

    load();
  </script>
</Layout>
