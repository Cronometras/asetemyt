---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin — Suscriptores" description="Gestión de suscriptores del newsletter.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div id="loading" class="text-center py-20"><div class="inline-block w-8 h-8 border-4 border-accent-500 border-t-transparent rounded-full animate-spin"></div></div>
    <div id="notAuth" class="hidden text-center py-20"><h2 class="text-2xl font-bold text-primary-900 mb-2">Acceso denegado</h2><a href="/login" class="inline-block mt-4 text-accent-600 font-semibold">Iniciar sesión →</a></div>
    <div id="panel" class="hidden">
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-extrabold text-primary-900">Suscriptores Newsletter</h1>
        <a href="/admin" class="text-sm text-accent-600 font-semibold">← Panel</a>
      </div>
      <div class="flex gap-3 mb-6">
        <input id="searchInput" type="text" placeholder="Buscar por email o empresa..." class="flex-1 border border-steel-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-accent-500 outline-none">
        <select id="statusFilter" class="border border-steel-300 rounded-lg px-3 py-2.5 text-sm bg-white">
          <option value="">Todos</option><option value="active">Activos</option><option value="canceled">Cancelados</option><option value="past_due">Morosos</option>
        </select>
      </div>
      <div id="count" class="text-sm text-steel-500 mb-3"></div>
      <div id="list" class="space-y-2"></div>
    </div>
  </section>
  <script>
    import { auth, onAuthStateChanged, authFetch } from '../../lib/auth';
    let allSubs: any[] = [];
    onAuthStateChanged(auth, async (u) => {
      if (!u) return showNotAuth();
      try { const r = await authFetch('/api/admin/subscribers'); if (!r.ok) return showNotAuth(); allSubs = (await r.json()).subscribers; show(); } catch { showNotAuth(); }
    });
    function showNotAuth() { document.getElementById('loading')!.classList.add('hidden'); document.getElementById('notAuth')!.classList.remove('hidden'); }
    function show() { document.getElementById('loading')!.classList.add('hidden'); document.getElementById('panel')!.classList.remove('hidden'); render(); }
    function filter() {
      const q = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();
      const s = (document.getElementById('statusFilter') as HTMLSelectElement).value;
      return allSubs.filter((x: any) => (!q || (x.email||'').toLowerCase().includes(q) || (x.company||'').toLowerCase().includes(q)) && (!s || x.status === s));
    }
    function render() {
      const f = filter();
      document.getElementById('count')!.textContent = `${f.length} suscriptor${f.length !== 1 ? 'es' : ''}`;
      document.getElementById('list')!.innerHTML = f.map((s: any) => {
        const sc: Record<string,string> = {active:'green',canceled:'red',past_due:'amber'};
        const c = sc[s.status]||'steel';
        const date = s.subscribedAt ? new Date(s.subscribedAt).toLocaleDateString('es-ES') : '—';
        return `<div class="bg-white rounded-lg shadow-sm border border-steel-100 p-4 flex items-center justify-between">
          <div class="min-w-0 flex-1"><p class="font-medium text-primary-800">${s.email}</p><p class="text-xs text-steel-500">${s.company||'Sin empresa'} · ${s.plan||'annual'} · ${date}</p></div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <span class="text-xs font-semibold bg-${c}-100 text-${c}-700 px-2 py-0.5 rounded-full">${s.status==='active'?'Activo':s.status==='canceled'?'Cancelado':'Moroso'}</span>
            ${s.status === 'active' ? `<button onclick="toggleSub('${s.id}','canceled')" class="text-xs text-red-600 hover:underline">Cancelar</button>` : `<button onclick="toggleSub('${s.id}','active')" class="text-xs text-green-600 hover:underline">Reactivar</button>`}
          </div></div>`;
      }).join('');
      document.getElementById('searchInput')!.addEventListener('input', render);
      document.getElementById('statusFilter')!.addEventListener('change', render);
    }
    (window as any).toggleSub = async (id:string, status:string) => {
      await authFetch('/api/admin/subscribers', {method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,status})});
      const r = await authFetch('/api/admin/subscribers'); allSubs = (await r.json()).subscribers; render();
    };
  </script>
</Layout>
