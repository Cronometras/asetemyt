---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin — Solicitudes de Verificación" description="Gestiona las solicitudes de verificación de fichas.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div id="loading" class="text-center py-20">
      <div class="inline-block w-8 h-8 border-4 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-steel-500 mt-4">Cargando solicitudes...</p>
    </div>

    <div id="notAuth" class="hidden text-center py-20">
      <h2 class="text-2xl font-bold text-primary-900 mb-2">Acceso denegado</h2>
      <p class="text-steel-500">No tienes permisos para ver esta página.</p>
      <a href="/login" class="inline-block mt-4 text-accent-600 font-semibold">Iniciar sesión →</a>
    </div>

    <div id="adminPanel" class="hidden">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-extrabold text-primary-900">Solicitudes de Verificación</h1>
        <a href="/admin" class="text-sm text-accent-600 font-medium">← Admin</a>
      </div>

      <!-- Pending claims -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-primary-800 mb-4 flex items-center gap-2">
          <span class="inline-block w-3 h-3 bg-amber-400 rounded-full"></span>
          Pendientes
          <span id="pendingCount" class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full font-medium"></span>
        </h2>
        <div id="pendingList" class="space-y-4">
          <p class="text-steel-500 text-sm">No hay solicitudes pendientes.</p>
        </div>
      </div>

      <!-- Approved claims -->
      <div>
        <h2 class="text-xl font-bold text-primary-800 mb-4 flex items-center gap-2">
          <span class="inline-block w-3 h-3 bg-green-500 rounded-full"></span>
          Aprobadas
          <span id="approvedCount" class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium"></span>
        </h2>
        <div id="approvedList" class="space-y-4">
          <p class="text-steel-500 text-sm">No hay solicitudes aprobadas.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { onAuthStateChanged, auth, authFetch } from '../../lib/auth';

  const loading = document.getElementById('loading')!;
  const notAuth = document.getElementById('notAuth')!;
  const adminPanel = document.getElementById('adminPanel')!;
  const pendingList = document.getElementById('pendingList')!;
  const approvedList = document.getElementById('approvedList')!;
  const pendingCount = document.getElementById('pendingCount')!;
  const approvedCount = document.getElementById('approvedCount')!;

  function renderPendingClaim(c: any): string {
    return `
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-amber-400">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="font-bold text-primary-900">${c.slug}</h3>
            <p class="text-sm text-steel-500 mt-1">Solicitado por: <strong>${c.nombre}</strong> (${c.email})</p>
            <p class="text-sm text-steel-500">Relación: ${c.relacion || 'No especificada'}</p>
            ${c.telefono ? `<p class="text-sm text-steel-500">Tel: ${c.telefono}</p>` : ''}
            ${c.mensaje ? `<p class="text-sm text-steel-600 mt-2 italic">"${c.mensaje}"</p>` : ''}
            <p class="text-xs text-steel-400 mt-2">${new Date(c.createdAt).toLocaleString('es-ES')}</p>
          </div>
          <div class="flex gap-2">
            <button onclick="handleClaim('${c.id}', 'approve')"
              class="px-4 py-2 bg-green-500 hover:bg-green-600 text-white text-sm font-bold rounded-lg transition-colors">
              Aprobar
            </button>
            <button onclick="handleClaim('${c.id}', 'reject')"
              class="px-4 py-2 bg-red-500 hover:bg-red-600 text-white text-sm font-bold rounded-lg transition-colors">
              Rechazar
            </button>
          </div>
        </div>
      </div>
    `;
  }

  function renderApprovedClaim(c: any): string {
    const paymentLink = `/checkout?slug=${encodeURIComponent(c.slug)}`;
    return `
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-400">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="font-bold text-primary-900">${c.slug}</h3>
            <p class="text-sm text-steel-500 mt-1">Solicitado por: <strong>${c.nombre}</strong> (${c.email})</p>
            <p class="text-xs text-steel-400 mt-1">UID: ${c.uid || 'N/A'}</p>
            ${c.reviewedAt ? `<p class="text-xs text-steel-400 mt-1">Aprobado: ${new Date(c.reviewedAt).toLocaleString('es-ES')}</p>` : ''}
          </div>
          <div class="flex gap-2 flex-shrink-0">
            <button onclick="copyPaymentLink('${paymentLink}')"
              class="px-4 py-2 bg-accent-500 hover:bg-accent-600 text-white text-sm font-bold rounded-lg transition-colors">
              Copiar enlace de pago
            </button>
          </div>
        </div>
      </div>
    `;
  }

  onAuthStateChanged(auth, async (user) => {
    loading.classList.add('hidden');
    if (!user) {
      notAuth.classList.remove('hidden');
      return;
    }

    adminPanel.classList.remove('hidden');

    try {
      const resp = await authFetch('/api/admin/claim-action');
      if (resp.status === 403) {
        notAuth.classList.remove('hidden');
        adminPanel.classList.add('hidden');
        return;
      }
      const data = await resp.json();
      const pending = data.pending || [];
      const approved = data.approved || [];

      pendingCount.textContent = pending.length.toString();
      approvedCount.textContent = approved.length.toString();

      if (pending.length === 0) {
        pendingList.innerHTML = '<p class="text-steel-500 text-sm">No hay solicitudes pendientes.</p>';
      } else {
        pendingList.innerHTML = pending.map(renderPendingClaim).join('');
      }

      if (approved.length === 0) {
        approvedList.innerHTML = '<p class="text-steel-500 text-sm">No hay solicitudes aprobadas.</p>';
      } else {
        approvedList.innerHTML = approved.map(renderApprovedClaim).join('');
      }
    } catch (err) {
      pendingList.innerHTML = '<p class="text-red-500 text-sm">Error cargando solicitudes.</p>';
    }
  });

  (window as any).handleClaim = async (claimId: string, action: string) => {
    try {
      const resp = await authFetch('/api/admin/claim-action', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ claimId, action }),
      });
      if (resp.ok) {
        // Reload
        window.location.reload();
      } else {
        alert('Error procesando la solicitud');
      }
    } catch {
      alert('Error de conexión');
    }
  };

  (window as any).copyPaymentLink = async (link: string) => {
    const fullUrl = `${window.location.origin}${link}`;
    try {
      await navigator.clipboard.writeText(fullUrl);
      alert('Enlace copiado al portapapeles:\n' + fullUrl);
    } catch {
      // Fallback
      const input = document.createElement('input');
      input.value = fullUrl;
      document.body.appendChild(input);
      input.select();
      document.execCommand('copy');
      document.body.removeChild(input);
      alert('Enlace copiado:\n' + fullUrl);
    }
  };
</script>
