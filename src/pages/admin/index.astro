---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin — Panel de Control" description="Panel de administración de ASETEMYT.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div id="loading" class="text-center py-20">
      <div class="inline-block w-8 h-8 border-4 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-steel-500 mt-4">Verificando acceso...</p>
    </div>

    <div id="notAuth" class="hidden text-center py-20">
      <h2 class="text-2xl font-bold text-primary-900 mb-2">Acceso denegado</h2>
      <p class="text-steel-500">No tienes permisos de administrador.</p>
      <a href="/login" class="inline-block mt-4 text-accent-600 font-semibold">Iniciar sesión →</a>
    </div>

    <div id="adminPanel" class="hidden">
      <h1 class="text-3xl font-extrabold text-primary-900 mb-8">Panel de Administración</h1>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/admin/fichas" class="bg-white rounded-xl shadow-md p-6 hover:shadow-lg transition-all border border-steel-100 group">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4 group-hover:bg-blue-200 transition-colors">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <h2 class="text-lg font-bold text-primary-800 mb-1">Gestión de Fichas</h2>
          <p class="text-sm text-steel-500">Crear, editar y eliminar fichas del directorio.</p>
        </a>

        <a href="/admin/claims" class="bg-white rounded-xl shadow-md p-6 hover:shadow-lg transition-all border border-steel-100 group">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center mb-4 group-hover:bg-amber-200 transition-colors">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h2 class="text-lg font-bold text-primary-800 mb-1">Solicitudes de Verificación</h2>
          <p class="text-sm text-steel-500">Aprobar o rechazar solicitudes de reclamación de fichas.</p>
        </a>

        <a href="/admin/newsletter" class="bg-white rounded-xl shadow-md p-6 hover:shadow-lg transition-all border border-steel-100 group">
          <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4 group-hover:bg-green-200 transition-colors">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h2 class="text-lg font-bold text-primary-800 mb-1">Newsletter Preview</h2>
          <p class="text-sm text-steel-500">Previsualizar el newsletter antes de enviarlo.</p>
        </a>
      </div>
    </div>
  </section>

  <script>
    import { auth, onAuthStateChanged, authFetch } from '../../lib/auth';

    (async () => {
      onAuthStateChanged(auth, async (user) => {
        if (!user) {
          document.getElementById('loading')!.classList.add('hidden');
          document.getElementById('notAuth')!.classList.remove('hidden');
          return;
        }

        try {
          const res = await authFetch('/api/admin/coupons');
          if (res.ok) {
            document.getElementById('loading')!.classList.add('hidden');
            document.getElementById('adminPanel')!.classList.remove('hidden');
          } else {
            document.getElementById('loading')!.classList.add('hidden');
            document.getElementById('notAuth')!.classList.remove('hidden');
          }
        } catch {
          document.getElementById('loading')!.classList.add('hidden');
          document.getElementById('notAuth')!.classList.remove('hidden');
        }
      });
    })();
  </script>
</Layout>
