---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin — Leads" description="Gestión de solicitudes de presupuesto.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div id="loading" class="text-center py-20">
      <div class="inline-block w-8 h-8 border-4 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-steel-500 mt-4">Verificando acceso...</p>
    </div>

    <div id="notAuth" class="hidden text-center py-20">
      <h2 class="text-2xl font-bold text-primary-900 mb-2">Acceso denegado</h2>
      <p class="text-steel-500">No tienes permisos de administrador.</p>
      <a href="/login" class="inline-block mt-4 text-accent-600 font-semibold">Iniciar sesión →</a>
    </div>

    <div id="leadsPanel" class="hidden">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-extrabold text-primary-900">Solicitudes de Presupuesto</h1>
          <p class="text-steel-500 mt-1">Gestiona las solicitudes recibidas de los profesionales del directorio.</p>
        </div>
        <a href="/admin" class="text-sm text-accent-600 hover:text-accent-700 font-semibold">← Volver al panel</a>
      </div>

      <!-- Filters -->
      <div class="flex flex-wrap gap-2 mb-6" id="statusFilters">
        <button data-status="" class="px-4 py-2 rounded-lg text-sm font-semibold bg-accent-500 text-white transition-colors">Todos</button>
        <button data-status="new" class="px-4 py-2 rounded-lg text-sm font-semibold bg-steel-100 text-steel-600 hover:bg-steel-200 transition-colors">Nuevos</button>
        <button data-status="sent" class="px-4 py-2 rounded-lg text-sm font-semibold bg-steel-100 text-steel-600 hover:bg-steel-200 transition-colors">Enviados</button>
        <button data-status="contacted" class="px-4 py-2 rounded-lg text-sm font-semibold bg-steel-100 text-steel-600 hover:bg-steel-200 transition-colors">Contactados</button>
        <button data-status="closed" class="px-4 py-2 rounded-lg text-sm font-semibold bg-steel-100 text-steel-600 hover:bg-steel-200 transition-colors">Cerrados</button>
      </div>

      <!-- Leads list -->
      <div id="leadsList" class="space-y-3"></div>
    </div>
  </section>

  <script>
    import { auth, onAuthStateChanged, authFetch } from '../../lib/auth';

    const statusLabels: Record<string, string> = {
      new: 'Nuevo', sent: 'Enviado', contacted: 'Contactado', closed: 'Cerrado',
    };
    const statusColors: Record<string, string> = {
      new: 'blue', sent: 'amber', contacted: 'green', closed: 'steel',
    };
    const nextStatus: Record<string, string> = {
      new: 'sent', sent: 'contacted', contacted: 'closed', closed: 'new',
    };
    const nextLabel: Record<string, string> = {
      new: 'Marcar enviado', sent: 'Marcar contactado', contacted: 'Marcar cerrado', closed: 'Reabrir',
    };

    let currentFilter = '';

    onAuthStateChanged(auth, async (user) => {
      if (!user) return showNotAuth();
      try {
        const res = await authFetch('/api/admin/leads');
        if (!res.ok) return showNotAuth();
        showLeads(await res.json());
      } catch { showNotAuth(); }
    });

    function showNotAuth() {
      document.getElementById('loading')!.classList.add('hidden');
      document.getElementById('notAuth')!.classList.remove('hidden');
    }

    function showLeads(data: any) {
      document.getElementById('loading')!.classList.add('hidden');
      document.getElementById('leadsPanel')!.classList.remove('hidden');
      setupFilters(data.leads || []);
    }

    function setupFilters(leads: any[]) {
      const btns = document.querySelectorAll('#statusFilters button');
      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => b.className = 'px-4 py-2 rounded-lg text-sm font-semibold bg-steel-100 text-steel-600 hover:bg-steel-200 transition-colors');
          (btn as HTMLElement).className = 'px-4 py-2 rounded-lg text-sm font-semibold bg-accent-500 text-white transition-colors';
          currentFilter = (btn as HTMLElement).dataset.status || '';
          renderLeads(leads);
        });
      });
      renderLeads(leads);
    }

    function renderLeads(allLeads: any[]) {
      const filtered = currentFilter ? allLeads.filter((l: any) => l.status === currentFilter) : allLeads;
      if (!filtered.length) {
        document.getElementById('leadsList')!.innerHTML = '<div class="bg-white rounded-xl shadow-md p-12 text-center border border-steel-100"><p class="text-steel-400">No hay solicitudes' + (currentFilter ? ` con estado "${statusLabels[currentFilter]}"` : '') + '.</p></div>';
        return;
      }

      document.getElementById('leadsList')!.innerHTML = filtered.map((l: any) => {
        const date = l.createdAt ? new Date(l.createdAt).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—';
        const c = statusColors[l.status] || 'steel';

        return `
        <div class="bg-white rounded-xl shadow-md border border-steel-100 overflow-hidden">
          <div class="p-5">
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="font-bold text-primary-800">${l.contactName || 'Sin nombre'}</h3>
                <p class="text-sm text-steel-500">${l.company || 'Sin empresa'} · <a href="mailto:${l.contactEmail}" class="text-accent-600 hover:underline">${l.contactEmail}</a>${l.contactPhone ? ' · ' + l.contactPhone : ''}</p>
              </div>
              <span class="text-xs font-semibold bg-${c}-100 text-${c}-700 px-2.5 py-1 rounded-full flex-shrink-0">${statusLabels[l.status]}</span>
            </div>

            ${l.serviceNeeded ? `<p class="text-sm text-steel-600 mb-2"><span class="font-medium">Servicio:</span> ${l.serviceNeeded}</p>` : ''}
            ${l.message ? `<p class="text-sm text-steel-500 bg-steel-50 rounded-lg p-3 mb-3 italic">"${l.message}"</p>` : ''}

            <div class="flex items-center justify-between text-xs text-steel-400">
              <span>Ficha: <a href="/directorio/${l.slug}" class="text-accent-600 hover:underline" target="_blank">${l.slug || l.targetName}</a></span>
              <span>${date}</span>
            </div>
          </div>
          <div class="bg-steel-50 px-5 py-3 flex items-center justify-between border-t border-steel-100">
            <span class="text-xs text-steel-500">ID: ${l.id?.substring(0, 12)}...</span>
            <button onclick="updateLeadStatus('${l.id}', '${l.status}')" class="text-xs font-semibold bg-white border border-steel-300 hover:border-accent-400 hover:text-accent-600 px-3 py-1.5 rounded-lg transition-colors">
              ${nextLabel[l.status] || 'Actualizar'} →
            </button>
          </div>
        </div>`;
      }).join('');
    }

    // Expose to window for onclick
    (window as any).updateLeadStatus = async (id: string, currentStatus: string) => {
      const newStatus = nextStatus[currentStatus] || 'new';
      try {
        const res = await authFetch('/api/admin/leads', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status: newStatus }),
        });
        if (res.ok) {
          // Reload
          const dataRes = await authFetch('/api/admin/leads' + (currentFilter ? '?status=' + currentFilter : ''));
          if (dataRes.ok) {
            const data = await dataRes.json();
            document.getElementById('loading')!.classList.remove('hidden');
            document.getElementById('leadsPanel')!.classList.add('hidden');
            showLeads(data);
          }
        } else {
          alert('Error al actualizar el estado.');
        }
      } catch {
        alert('Error de conexión.');
      }
    };
  </script>
</Layout>
