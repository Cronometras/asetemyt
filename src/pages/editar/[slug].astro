---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Editar Ficha" description="Edita los datos de tu ficha verificada en ASETEMYT.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div id="loading" class="text-center py-20">
      <div class="inline-block w-8 h-8 border-4 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-steel-500 mt-4">Cargando ficha...</p>
    </div>

    <div id="notAuth" class="hidden text-center py-20">
      <h2 class="text-2xl font-bold text-primary-900 mb-2">Acceso requerido</h2>
      <p class="text-steel-500 mb-6">Inicia sesión para editar tu ficha</p>
      <a href="/login" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3 rounded-lg transition-colors">
        Iniciar Sesión
      </a>
    </div>

    <div id="notOwner" class="hidden text-center py-20">
      <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-primary-900 mb-2">No eres el propietario</h2>
      <p class="text-steel-500 mb-6">Solo el propietario verificado puede editar esta ficha.</p>
      <a href="/directorio" class="text-accent-600 font-semibold">Volver al directorio →</a>
    </div>

    <div id="editPanel" class="hidden">
      <nav class="mb-8">
        <a id="backLink" href="/mi-cuenta" class="text-accent-600 hover:text-accent-700 text-sm font-medium flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Volver a mi cuenta
        </a>
      </nav>

      <div class="bg-white rounded-2xl shadow-lg p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <div>
            <h1 class="text-2xl font-extrabold text-primary-900">Editar Ficha</h1>
            <p id="fichaName" class="text-steel-500 text-sm"></p>
          </div>
        </div>

        <div id="alert" class="hidden mb-4 p-3 rounded-lg text-sm"></div>

        <form id="editForm" class="space-y-6">
          <!-- Descripción -->
          <div>
            <label for="descripcion" class="block text-sm font-semibold text-steel-700 mb-1">Descripción</label>
            <textarea id="descripcion" name="descripcion" rows="4"
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors"
              placeholder="Describe tu empresa o servicios..."></textarea>
          </div>

          <!-- Ubicación -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label for="ciudad" class="block text-sm font-semibold text-steel-700 mb-1">Ciudad</label>
              <input type="text" id="ciudad" name="ciudad"
                class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors" />
            </div>
            <div>
              <label for="pais" class="block text-sm font-semibold text-steel-700 mb-1">País</label>
              <input type="text" id="pais" name="pais"
                class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors" />
            </div>
            <div>
              <label for="direccion" class="block text-sm font-semibold text-steel-700 mb-1">Dirección</label>
              <input type="text" id="direccion" name="direccion"
                class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors" />
            </div>
          </div>

          <!-- Contacto -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="email" class="block text-sm font-semibold text-steel-700 mb-1">Email de contacto</label>
              <input type="email" id="email" name="email"
                class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors" />
            </div>
            <div>
              <label for="telefono" class="block text-sm font-semibold text-steel-700 mb-1">Teléfono</label>
              <input type="tel" id="telefono" name="telefono"
                class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors" />
            </div>
            <div>
              <label for="web" class="block text-sm font-semibold text-steel-700 mb-1">Web</label>
              <input type="url" id="web" name="web"
                class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors"
                placeholder="https://..." />
            </div>
            <div>
              <label for="linkedin" class="block text-sm font-semibold text-steel-700 mb-1">LinkedIn</label>
              <input type="text" id="linkedin" name="linkedin"
                class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors"
                placeholder="https://linkedin.com/in/..." />
            </div>
          </div>

          <!-- Logo URL -->
          <div>
            <label for="logo" class="block text-sm font-semibold text-steel-700 mb-1">URL del logo</label>
            <input type="url" id="logo" name="logo"
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors"
              placeholder="https://..." />
          </div>

          <!-- Especialidades (comma separated) -->
          <div>
            <label for="especialidades" class="block text-sm font-semibold text-steel-700 mb-1">Especialidades (separadas por coma)</label>
            <input type="text" id="especialidades" name="especialidades"
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors"
              placeholder="Lean Manufacturing, Kaizen, 5S..." />
          </div>

          <!-- Servicios (one per line) -->
          <div>
            <label for="servicios" class="block text-sm font-semibold text-steel-700 mb-1">Servicios (uno por línea)</label>
            <textarea id="servicios" name="servicios" rows="3"
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors"
              placeholder="Consultoría Lean&#10;Formación in-company&#10;Auditorías de procesos"></textarea>
          </div>

          <button type="submit" id="submitBtn"
            class="w-full bg-accent-500 hover:bg-accent-600 text-white font-bold py-3 rounded-lg transition-colors">
            Guardar Cambios
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { onAuthStateChanged, auth, authFetch } from '../../lib/auth';

  const slug = window.location.pathname.split('/').filter(Boolean).pop();
  const loading = document.getElementById('loading')!;
  const notAuth = document.getElementById('notAuth')!;
  const notOwner = document.getElementById('notOwner')!;
  const editPanel = document.getElementById('editPanel')!;
  const fichaName = document.getElementById('fichaName')!;
  const editForm = document.getElementById('editForm') as HTMLFormElement;
  const alertEl = document.getElementById('alert')!;
  const submitBtn = document.getElementById('submitBtn')!;

  function showAlert(msg: string, type: 'error' | 'success' = 'error') {
    alertEl.textContent = msg;
    alertEl.className = `mb-4 p-3 rounded-lg text-sm ${type === 'error' ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700'}`;
    alertEl.classList.remove('hidden');
  }

  function fillForm(data: any) {
    const set = (id: string, value: string) => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
      if (el && value) el.value = value;
    };

    set('descripcion', data.descripcion || '');
    set('ciudad', data.ubicacion?.ciudad || '');
    set('pais', data.ubicacion?.pais || '');
    set('direccion', data.ubicacion?.direccion || '');
    set('email', data.contacto?.email || '');
    set('telefono', data.contacto?.telefono || '');
    set('web', data.contacto?.web || '');
    set('linkedin', data.contacto?.linkedin || '');
    set('logo', data.logo || '');
    set('especialidades', (data.especialidades || []).join(', '));
    set('servicios', (data.servicios || []).join('\n'));
  }

  onAuthStateChanged(auth, async (user) => {
    loading.classList.add('hidden');
    if (!user) {
      notAuth.classList.remove('hidden');
      return;
    }

    fichaName.textContent = `Editando: ${slug}`;

    // Load current listing data
    try {
      const resp = await authFetch(`/api/ficha/get?slug=${encodeURIComponent(slug || '')}`);
      if (resp.status === 403) {
        notOwner.classList.remove('hidden');
        return;
      }
      if (!resp.ok) {
        editPanel.classList.remove('hidden');
        showAlert('Error cargando datos de la ficha');
        return;
      }

      const data = await resp.json();
      fillForm(data);
      fichaName.textContent = `Editando: ${data.nombre || slug}`;
      editPanel.classList.remove('hidden');
    } catch (err) {
      editPanel.classList.remove('hidden');
      showAlert('Error de conexión cargando la ficha');
    }
  });

  editForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Guardando...';
    submitBtn.setAttribute('disabled', 'true');

    const updates: any = {};

    const descripcion = (document.getElementById('descripcion') as HTMLTextAreaElement).value;
    if (descripcion) updates.descripcion = descripcion;

    const ciudad = (document.getElementById('ciudad') as HTMLInputElement).value;
    const pais = (document.getElementById('pais') as HTMLInputElement).value;
    const direccion = (document.getElementById('direccion') as HTMLInputElement).value;
    if (ciudad || pais || direccion) {
      updates.ubicacion = { ciudad, pais, direccion };
    }

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const telefono = (document.getElementById('telefono') as HTMLInputElement).value;
    const web = (document.getElementById('web') as HTMLInputElement).value;
    const linkedin = (document.getElementById('linkedin') as HTMLInputElement).value;
    if (email || telefono || web || linkedin) {
      updates.contacto = { email, telefono, web, linkedin };
    }

    const logo = (document.getElementById('logo') as HTMLInputElement).value;
    if (logo) updates.logo = logo;

    const especialidades = (document.getElementById('especialidades') as HTMLInputElement).value;
    if (especialidades) updates.especialidades = especialidades.split(',').map((s) => s.trim()).filter(Boolean);

    const servicios = (document.getElementById('servicios') as HTMLTextAreaElement).value;
    if (servicios) updates.servicios = servicios.split('\n').map((s) => s.trim()).filter(Boolean);

    try {
      const resp = await authFetch('/api/ficha/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, updates }),
      });

      const data = await resp.json();
      if (resp.ok) {
        showAlert('Ficha actualizada correctamente', 'success');
      } else if (resp.status === 403) {
        notOwner.classList.remove('hidden');
        editPanel.classList.add('hidden');
      } else {
        showAlert(data.error || 'Error actualizando ficha');
      }
    } catch (err) {
      showAlert('Error de conexión');
    }

    submitBtn.textContent = 'Guardar Cambios';
    submitBtn.removeAttribute('disabled');
  });
</script>
