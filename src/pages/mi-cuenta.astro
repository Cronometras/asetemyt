---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mi Cuenta" description="Gestiona tus fichas verificadas en ASETEMYT.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Loading state -->
    <div id="loading" class="text-center py-20">
      <div class="inline-block w-8 h-8 border-4 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-steel-500 mt-4">Cargando tu cuenta...</p>
    </div>

    <!-- Not logged in -->
    <div id="notAuth" class="hidden text-center py-20">
      <div class="w-20 h-20 bg-steel-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-steel-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-primary-900 mb-2">Acceso requerido</h2>
      <p class="text-steel-500 mb-6">Inicia sesión para ver tu cuenta</p>
      <a href="/login" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3 rounded-lg transition-colors">
        Iniciar Sesión
      </a>
    </div>

    <!-- Dashboard -->
    <div id="dashboard" class="hidden">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-extrabold text-primary-900">Mi Cuenta</h1>
          <p class="text-steel-500 mt-1">Hola, <span id="userName" class="font-semibold text-steel-700"></span></p>
        </div>
        <button id="logoutBtn" class="text-sm text-steel-500 hover:text-red-600 font-medium transition-colors">
          Cerrar sesión
        </button>
      </div>

      <!-- Success alert -->
      <div id="successAlert" class="hidden mb-6 p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm">
        ✅ Pago completado. Tu ficha ha sido verificada correctamente.
      </div>

      <!-- Fichas verificadas -->
      <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-primary-900">Mis Fichas</h2>
        </div>
        <div id="fichasList" class="space-y-3">
          <p class="text-steel-500 text-sm">Cargando fichas...</p>
        </div>
      </div>

      <!-- Suscripción -->
      <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-accent-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-primary-900">Suscripción</h2>
        </div>
        <div id="subInfo">
          <p class="text-steel-500 text-sm">Cargando...</p>
        </div>
        <button id="portalBtn" class="hidden mt-4 text-sm text-accent-600 hover:text-accent-700 font-semibold">
          Gestionar suscripción →
        </button>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { onAuthStateChanged, logOut, auth, authFetch } from '../lib/auth';

  const loading = document.getElementById('loading')!;
  const notAuth = document.getElementById('notAuth')!;
  const dashboard = document.getElementById('dashboard')!;
  const userName = document.getElementById('userName')!;
  const fichasList = document.getElementById('fichasList')!;
  const subInfo = document.getElementById('subInfo')!;
  const portalBtn = document.getElementById('portalBtn')!;
  const logoutBtn = document.getElementById('logoutBtn')!;
  const successAlert = document.getElementById('successAlert')!;

  // Check for success param from Stripe
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true' || params.get('success') === '1') {
    successAlert.classList.remove('hidden');
    window.history.replaceState({}, '', '/mi-cuenta');
  }

  const statusLabels: Record<string, { label: string; color: string }> = {
    active: { label: 'Activa', color: 'bg-green-100 text-green-700' },
    past_due: { label: 'Pago pendiente', color: 'bg-amber-100 text-amber-700' },
    canceled: { label: 'Cancelada', color: 'bg-red-100 text-red-700' },
    unpaid: { label: 'Impagada', color: 'bg-red-100 text-red-700' },
    trialing: { label: 'Periodo de prueba', color: 'bg-blue-100 text-blue-700' },
  };

  onAuthStateChanged(auth, async (user) => {
    loading.classList.add('hidden');
    if (!user) {
      notAuth.classList.remove('hidden');
      return;
    }

    dashboard.classList.remove('hidden');
    userName.textContent = user.displayName || user.email || 'Usuario';

    // Load user data from API
    try {
      const resp = await authFetch('/api/user/data');
      if (!resp.ok) {
        fichasList.innerHTML = '<p class="text-steel-500 text-sm">No tienes fichas verificadas todavía.</p>';
        subInfo.innerHTML = '<p class="text-steel-500 text-sm">No tienes suscripción activa.</p>';
        return;
      }

      const data = await resp.json();

      // Render fichas
      if (data.fichas && data.fichas.length > 0) {
        fichasList.innerHTML = data.fichas.map((f: any) => `
          <div class="flex items-center justify-between p-4 bg-steel-50 rounded-xl">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                ${f.verificado
                  ? '<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
                  : '<span class="text-steel-500 font-bold text-sm">?</span>'}
              </div>
              <div>
                <p class="font-semibold text-steel-700">${f.nombre || f.slug}</p>
                <p class="text-xs text-steel-500">${f.verificado ? '✓ Verificada' : 'Pendiente de verificación'}</p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <a href="/directorio/${f.slug}" class="text-xs text-accent-600 hover:text-accent-700 font-medium">Ver</a>
              ${f.verificado ? `<a href="/editar/${f.slug}" class="text-xs text-accent-600 hover:text-accent-700 font-medium">Editar</a>` : ''}
            </div>
          </div>
        `).join('');
      } else {
        fichasList.innerHTML = `
          <div class="flex items-center gap-3 p-4 bg-steel-50 rounded-xl">
            <div class="w-10 h-10 bg-steel-200 rounded-lg flex items-center justify-center text-steel-500 font-bold">?</div>
            <div>
              <p class="font-semibold text-steel-700">Tus fichas aparecerán aquí</p>
              <p class="text-sm text-steel-500">Reclama una ficha del directorio para empezar</p>
            </div>
          </div>
          <a href="/directorio" class="inline-block mt-3 text-sm text-accent-600 hover:text-accent-700 font-semibold">
            Explorar directorio →
          </a>
        `;
      }

      // Render subscription
      if (data.subscriptions && data.subscriptions.length > 0) {
        const sub = data.subscriptions[0]; // Show most recent
        const statusInfo = statusLabels[sub.status] || { label: sub.status, color: 'bg-steel-100 text-steel-700' };
        const periodEnd = sub.currentPeriodEnd ? new Date(sub.currentPeriodEnd).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A';

        subInfo.innerHTML = `
          <div class="flex items-center gap-3">
            <span class="inline-block text-xs font-bold px-3 py-1 rounded-full ${statusInfo.color}">
              ${statusInfo.label}
            </span>
            <span class="text-sm text-steel-500">Ficha: <strong>${sub.slug}</strong></span>
          </div>
          <p class="text-sm text-steel-500 mt-2">
            ${sub.status === 'active' ? `Próxima renovación: ${periodEnd}` : `Válido hasta: ${periodEnd}`}
          </p>
        `;
        portalBtn.classList.remove('hidden');
      } else {
        subInfo.innerHTML = '<p class="text-steel-500 text-sm">No tienes suscripción activa.</p>';
      }

    } catch (err) {
      fichasList.innerHTML = '<p class="text-red-500 text-sm">Error cargando datos.</p>';
      subInfo.innerHTML = '<p class="text-red-500 text-sm">Error cargando datos.</p>';
    }
  });

  logoutBtn.addEventListener('click', async () => {
    await logOut();
    window.location.href = '/';
  });

  portalBtn.addEventListener('click', async () => {
    try {
      const resp = await authFetch('/api/stripe/portal', { method: 'POST' });
      const data = await resp.json();
      if (data.url) window.location.href = data.url;
    } catch (err) {
      console.error('Error opening portal:', err);
    }
  });
</script>
