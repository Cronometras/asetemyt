---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mi Cuenta" description="Gestiona tus fichas verificadas en ASETEMYT.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Loading state -->
    <div id="loading" class="text-center py-20">
      <div class="inline-block w-8 h-8 border-4 border-accent-500 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-steel-500 mt-4">Cargando tu cuenta...</p>
    </div>

    <!-- Not logged in -->
    <div id="notAuth" class="hidden text-center py-20">
      <div class="w-20 h-20 bg-steel-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-steel-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-primary-900 mb-2">Acceso requerido</h2>
      <p class="text-steel-500 mb-6">Inicia sesión para ver tu cuenta</p>
      <a href="/login" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3 rounded-lg transition-colors">
        Iniciar Sesión
      </a>
    </div>

    <!-- Dashboard -->
    <div id="dashboard" class="hidden">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-extrabold text-primary-900">Mi Cuenta</h1>
          <p class="text-steel-500 mt-1">Hola, <span id="userName" class="font-semibold text-steel-700"></span></p>
        </div>
        <button id="logoutBtn" class="text-sm text-steel-500 hover:text-red-600 font-medium transition-colors">
          Cerrar sesión
        </button>
      </div>

      <!-- Success alert -->
      <div id="successAlert" class="hidden mb-6 p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm">
        ✅ Pago completado. Tu ficha ha sido verificada correctamente.
      </div>

      <!-- Fichas verificadas -->
      <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-primary-900">Mis Fichas</h2>
        </div>
        <div id="fichasList" class="space-y-3">
          <p class="text-steel-500 text-sm">Cargando fichas...</p>
        </div>
      </div>

      <!-- Suscripción -->
      <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-accent-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-primary-900">Suscripción</h2>
        </div>
        <div id="subInfo">
          <p class="text-steel-500 text-sm">Cargando...</p>
        </div>
        <button id="portalBtn" class="hidden mt-4 text-sm text-accent-600 hover:text-accent-700 font-semibold">
          Gestionar suscripción →
        </button>
      </div>

      <!-- ===== ADMIN PANEL ===== -->
      <div id="adminSection" class="hidden">
        <div class="bg-gradient-to-br from-purple-50 via-indigo-50 to-blue-50 border border-purple-200 rounded-2xl shadow-lg p-6 mb-6">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center">
              <span class="text-xl">👑</span>
            </div>
            <div>
              <h2 class="text-xl font-bold text-purple-900">Administración</h2>
              <p class="text-purple-600 text-sm">Gestiona cupones y solicitudes</p>
            </div>
          </div>

          <!-- Admin nav links -->
          <div class="flex flex-wrap gap-3 mb-6">
            <a href="/admin/claims" class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg border border-purple-200 text-purple-700 hover:bg-purple-50 font-medium text-sm transition-colors">
              📋 Solicitudes de verificación
            </a>
          </div>

          <!-- Tabs -->
          <div class="flex flex-wrap gap-2 mb-6">
            <button id="tabCoupons" class="admin-tab px-4 py-2 rounded-lg text-sm font-medium bg-purple-600 text-white shadow-md">
              🎫 Cupones
            </button>
            <button id="tabCreate" class="admin-tab px-4 py-2 rounded-lg text-sm font-medium bg-white text-purple-700 border border-purple-200 hover:bg-purple-100">
              ➕ Crear Cupón
            </button>
          </div>

          <!-- Tab: Coupon list -->
          <div id="panelCoupons" class="bg-white rounded-xl shadow-md border border-purple-100 p-4 sm:p-6">
            <div id="couponsList">
              <p class="text-steel-500 text-sm">Cargando cupones...</p>
            </div>
          </div>

          <!-- Tab: Create coupon -->
          <div id="panelCreate" class="hidden bg-white rounded-xl shadow-md border border-purple-100 p-4 sm:p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Crear Nuevo Cupón</h3>
            <form id="couponForm" class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Código *</label>
                <input type="text" id="couponCode" required uppercase
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 font-mono text-lg"
                  placeholder="Ej: EMPRESA2024" />
                <p class="text-xs text-gray-500 mt-1">Se convertirá a mayúsculas automáticamente</p>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
                <input type="text" id="couponDesc"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500"
                  placeholder="Nota interna sobre este cupón" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de descuento *</label>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                  <label class="coupon-type-option flex items-center gap-3 p-4 rounded-lg border-2 border-purple-500 bg-purple-50 cursor-pointer" data-type="free">
                    <input type="radio" name="couponType" value="free" checked class="hidden" />
                    <span class="text-2xl">🆓</span>
                    <span class="font-medium text-gray-700">Gratis</span>
                  </label>
                  <label class="coupon-type-option flex items-center gap-3 p-4 rounded-lg border-2 border-gray-200 hover:border-purple-300 cursor-pointer" data-type="discount">
                    <input type="radio" name="couponType" value="discount" class="hidden" />
                    <span class="text-2xl">💰</span>
                    <span class="font-medium text-gray-700">Descuento %</span>
                  </label>
                  <label class="coupon-type-option flex items-center gap-3 p-4 rounded-lg border-2 border-gray-200 hover:border-purple-300 cursor-pointer" data-type="trial">
                    <input type="radio" name="couponType" value="trial" class="hidden" />
                    <span class="text-2xl">📅</span>
                    <span class="font-medium text-gray-700">Meses gratis</span>
                  </label>
                </div>
              </div>

              <div id="valueField" class="hidden">
                <label id="valueLabel" class="block text-sm font-medium text-gray-700 mb-1">Valor *</label>
                <div class="relative">
                  <input type="number" id="couponValue" min="1" max="100"
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 pr-12" />
                  <span id="valueUnit" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500">%</span>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Usos máximos</label>
                  <input type="number" id="couponMaxUses" min="0" value="0"
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" />
                  <p class="text-xs text-gray-500 mt-1">0 = ilimitados</p>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Caduca</label>
                  <input type="datetime-local" id="couponExpiry"
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500" />
                  <p class="text-xs text-gray-500 mt-1">Vacío = sin caducidad</p>
                </div>
              </div>

              <div id="formError" class="hidden text-red-600 text-sm bg-red-50 p-3 rounded-lg"></div>
              <div id="formSuccess" class="hidden text-green-600 text-sm bg-green-50 p-3 rounded-lg"></div>

              <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-6 rounded-lg transition-colors">
                Crear Cupón
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { onAuthStateChanged, logOut, auth, authFetch } from '../lib/auth';

  const loading = document.getElementById('loading')!;
  const notAuth = document.getElementById('notAuth')!;
  const dashboard = document.getElementById('dashboard')!;
  const userName = document.getElementById('userName')!;
  const fichasList = document.getElementById('fichasList')!;
  const subInfo = document.getElementById('subInfo')!;
  const portalBtn = document.getElementById('portalBtn')!;
  const logoutBtn = document.getElementById('logoutBtn')!;
  const successAlert = document.getElementById('successAlert')!;

  // Check for success param from Stripe
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true' || params.get('success') === '1') {
    successAlert.classList.remove('hidden');
    window.history.replaceState({}, '', '/mi-cuenta');
  }

  const statusLabels: Record<string, { label: string; color: string }> = {
    active: { label: 'Activa', color: 'bg-green-100 text-green-700' },
    past_due: { label: 'Pago pendiente', color: 'bg-amber-100 text-amber-700' },
    canceled: { label: 'Cancelada', color: 'bg-red-100 text-red-700' },
    unpaid: { label: 'Impagada', color: 'bg-red-100 text-red-700' },
    trialing: { label: 'Periodo de prueba', color: 'bg-blue-100 text-blue-700' },
  };

  onAuthStateChanged(auth, async (user) => {
    loading.classList.add('hidden');
    if (!user) {
      notAuth.classList.remove('hidden');
      return;
    }

    dashboard.classList.remove('hidden');
    userName.textContent = user.displayName || user.email || 'Usuario';

    // Check admin status (shows admin panel if applicable)
    checkAdmin();

    // Load user data from API
    try {
      const resp = await authFetch('/api/user/data');
      if (!resp.ok) {
        fichasList.innerHTML = '<p class="text-steel-500 text-sm">No tienes fichas verificadas todavía.</p>';
        subInfo.innerHTML = '<p class="text-steel-500 text-sm">No tienes suscripción activa.</p>';
        return;
      }

      const data = await resp.json();

      // Render fichas
      if (data.fichas && data.fichas.length > 0) {
        fichasList.innerHTML = data.fichas.map((f: any) => `
          <div class="flex items-center justify-between p-4 bg-steel-50 rounded-xl">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                ${f.verificado
                  ? '<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
                  : '<span class="text-steel-500 font-bold text-sm">?</span>'}
              </div>
              <div>
                <p class="font-semibold text-steel-700">${f.nombre || f.slug}</p>
                <p class="text-xs text-steel-500">${f.verificado ? '✓ Verificada' : 'Pendiente de verificación'}</p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <a href="/directorio/${f.slug}" class="text-xs text-accent-600 hover:text-accent-700 font-medium">Ver</a>
              ${f.verificado ? `<a href="/editar/${f.slug}" class="text-xs text-accent-600 hover:text-accent-700 font-medium">Editar</a>` : ''}
            </div>
          </div>
        `).join('');
      } else {
        fichasList.innerHTML = `
          <div class="flex items-center gap-3 p-4 bg-steel-50 rounded-xl">
            <div class="w-10 h-10 bg-steel-200 rounded-lg flex items-center justify-center text-steel-500 font-bold">?</div>
            <div>
              <p class="font-semibold text-steel-700">Tus fichas aparecerán aquí</p>
              <p class="text-sm text-steel-500">Reclama una ficha del directorio para empezar</p>
            </div>
          </div>
          <a href="/directorio" class="inline-block mt-3 text-sm text-accent-600 hover:text-accent-700 font-semibold">
            Explorar directorio →
          </a>
        `;
      }

      // Render subscription
      if (data.subscriptions && data.subscriptions.length > 0) {
        const sub = data.subscriptions[0]; // Show most recent
        const statusInfo = statusLabels[sub.status] || { label: sub.status, color: 'bg-steel-100 text-steel-700' };
        const periodEnd = sub.currentPeriodEnd ? new Date(sub.currentPeriodEnd).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A';

        subInfo.innerHTML = `
          <div class="flex items-center gap-3">
            <span class="inline-block text-xs font-bold px-3 py-1 rounded-full ${statusInfo.color}">
              ${statusInfo.label}
            </span>
            <span class="text-sm text-steel-500">Ficha: <strong>${sub.slug}</strong></span>
          </div>
          <p class="text-sm text-steel-500 mt-2">
            ${sub.status === 'active' ? `Próxima renovación: ${periodEnd}` : `Válido hasta: ${periodEnd}`}
          </p>
        `;
        portalBtn.classList.remove('hidden');
      } else {
        subInfo.innerHTML = '<p class="text-steel-500 text-sm">No tienes suscripción activa.</p>';
      }

    } catch (err) {
      fichasList.innerHTML = '<p class="text-red-500 text-sm">Error cargando datos.</p>';
      subInfo.innerHTML = '<p class="text-red-500 text-sm">Error cargando datos.</p>';
    }
  });

  logoutBtn.addEventListener('click', async () => {
    await logOut();
    window.location.href = '/';
  });

  portalBtn.addEventListener('click', async () => {
    try {
      const resp = await authFetch('/api/stripe/portal', { method: 'POST' });
      const data = await resp.json();
      if (data.url) window.location.href = data.url;
    } catch (err) {
      console.error('Error opening portal:', err);
    }
  });

  // ===== ADMIN PANEL LOGIC =====
  const adminSection = document.getElementById('adminSection')!;
  const tabCoupons = document.getElementById('tabCoupons')!;
  const tabCreate = document.getElementById('tabCreate')!;
  const panelCoupons = document.getElementById('panelCoupons')!;
  const panelCreate = document.getElementById('panelCreate')!;
  const couponsList = document.getElementById('couponsList')!;
  const couponForm = document.getElementById('couponForm') as HTMLFormElement;
  const formError = document.getElementById('formError')!;
  const formSuccess = document.getElementById('formSuccess')!;

  // Check admin status after auth
  async function checkAdmin() {
    try {
      const resp = await authFetch('/api/admin/status');
      const data = await resp.json();
      if (data.admin) {
        adminSection.classList.remove('hidden');
        loadCoupons();
      }
    } catch {}
  }

  // Tab switching
  tabCoupons.addEventListener('click', () => {
    tabCoupons.className = 'admin-tab px-4 py-2 rounded-lg text-sm font-medium bg-purple-600 text-white shadow-md';
    tabCreate.className = 'admin-tab px-4 py-2 rounded-lg text-sm font-medium bg-white text-purple-700 border border-purple-200 hover:bg-purple-100';
    panelCoupons.classList.remove('hidden');
    panelCreate.classList.add('hidden');
  });

  tabCreate.addEventListener('click', () => {
    tabCreate.className = 'admin-tab px-4 py-2 rounded-lg text-sm font-medium bg-purple-600 text-white shadow-md';
    tabCoupons.className = 'admin-tab px-4 py-2 rounded-lg text-sm font-medium bg-white text-purple-700 border border-purple-200 hover:bg-purple-100';
    panelCreate.classList.remove('hidden');
    panelCoupons.classList.add('hidden');
  });

  // Coupon type selection
  const typeOptions = document.querySelectorAll('.coupon-type-option');
  const valueField = document.getElementById('valueField')!;
  const valueLabel = document.getElementById('valueLabel')!;
  const valueUnit = document.getElementById('valueUnit')!;
  const couponValue = document.getElementById('couponValue') as HTMLInputElement;

  typeOptions.forEach(opt => {
    opt.addEventListener('click', () => {
      typeOptions.forEach(o => {
        o.className = 'coupon-type-option flex items-center gap-3 p-4 rounded-lg border-2 border-gray-200 hover:border-purple-300 cursor-pointer';
      });
      opt.className = 'coupon-type-option flex items-center gap-3 p-4 rounded-lg border-2 border-purple-500 bg-purple-50 cursor-pointer';
      const type = (opt as HTMLElement).dataset.type;
      if (type === 'free') {
        valueField.classList.add('hidden');
      } else {
        valueField.classList.remove('hidden');
        if (type === 'discount') {
          valueLabel.textContent = 'Porcentaje de descuento *';
          valueUnit.textContent = '%';
          couponValue.max = '100';
          couponValue.placeholder = '25';
        } else {
          valueLabel.textContent = 'Meses gratis *';
          valueUnit.textContent = 'meses';
          couponValue.max = '';
          couponValue.placeholder = '3';
        }
      }
    });
  });

  // Load coupons
  async function loadCoupons() {
    try {
      const resp = await authFetch('/api/admin/coupons');
      const data = await resp.json();
      if (!data.coupons || data.coupons.length === 0) {
        couponsList.innerHTML = '<p class="text-steel-500 text-sm">No hay cupones creados.</p>';
        return;
      }
      couponsList.innerHTML = data.coupons.map((c: any) => {
        const expired = c.expiresAt && new Date(c.expiresAt) < new Date();
        const maxedOut = c.maxUses > 0 && c.usedCount >= c.maxUses;
        const statusBadge = !c.activo
          ? '<span class="text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded-full">Inactivo</span>'
          : expired
          ? '<span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full">Expirado</span>'
          : maxedOut
          ? '<span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Agotado</span>'
          : '<span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Activo</span>';

        const typeIcon = c.type === 'free' ? '🆓' : c.type === 'discount' ? '💰' : '📅';
        const typeLabel = c.type === 'free' ? 'Gratis' : c.type === 'discount' ? `${c.value}%` : `${c.value} meses`;

        return `
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 bg-steel-50 rounded-xl mb-3 ${!c.activo ? 'opacity-60' : ''}">
            <div class="flex items-center gap-3">
              <span class="text-2xl">${typeIcon}</span>
              <div>
                <div class="flex items-center gap-2">
                  <code class="font-bold font-mono bg-purple-100 text-purple-800 px-2 py-0.5 rounded text-sm">${c.code}</code>
                  ${statusBadge}
                </div>
                <p class="text-xs text-steel-500 mt-1">
                  ${typeLabel} · Usos: ${c.usedCount}${c.maxUses > 0 ? '/' + c.maxUses : ''} (∞)
                  ${c.expiresAt ? ' · Caduca: ' + new Date(c.expiresAt).toLocaleDateString('es-ES') : ''}
                  ${c.descripcion ? ' · ' + c.descripcion : ''}
                </p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <button onclick="toggleCoupon('${c.id}', ${!c.activo})"
                class="p-2 rounded-lg ${c.activo ? 'text-green-600 hover:bg-green-100' : 'text-gray-400 hover:bg-gray-100'} transition-colors"
                title="${c.activo ? 'Desactivar' : 'Activar'}">
                ${c.activo ? '✅' : '⬜'}
              </button>
              <button onclick="deleteCoupon('${c.id}', '${c.code}')"
                class="p-2 text-red-600 hover:bg-red-100 rounded-lg transition-colors"
                title="Eliminar">
                🗑️
              </button>
            </div>
          </div>
        `;
      }).join('');
    } catch {
      couponsList.innerHTML = '<p class="text-red-500 text-sm">Error cargando cupones.</p>';
    }
  }

  // Toggle coupon active
  (window as any).toggleCoupon = async (id: string, activo: boolean) => {
    try {
      await authFetch('/api/admin/coupons', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, activo }),
      });
      loadCoupons();
    } catch {
      alert('Error actualizando cupón');
    }
  };

  // Delete coupon
  (window as any).deleteCoupon = async (id: string, code: string) => {
    if (!confirm(`¿Eliminar el cupón ${code}?`)) return;
    try {
      await authFetch('/api/admin/coupons', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      loadCoupons();
    } catch {
      alert('Error eliminando cupón');
    }
  };

  // Create coupon form
  couponForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.classList.add('hidden');
    formSuccess.classList.add('hidden');

    const code = (document.getElementById('couponCode') as HTMLInputElement).value.trim();
    const descripcion = (document.getElementById('couponDesc') as HTMLInputElement).value.trim();
    const typeRadio = document.querySelector('input[name="couponType"]:checked') as HTMLInputElement;
    const type = typeRadio?.value || 'free';
    const maxUses = Number((document.getElementById('couponMaxUses') as HTMLInputElement).value || 0);
    const expiryEl = document.getElementById('couponExpiry') as HTMLInputElement;
    const expiresAt = expiryEl.value ? new Date(expiryEl.value).toISOString() : null;

    let value = 0;
    if (type !== 'free') {
      value = Number(couponValue.value);
      if (!value || value < 1) {
        formError.textContent = 'Introduce un valor válido';
        formError.classList.remove('hidden');
        return;
      }
      if (type === 'discount' && value > 100) {
        formError.textContent = 'El descuento no puede superar el 100%';
        formError.classList.remove('hidden');
        return;
      }
    }

    try {
      const resp = await authFetch('/api/admin/coupons', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, type, value, maxUses, expiresAt, descripcion }),
      });
      const data = await resp.json();
      if (!resp.ok) {
        formError.textContent = data.error || 'Error creando cupón';
        formError.classList.remove('hidden');
        return;
      }
      formSuccess.textContent = `✅ Cupón ${data.code} creado correctamente`;
      formSuccess.classList.remove('hidden');
      couponForm.reset();
      // Reset type selector to free
      typeOptions.forEach(o => {
        o.className = 'coupon-type-option flex items-center gap-3 p-4 rounded-lg border-2 border-gray-200 hover:border-purple-300 cursor-pointer';
      });
      typeOptions[0].className = 'coupon-type-option flex items-center gap-3 p-4 rounded-lg border-2 border-purple-500 bg-purple-50 cursor-pointer';
      valueField.classList.add('hidden');
      // Switch to list tab and reload
      tabCoupons.click();
      loadCoupons();
    } catch {
      formError.textContent = 'Error de conexión';
      formError.classList.remove('hidden');
    }
  });

  // Uppercase coupon code input
  (document.getElementById('couponCode') as HTMLInputElement).addEventListener('input', (e) => {
    (e.target as HTMLInputElement).value = (e.target as HTMLInputElement).value.toUpperCase();
  });
</script>
