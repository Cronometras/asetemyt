---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Página no encontrada (404)"
  description="La página que buscas no existe o ha sido movida. Vuelve al directorio de cronometraje industrial de ASETEMYT."
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center px-4 py-20">
    <div class="text-center max-w-xl">
      <p class="text-9xl font-extrabold text-blue-600" aria-hidden="true">404</p>
      <h1 class="mt-4 text-3xl md:text-4xl font-bold text-gray-900">
        Página no encontrada
      </h1>
      <p class="mt-3 text-lg text-gray-600">
        Lo sentimos, la página que buscas no existe o ha sido movida.
        Desde aquí puedes volver al inicio o explorar las secciones principales.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="/"
          class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition"
        >Volver al inicio</a>
        <a
          href="/directorio"
          class="bg-white text-blue-700 border border-blue-200 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition"
        >Explorar directorio</a>
        <a
          href="/blog"
          class="bg-white text-blue-700 border border-blue-200 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition"
        >Leer el blog</a>
      </div>
      <nav class="mt-10 text-sm text-gray-500" aria-label="Páginas populares">
        <p class="font-semibold text-gray-700 mb-2">Páginas populares</p>
        <ul class="flex flex-wrap justify-center gap-x-4 gap-y-1">
          <li><a class="hover:text-blue-600" href="/software">Software MTM</a></li>
          <li><a class="hover:text-blue-600" href="/glosario">Glosario</a></li>
          <li><a class="hover:text-blue-600" href="/comparador">Comparador</a></li>
          <li><a class="hover:text-blue-600" href="/empleo">Empleo</a></li>
        </ul>
      </nav>
    </div>
  </section>
</Layout>
