---
  export const prerender = true;
  import Layout from '../../layouts/Layout.astro';
  import ReviewsSection from '../../components/ReviewsSection.astro';
  import RequestQuote from '../../components/RequestQuote.astro';
  import Certificate from '../../components/Certificate.astro';
  import PartnerBadge from '../../components/PartnerBadge.astro';
  import CasesSection from '../../components/CasesSection.astro';
  import { getDirectoryEntries, getDirectoryEntryBySlug } from '../../lib/firebase';

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    entries = await getDirectoryEntries();
  } catch (e) {
    console.error('Error fetching entries for static paths:', e);
  }

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {
  return Astro.redirect('/directorio');
}

const tipoColors: Record<string, string> = {
  empresa: 'bg-blue-100 text-blue-700',
  consultor: 'bg-green-100 text-green-700',
  freelance: 'bg-purple-100 text-purple-700',
};
---

<Layout title={entry.nombre} description={entry.descripcion}>
  <!-- BreadcrumbList structured data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://asetemyt.com/" },
        { "@type": "ListItem", "position": 2, "name": "Directorio", "item": "https://asetemyt.com/directorio" },
        { "@type": "ListItem", "position": 3, "name": {JSON.stringify(entry.nombre)}, "item": {JSON.stringify(`https://asetemyt.com/directorio/${entry.slug}`)} }
      ]
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": entry.tipo === 'empresa' ? "Organization" : "Person",
      "name": {JSON.stringify(entry.nombre)},
      "url": {JSON.stringify(`https://asetemyt.com/directorio/${entry.slug}`)},
      "description": {JSON.stringify(entry.descripcion || '')}
    }
  </script>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8">
      <a href="/directorio" onclick="event.preventDefault(); window.history.length > 1 ? window.history.back() : window.location.href='/directorio'" class="text-accent-600 hover:text-accent-700 text-sm font-medium flex items-center gap-1 cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver
      </a>
    </nav>

    <!-- Profile Header -->
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-8">
      <div class="bg-gradient-to-r from-primary-800 to-primary-900 p-8">
        <div class="flex items-center gap-6">
          {entry.logo ? (
            <img src={entry.logo} alt={entry.nombre} class="w-24 h-24 rounded-xl object-cover shadow-lg border-2 border-white/20" />
          ) : (
            <div class="w-24 h-24 rounded-xl bg-accent-500 flex items-center justify-center text-white font-bold text-3xl shadow-lg">
              {entry.nombre?.[0]?.toUpperCase() || '?'}
            </div>
          )}
          <div>
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-3xl font-extrabold text-white">{entry.nombre}</h1>
              {entry.verificado && (
                <span class="bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full flex items-center gap-1">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  Verificado
                </span>
              )}
              <PartnerBadge tools={entry.herramientas || []} />
            </div>
            <span class={`inline-block text-sm font-semibold px-3 py-1 rounded-full ${tipoColors[entry.tipo] || 'bg-steel-100 text-steel-600'}`}>
              {entry.tipo === 'empresa' ? 'Empresa' : entry.tipo === 'consultor' ? 'Consultor' : entry.tipo === 'freelance' ? 'Freelancer' : entry.tipo || 'Sin tipo'}
            </span>
          </div>
        </div>
      </div>

      <div class="p-8">
        <!-- Description -->
        {entry.descripcion && (
          <div class="mb-8">
            <h2 class="text-lg font-bold text-primary-800 mb-3">Acerca de</h2>
            <p class="text-steel-600 leading-relaxed">{entry.descripcion}</p>
          </div>
        )}

        <!-- Especialidades -->
        {entry.especialidades?.length > 0 && (
          <div class="mb-8">
            <h2 class="text-lg font-bold text-primary-800 mb-3">Especialidades</h2>
            <div class="flex flex-wrap gap-2">
              {entry.especialidades.map((esp: string) => (
                <a
                  href={`/directorio?especialidad=${esp}`}
                  class="bg-primary-50 text-primary-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary-100 transition-colors"
                >
                  {esp.toUpperCase()}
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Servicios -->
        {entry.servicios?.length > 0 && (
          <div class="mb-8">
            <h2 class="text-lg font-bold text-primary-800 mb-3">Servicios</h2>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
              {entry.servicios.map((servicio: string) => (
                <li class="flex items-center gap-2 text-steel-600">
                  <svg class="w-5 h-5 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {servicio}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Ubicación -->
        {entry.ubicacion && (
          <div class="mb-8">
            <h2 class="text-lg font-bold text-primary-800 mb-3">Ubicación</h2>
            <div class="flex items-start gap-3 text-steel-600">
              <svg class="w-5 h-5 text-steel-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                {entry.ubicacion.direccion && <p>{entry.ubicacion.direccion}</p>}
                <p>
                  {[entry.ubicacion.ciudad, entry.ubicacion.pais].filter(Boolean).join(', ')}
                </p>
              </div>
            </div>
          </div>
        )}

        <!-- Contacto -->
        {entry.contacto && (
          <div>
            <h2 class="text-lg font-bold text-primary-800 mb-3">Contacto</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {entry.contacto.email && (
                <a href={`mailto:${entry.contacto.email}`} class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg hover:bg-steel-100 transition-colors">
                  <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <span class="text-sm text-steel-700">{entry.contacto.email}</span>
                </a>
              )}
              {entry.contacto.telefono && (
                <a href={`tel:${entry.contacto.telefono}`} class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg hover:bg-steel-100 transition-colors">
                  <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span class="text-sm text-steel-700">{entry.contacto.telefono}</span>
                </a>
              )}
              {entry.contacto.web && (
                <a href={entry.contacto.web.startsWith('http') ? entry.contacto.web : `https://${entry.contacto.web}`} target="_blank" rel="noopener" class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg hover:bg-steel-100 transition-colors">
                  <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                  <span class="text-sm text-steel-700">{entry.contacto.web}</span>
                </a>
              )}
              {entry.contacto.linkedin && (
                <a href={entry.contacto.linkedin.startsWith('http') ? entry.contacto.linkedin : `https://linkedin.com/in/${entry.contacto.linkedin}`} target="_blank" rel="noopener" class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg hover:bg-steel-100 transition-colors">
                  <svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  <span class="text-sm text-steel-700">LinkedIn</span>
                </a>
              )}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Reclamar ficha CTA (not verified) -->
    {!entry.verificado && (
      <div class="mt-8 p-6 bg-gradient-to-r from-accent-50 to-accent-100 rounded-xl border border-accent-200">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-accent-500 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-primary-900">¿Eres el propietario de esta ficha?</h3>
            <p class="text-sm text-steel-600 mt-1 mb-3">Verifícala para editar los datos y mostrar el badge de confianza. 50€/año.</p>
            <a href={`/reclamar/${entry.slug}`}
              class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-5 py-2.5 rounded-lg text-sm transition-colors">
              Reclamar esta ficha →
            </a>
          </div>
        </div>
      </div>
    )}

    <!-- Editar ficha CTA (verified — shown to owner only via client-side check) -->
    {entry.verificado && (
      <div id="ownerEditCTA" class="hidden mt-8 p-6 bg-gradient-to-r from-green-50 to-green-100 rounded-xl border border-green-200">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-primary-900">Tu ficha verificada</h3>
            <p class="text-sm text-steel-600 mt-1 mb-3">Edita los datos de tu ficha para mantenerla actualizada.</p>
            <a href={`/editar/${entry.slug}`}
              class="inline-block bg-green-600 hover:bg-green-700 text-white font-bold px-5 py-2.5 rounded-lg text-sm transition-colors">
              Editar ficha →
            </a>
          </div>
        </div>
      </div>
    )}
  </section>
  {/* Reviews */}
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    {/* Lead Gen: Solicitar Presupuesto */}
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-4">
      <RequestQuote slug={entry.slug} entryName={entry.nombre} services={entry.servicios || []} />
    </div>
    <ReviewsSection slug={entry.slug} entryName={entry.nombre} />
    <CasesSection slug={entry.slug} entryName={entry.nombre} isOwner={false} />
  </section>

  {/* Certificate for verified members */}
  {entry.verificado && (
    <section id="ownerCertSection" class="hidden max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <Certificate entryName={entry.nombre} entrySlug={entry.slug} tipo={entry.tipo} />
    </section>
  )}

  {/* Client-side: show edit CTA to the owner of this verified ficha */}
  {entry.verificado && (
    <script>
      import { onAuthStateChanged, auth, authFetch } from '../../lib/auth';

      const slug = window.location.pathname.split('/').filter(Boolean).pop();

      onAuthStateChanged(auth, async (user) => {
        if (!user || !slug) return;
        try {
          const resp = await authFetch('/api/user/data');
          if (!resp.ok) return;
          const data = await resp.json();
          const isOwner = data.fichas?.some((f: any) => f.slug === slug);
          if (isOwner) {
            document.getElementById('ownerEditCTA')?.classList.remove('hidden');
            document.getElementById('ownerCertSection')?.classList.remove('hidden');
            // Show cases form for owner
            const casesForm = document.getElementById('case-form');
            if (casesForm) {
              document.getElementById('toggle-case-form')?.classList.remove('hidden');
            }
          }
        } catch {}
      });
    </script>
  )}
</Layout>
