---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getDirectoryEntries } from '../../lib/firebase';

const SITE = 'https://asetemyt.com';

let allEntries: any[] = [];
try {
  allEntries = await getDirectoryEntries();
} catch (e) {
  console.error('Error fetching entries for /directorio:', e);
}

const featured = allEntries
  .filter((e) => e.destacado)
  .sort((a, b) => (b.verificado ? 1 : 0) - (a.verificado ? 1 : 0))
  .slice(0, 9);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Directorio de Cronometraje Industrial',
  itemListElement: allEntries.slice(0, 50).map((e: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: e.nombre,
    url: `${SITE}/directorio/${e.slug}`,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Directorio', item: `${SITE}/directorio` },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${SITE}/directorio`,
  name: 'Directorio de Cronometraje Industrial',
  description: 'Directorio de técnicos, consultores y empresas de cronometraje industrial e ingeniería de métodos y tiempos (MTM, MOST, OEE, Lean, Work Sampling).',
  isPartOf: { '@id': `${SITE}#website` },
  about: { '@type': 'Thing', name: 'Cronometraje industrial' },
};
---

<Layout
  title="Directorio de Cronometraje Industrial — Consultores y Empresas | ASETEMYT"
  description="Directorio verificado de consultores y empresas especializados en cronometraje industrial, MTM, MOST, OEE, Lean Manufacturing y Work Sampling en España y Latinoamérica."
  canonical={`${SITE}/directorio`}
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-primary-800 mb-3">
        Directorio de Cronometraje Industrial
      </h1>
      <p class="text-steel-600 text-lg max-w-3xl">
        Encuentra consultores y empresas especializados en cronometraje industrial,
        MTM, MOST, OEE, Lean Manufacturing y Work Sampling. Fichas verificadas
        con datos de contacto, especialidades y ubicación.
      </p>
      <p class="text-sm text-steel-400 mt-2">{allEntries.length} profesionales en el directorio</p>
    </header>

    {featured.length > 0 && (
      <section aria-labelledby="destacados-h2" class="mb-12">
        <h2 id="destacados-h2" class="text-2xl font-bold text-primary-800 mb-4">Destacados</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featured.map((entry: any) => (
            <a
              href={`/directorio/${entry.slug}`}
              class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all hover:-translate-y-1 p-6 group"
            >
              <div class="flex items-start gap-4 mb-4">
                {entry.logo ? (
                  <img
                    src={entry.logo}
                    alt={`Logo de ${entry.nombre}`}
                    class="w-14 h-14 rounded-lg object-cover shadow-sm"
                    width="56"
                    height="56"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="w-14 h-14 rounded-lg bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-xl" aria-hidden="true">
                    {(entry.nombre || '?')[0].toUpperCase()}
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-bold text-primary-800 group-hover:text-accent-600 transition-colors truncate">
                    {entry.nombre}
                  </h3>
                  <span class={`inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mt-1 ${entry.tipo === 'empresa' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700'}`}>
                    {entry.tipo === 'empresa' ? 'Empresa' : 'Consultor'}
                  </span>
                </div>
              </div>
              {entry.descripcion && <p class="text-steel-500 text-sm line-clamp-2 mb-3">{entry.descripcion}</p>}
              <div class="flex flex-wrap gap-1.5 mb-3">
                {(entry.especialidades || []).slice(0, 3).map((esp: string) => (
                  <span class="text-xs bg-steel-100 text-steel-600 px-2 py-0.5 rounded font-medium">{esp}</span>
                ))}
              </div>
              <div class="flex items-center text-sm text-steel-400">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {[entry.ubicacion?.ciudad, entry.ubicacion?.pais].filter(Boolean).join(', ') || 'Sin ubicación'}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section aria-labelledby="todos-h2" class="mb-12">
      <h2 id="todos-h2" class="text-2xl font-bold text-primary-800 mb-4">Todos los profesionales</h2>
      <div id="directory-content">
        <div class="mb-10">
          <div class="h-10 w-96 bg-steel-200 rounded animate-pulse mb-3"></div>
          <div class="h-5 w-[32rem] bg-steel-100 rounded animate-pulse"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {[1,2,3,4,5,6].map(() => (
            <div class="bg-white rounded-xl shadow-md p-6">
              <div class="flex items-start gap-4 mb-4">
                <div class="w-14 h-14 bg-steel-200 rounded-lg animate-pulse"></div>
                <div class="flex-1">
                  <div class="h-5 w-32 bg-steel-200 rounded animate-pulse mb-2"></div>
                  <div class="h-5 w-20 bg-steel-100 rounded-full animate-pulse"></div>
                </div>
              </div>
              <div class="h-4 w-full bg-steel-100 rounded animate-pulse mb-2"></div>
              <div class="h-4 w-3/4 bg-steel-100 rounded animate-pulse mb-3"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="mt-8 bg-gradient-to-r from-primary-800 to-primary-900 rounded-2xl p-8 text-white text-center">
      <h2 class="text-xl md:text-2xl font-bold mb-3">¿Tu empresa no aparece aquí?</h2>
      <p class="text-steel-300 mb-5">Añade tu perfil al directorio gratuito y conecta con clientes potenciales.</p>
      <a href="/anadir" class="inline-flex items-center bg-accent-500 hover:bg-accent-600 text-white px-6 py-3 rounded-lg font-semibold transition-all">
        Añadir mi empresa
      </a>
    </div>
  </section>

  <script>
    import { t, getLang, type Lang } from '../../lib/firebase';
    // NOTE: previously used `db, COLLECTION_CONSULTORES, getDocs, query, orderBy`
    // here to read consultores directly from Firestore. That was replaced
    // with a fetch to /api/directorio/consultores, which is cached in
    // Cloudflare KV (24h TTL, invalidated on mutations). This brought the
    // Firestore reads from ~974/page-load to ~1/day.

    // Filter URLs (?especialidad=...&pais=...) are duplicate-content traps.
    // Inject a noindex meta so Google doesn't index every combination.
    if (window.location.search) {
      const meta = document.createElement('meta');
      meta.name = 'robots';
      meta.content = 'noindex, follow';
      document.head.appendChild(meta);
    }

    let lang: Lang = getLang();

    async function load() {
      const tr = (k: string) => t(k, lang);

      // Cache-first: hit /api/directorio/consultores (server-side KV cache, 24h TTL).
      // Replaces the previous client-side getDocs() which read every listing
      // from Firestore on every page load — that was responsible for the
      // 27k reads/day spike we saw before adding Cloudflare KV.
      const resp = await fetch('/api/directorio/consultores');
      const data = await resp.json();
      let consultores = (data.consultores || []) as any[];

      // Sort: destacado first
      consultores.sort((a, b) => (b.destacado ? 1 : 0) - (a.destacado ? 1 : 0));

      const tipos = [
        { value: 'empresa', label: lang === 'es' ? 'Empresas' : 'Companies' },
        { value: 'consultor', label: lang === 'es' ? 'Consultores' : 'Consultants' },
      ];

      // Normalize country names to prevent duplicates (e.g. "España"/"Spain")
      const countryMap: Record<string, string> = {
        'spain': 'España', 'españa': 'España',
        'germany': 'Alemania', 'alemania': 'Alemania',
        'mexico': 'México', 'méxico': 'México', 'méjico': 'México',
        'peru': 'Perú', 'perú': 'Perú',
        'usa': 'Estados Unidos', 'us': 'Estados Unidos', 'united states': 'Estados Unidos', 'estados unidos': 'Estados Unidos',
        'france': 'Francia', 'francia': 'Francia',
        'italy': 'Italia', 'italia': 'Italia',
        'portugal': 'Portugal',
        'brazil': 'Brasil', 'brasil': 'Brasil',
        'colombia': 'Colombia',
        'argentina': 'Argentina',
        'chile': 'Chile',
        'uk': 'Reino Unido', 'united kingdom': 'Reino Unido', 'reino unido': 'Reino Unido',
        'china': 'China',
        'japan': 'Japón', 'japón': 'Japón',
        'india': 'India',
      };
      consultores.forEach((e: any) => {
        if (e.ubicacion?.pais) {
          const normalized = countryMap[e.ubicacion.pais.toLowerCase().trim()];
          if (normalized) e.ubicacion.pais = normalized;
        }
      });
      const paises = [...new Set(consultores.map((e: any) => e.ubicacion?.pais).filter(Boolean))].sort();
      const provincias = [...new Set(consultores.map((e: any) => e.ubicacion?.provincia).filter(Boolean))].sort();
      const ciudades = [...new Set(consultores.map((e: any) => e.ubicacion?.ciudad).filter(Boolean))].sort();
      const especialidades = ['cronometraje', 'mtm', 'most', 'oee', 'lean'];

      const container = document.getElementById('directory-content')!;

      container.innerHTML = `
        <div class="mb-10">
          <nav class="mb-4 text-sm text-steel-500">
            <a href="/" class="hover:text-accent-600">${tr('home')}</a>
            <span class="mx-2">/</span>
            <span class="text-steel-700">${lang === 'es' ? 'Profesionales' : 'Professionals'}</span>
          </nav>
          <h1 class="text-3xl md:text-4xl font-extrabold text-primary-800 mb-3">${lang === 'es' ? 'Directorio de Profesionales' : 'Professionals Directory'}</h1>
          <p class="text-steel-500 text-lg">${lang === 'es' ? 'Consultores y empresas especializados en ingeniería de métodos y tiempos.' : 'Consultants and companies specialized in methods and time engineering.'}</p>
        </div>

        <!-- Filters -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-8" id="filters-container">
          <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4">
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${tr('search')}</label>
              <input type="text" id="search-input" placeholder="${lang === 'es' ? 'Nombre, especialidad...' : 'Name, specialty...'}"
                class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${tr('type')}</label>
              <select id="filter-tipo" class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none bg-white">
                <option value="">${tr('all')}</option>
                ${tipos.map((t) => `<option value="${t.value}">${t.label}</option>`).join('')}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${tr('specialty')}</label>
              <select id="filter-especialidad" class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none bg-white">
                <option value="">${tr('allSpec')}</option>
                ${especialidades.map((esp) => `<option value="${esp}">${esp.toUpperCase()}</option>`).join('')}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${tr('country')}</label>
              <select id="filter-ubicacion" class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none bg-white">
                <option value="">${tr('allCountries')}</option>
                ${paises.map((p) => `<option value="${(p as string).toLowerCase()}">${p}</option>`).join('')}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${lang === 'es' ? 'Provincia' : 'Province'}</label>
              <select id="filter-provincia" class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none bg-white">
                <option value="">${lang === 'es' ? 'Todas' : 'All'}</option>
                ${provincias.map((p) => `<option value="${(p as string).toLowerCase()}">${p}</option>`).join('')}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-steel-600 mb-1">${lang === 'es' ? 'Ciudad' : 'City'}</label>
              <select id="filter-ciudad" class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none bg-white">
                <option value="">${lang === 'es' ? 'Todas' : 'All'}</option>
                ${ciudades.map((c) => `<option value="${(c as string).toLowerCase()}">${c}</option>`).join('')}
              </select>
            </div>
          </div>
        </div>

        <p class="text-steel-500 mb-4" id="results-count">
          ${consultores.length} ${consultores.length === 1 ? tr('result') : tr('results')}
        </p>

        ${consultores.length === 0 ? `
          <div class="text-center py-20 bg-white rounded-xl shadow">
            <svg class="w-16 h-16 mx-auto text-steel-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <p class="text-steel-400 text-lg">${tr('noEntries')}</p>
            <a href="/anadir" class="inline-block mt-4 text-accent-600 hover:text-accent-700 font-semibold">${tr('addFirst')}</a>
          </div>
        ` : `
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="directory-grid">
            ${consultores.map((entry: any) => `
              <a href="/directorio/${entry.slug}" class="directory-card relative bg-white rounded-xl shadow-md hover:shadow-xl transition-all hover:-translate-y-1 p-6 group ${entry.destacado ? 'ring-2 ring-amber-400 border-amber-300' : ''}"
                data-name="${(entry.nombre || '').toLowerCase()}"
                data-tipo="${entry.tipo || ''}"
                data-especialidades="${(entry.especialidades || []).join(',').toLowerCase()}"
                data-ubicacion="${`${entry.ubicacion?.pais || ''} ${entry.ubicacion?.ciudad || ''}`.toLowerCase()}"
                data-provincia="${(entry.ubicacion?.provincia || '').toLowerCase()}"
                data-ciudad="${(entry.ubicacion?.ciudad || '').toLowerCase()}">
                ${entry.verificado ? '<span class="absolute top-3 right-3 w-5 h-5 bg-green-500 rounded-full flex items-center justify-center shadow-sm" title="Verificado"><svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg></span>' : ''}
                <div class="flex items-start gap-4 mb-4">
                  ${entry.logo
                    ? `<img src="${entry.logo}" alt="${entry.nombre}" class="w-14 h-14 rounded-lg object-cover shadow-sm" />`
                    : `<div class="w-14 h-14 rounded-lg bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-xl">${(entry.nombre || '?')[0].toUpperCase()}</div>`
                  }
                  <div class="flex-1 min-w-0">
                    <h3 class="text-lg font-bold text-primary-800 group-hover:text-accent-600 transition-colors truncate">${entry.nombre}</h3>
                    <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mt-1 ${
                      entry.tipo === 'empresa' ? 'bg-blue-100 text-blue-700' :
                      entry.tipo === 'consultor' ? 'bg-green-100 text-green-700' :
                      'bg-purple-100 text-purple-700'
                    }">
                      ${entry.tipo === 'empresa' ? tr('empresa') : tr('consultor')}
                    </span>
                  </div>
                </div>
                ${entry.descripcion ? `<p class="text-steel-500 text-sm line-clamp-2 mb-3">${entry.descripcion}</p>` : ''}
                <div class="flex flex-wrap gap-1.5 mb-3">
                  ${(entry.especialidades || []).slice(0, 3).map((esp: string) => `<span class="text-xs bg-steel-100 text-steel-600 px-2 py-0.5 rounded font-medium" data-field="${esp}">${esp}</span>`).join('')}
                </div>
                <div class="flex items-center text-sm text-steel-400">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  ${[entry.ubicacion?.ciudad, entry.ubicacion?.pais].filter(Boolean).join(', ') || tr('noLocation')}
                </div>
              </a>
            `).join('')}
          </div>
        `}
      `;

      // Client-side filtering
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const filterTipo = document.getElementById('filter-tipo') as HTMLSelectElement;
      const filterEsp = document.getElementById('filter-especialidad') as HTMLSelectElement;
      const filterLoc = document.getElementById('filter-ubicacion') as HTMLSelectElement;
      const filterProv = document.getElementById('filter-provincia') as HTMLSelectElement;
      const filterCiudad = document.getElementById('filter-ciudad') as HTMLSelectElement;
      const cards = document.querySelectorAll('.directory-card') as NodeListOf<HTMLElement>;
      const countEl = document.getElementById('results-count');

      function applyFilters() {
        const search = searchInput?.value?.toLowerCase() || '';
        const tipo = filterTipo?.value?.toLowerCase() || '';
        const esp = filterEsp?.value?.toLowerCase() || '';
        const loc = filterLoc?.value?.toLowerCase() || '';
        const prov = filterProv?.value?.toLowerCase() || '';
        const ciudad = filterCiudad?.value?.toLowerCase() || '';

        let visible = 0;
        cards.forEach((card) => {
          const name = card.dataset.name || '';
          const cardTipo = card.dataset.tipo || '';
          const cardEsp = card.dataset.especialidades || '';
          const cardLoc = card.dataset.ubicacion || '';
          const cardProv = card.dataset.provincia || '';
          const cardCiudad = card.dataset.ciudad || '';

          const matchSearch = !search || name.includes(search) || cardEsp.includes(search);
          const matchTipo = !tipo || cardTipo === tipo;
          const matchEsp = !esp || cardEsp.includes(esp);
          const matchLoc = !loc || cardLoc.includes(loc);
          const matchProv = !prov || cardProv.includes(prov);
          const matchCiudad = !ciudad || cardCiudad.includes(ciudad);

          const show = matchSearch && matchTipo && matchEsp && matchLoc && matchProv && matchCiudad;
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (countEl) {
          countEl.textContent = `${visible} ${visible === 1 ? tr('result') : tr('results')}`;
        }
      }

      searchInput?.addEventListener('input', applyFilters);
      filterTipo?.addEventListener('change', applyFilters);
      filterEsp?.addEventListener('change', applyFilters);
      filterLoc?.addEventListener('change', applyFilters);
      filterProv?.addEventListener('change', applyFilters);
      filterCiudad?.addEventListener('change', applyFilters);

      // Apply URL params
      const params = new URLSearchParams(window.location.search);
      if (params.get('tipo') && filterTipo) filterTipo.value = params.get('tipo')!;
      if (params.get('especialidad') && filterEsp) filterEsp.value = params.get('especialidad')!;
      if (params.get('ubicacion') && filterLoc) filterLoc.value = params.get('ubicacion')!;
      if (params.get('provincia') && filterProv) filterProv.value = params.get('provincia')!.toLowerCase();
      if (params.get('ciudad') && filterCiudad) filterCiudad.value = params.get('ciudad')!.toLowerCase();
      if (params.toString()) applyFilters();
    }

    function updateLabels() {
      document.querySelectorAll('[data-field]').forEach((el) => {
        const key = (el as HTMLElement).dataset.field!;
        const label = t(key, lang);
        if (label && label !== key) el.textContent = label;
      });
    }

    window.addEventListener('langChange', ((e: CustomEvent) => {
      lang = e.detail;
      load().then(() => updateLabels());
    }) as EventListener);

    load().then(() => updateLabels());
  </script>
</Layout>
