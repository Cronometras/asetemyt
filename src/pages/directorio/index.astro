---
import Layout from '../../layouts/Layout.astro';
import { getDirectoryEntries } from '../../lib/firebase';

let entries: any[] = [];
try {
  entries = await getDirectoryEntries();
} catch (e) {
  console.error('Error fetching directory:', e);
}

const especialidades = ['cronometraje', 'mtm', 'most', 'oee', 'lean'];
const tipos = [
  { value: 'empresa', label: 'Empresas' },
  { value: 'consultor', label: 'Consultores' },
  { value: 'freelance', label: 'Freelancers' },
];

// Unique countries
const paises = [...new Set(entries.map((e) => e.ubicacion?.pais).filter(Boolean))].sort();
---

<Layout title="Directorio">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-primary-800 mb-3">
        Directorio de Cronometraje Industrial
      </h1>
      <p class="text-steel-500 text-lg">
        Consultores, empresas y freelancers especializados en ingeniería de métodos y tiempos.
      </p>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-md p-6 mb-8" id="filters-container">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <!-- Search -->
        <div>
          <label class="block text-sm font-medium text-steel-600 mb-1">Buscar</label>
          <input
            type="text"
            id="search-input"
            placeholder="Nombre, especialidad..."
            class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none transition-all"
          />
        </div>
        <!-- Tipo -->
        <div>
          <label class="block text-sm font-medium text-steel-600 mb-1">Tipo</label>
          <select
            id="filter-tipo"
            class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none bg-white"
          >
            <option value="">Todos</option>
            {tipos.map((t) => (
              <option value={t.value}>{t.label}</option>
            ))}
          </select>
        </div>
        <!-- Especialidad -->
        <div>
          <label class="block text-sm font-medium text-steel-600 mb-1">Especialidad</label>
          <select
            id="filter-especialidad"
            class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none bg-white"
          >
            <option value="">Todas</option>
            {especialidades.map((esp) => (
              <option value={esp}>{esp.toUpperCase()}</option>
            ))}
          </select>
        </div>
        <!-- Ubicación -->
        <div>
          <label class="block text-sm font-medium text-steel-600 mb-1">País</label>
          <select
            id="filter-ubicacion"
            class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 focus:border-accent-500 outline-none bg-white"
          >
            <option value="">Todos</option>
            {paises.map((pais) => (
              <option value={(pais as string).toLowerCase()}>{pais}</option>
            ))}
          </select>
        </div>
      </div>
    </div>

    <!-- Results count -->
    <p class="text-steel-500 mb-4" id="results-count">
      {entries.length} {entries.length === 1 ? 'resultado' : 'resultados'}
    </p>

    <!-- Directory Grid -->
    {entries.length === 0 ? (
      <div class="text-center py-20 bg-white rounded-xl shadow">
        <svg class="w-16 h-16 mx-auto text-steel-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <p class="text-steel-400 text-lg">No hay entradas en el directorio todavía.</p>
        <a href="/anadir" class="inline-block mt-4 text-accent-600 hover:text-accent-700 font-semibold">
          Añade la primera entrada →
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="directory-grid">
        {entries.map((entry: any) => (
          <a
            href={`/directorio/${entry.slug}`}
            class="directory-card bg-white rounded-xl shadow-md hover:shadow-xl transition-all hover:-translate-y-1 p-6 group"
            data-name={entry.nombre?.toLowerCase() || ''}
            data-tipo={entry.tipo || ''}
            data-especialidades={(entry.especialidades || []).join(',').toLowerCase()}
            data-ubicacion={`${entry.ubicacion?.pais || ''} ${entry.ubicacion?.ciudad || ''}`.toLowerCase()}
          >
            <div class="flex items-start gap-4 mb-4">
              {entry.logo ? (
                <img src={entry.logo} alt={entry.nombre} class="w-14 h-14 rounded-lg object-cover shadow-sm" />
              ) : (
                <div class="w-14 h-14 rounded-lg bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-xl">
                  {entry.nombre?.[0]?.toUpperCase() || '?'}
                </div>
              )}
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-bold text-primary-800 group-hover:text-accent-600 transition-colors truncate">
                  {entry.nombre}
                </h3>
                <span class={`inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mt-1 ${
                  entry.tipo === 'empresa' ? 'bg-blue-100 text-blue-700' :
                  entry.tipo === 'consultor' ? 'bg-green-100 text-green-700' :
                  'bg-purple-100 text-purple-700'
                }`}>
                  {entry.tipo || 'Sin tipo'}
                </span>
              </div>
            </div>

            {entry.descripcion && (
              <p class="text-steel-500 text-sm line-clamp-2 mb-3">{entry.descripcion}</p>
            )}

            <div class="flex flex-wrap gap-1.5 mb-3">
              {entry.especialidades?.slice(0, 3).map((esp: string) => (
                <span class="text-xs bg-steel-100 text-steel-600 px-2 py-0.5 rounded font-medium">
                  {esp}
                </span>
              ))}
            </div>

            <div class="flex items-center text-sm text-steel-400">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {[entry.ubicacion?.ciudad, entry.ubicacion?.pais].filter(Boolean).join(', ') || 'Sin ubicación'}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <script>
    // Client-side filtering
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const filterTipo = document.getElementById('filter-tipo') as HTMLSelectElement;
    const filterEsp = document.getElementById('filter-especialidad') as HTMLSelectElement;
    const filterLoc = document.getElementById('filter-ubicacion') as HTMLSelectElement;
    const cards = document.querySelectorAll('.directory-card') as NodeListOf<HTMLElement>;
    const countEl = document.getElementById('results-count');

    function applyFilters() {
      const search = searchInput?.value?.toLowerCase() || '';
      const tipo = filterTipo?.value?.toLowerCase() || '';
      const esp = filterEsp?.value?.toLowerCase() || '';
      const loc = filterLoc?.value?.toLowerCase() || '';

      let visible = 0;
      cards.forEach((card) => {
        const name = card.dataset.name || '';
        const cardTipo = card.dataset.tipo || '';
        const cardEsp = card.dataset.especialidades || '';
        const cardLoc = card.dataset.ubicacion || '';

        const matchSearch = !search || name.includes(search) || cardEsp.includes(search);
        const matchTipo = !tipo || cardTipo === tipo;
        const matchEsp = !esp || cardEsp.includes(esp);
        const matchLoc = !loc || cardLoc.includes(loc);

        const show = matchSearch && matchTipo && matchEsp && matchLoc;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (countEl) {
        countEl.textContent = `${visible} ${visible === 1 ? 'resultado' : 'resultados'}`;
      }
    }

    searchInput?.addEventListener('input', applyFilters);
    filterTipo?.addEventListener('change', applyFilters);
    filterEsp?.addEventListener('change', applyFilters);
    filterLoc?.addEventListener('change', applyFilters);

    // Pre-select from URL params
    const params = new URLSearchParams(window.location.search);
    if (params.get('tipo') && filterTipo) filterTipo.value = params.get('tipo')!;
    if (params.get('especialidad') && filterEsp) filterEsp.value = params.get('especialidad')!;
    if (params.get('ubicacion') && filterLoc) filterLoc.value = params.get('ubicacion')!;

    if (params.toString()) applyFilters();
  </script>
</Layout>
