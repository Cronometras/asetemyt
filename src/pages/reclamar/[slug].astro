---
import Layout from '../../layouts/Layout.astro';
import { getDirectoryEntries } from '../../lib/firebase';

export const prerender = true;

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    entries = await getDirectoryEntries();
  } catch (e) {
    console.error('Error fetching entries:', e);
  }
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
if (!entry) return Astro.redirect('/directorio');
---

<Layout title={`Reclamar: ${entry.nombre}`} description={`Reclama la ficha de ${entry.nombre} en ASETEMYT para verificarla y editarla.`}>
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8">
      <a href={`/directorio/${entry.slug}`} class="text-accent-600 hover:text-accent-700 text-sm font-medium flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver a la ficha
      </a>
    </nav>

    <!-- Header -->
    <div class="bg-gradient-to-r from-primary-800 to-primary-900 rounded-2xl p-8 mb-8 text-white">
      <div class="flex items-center gap-4 mb-4">
        {entry.logo ? (
          <img src={entry.logo} alt={entry.nombre} class="w-16 h-16 rounded-xl object-cover shadow-lg" />
        ) : (
          <div class="w-16 h-16 rounded-xl bg-accent-500 flex items-center justify-center text-white font-bold text-2xl shadow-lg">
            {entry.nombre?.[0]?.toUpperCase() || '?'}
          </div>
        )}
        <div>
          <h1 class="text-2xl font-extrabold">{entry.nombre}</h1>
          <p class="text-steel-300 text-sm">{entry.ubicacion?.ciudad || ''} {entry.ubicacion?.pais ? `, ${entry.ubicacion.pais}` : ''}</p>
        </div>
      </div>
      <div class="bg-white/10 rounded-xl p-4 mt-4">
        <h2 class="font-bold text-lg mb-2">¿Eres el propietario de esta ficha?</h2>
        <p class="text-steel-200 text-sm">
          Reclámala para verificarla, editar los datos y aparecer con el badge de verificado.
          <strong>50€/año</strong> renovable automáticamente.
        </p>
      </div>
    </div>

    <!-- Not logged in warning -->
    <div id="notAuthWarning" class="hidden mb-6 p-4 bg-amber-50 border border-amber-200 rounded-xl">
      <p class="text-amber-800 text-sm font-medium">
        ⚠️ Necesitas <a href="/login" class="text-accent-600 underline font-bold">iniciar sesión</a> o
        <a href="/registro" class="text-accent-600 underline font-bold">registrarte</a> para reclamar una ficha.
      </p>
    </div>

    <!-- Claim form -->
    <div id="claimSection" class="hidden">
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <h2 class="text-xl font-bold text-primary-900 mb-6">Solicitar Verificación</h2>

        <div id="alert" class="hidden mb-4 p-3 rounded-lg text-sm"></div>

        <form id="claimForm" class="space-y-4">
          <div>
            <label for="claimNombre" class="block text-sm font-semibold text-steel-700 mb-1">Tu nombre / Razón social</label>
            <input type="text" id="claimNombre" required
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors" />
          </div>
          <div>
            <label for="claimEmail" class="block text-sm font-semibold text-steel-700 mb-1">Email de contacto</label>
            <input type="email" id="claimEmail" required
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors" />
          </div>
          <div>
            <label for="claimTelefono" class="block text-sm font-semibold text-steel-700 mb-1">Teléfono (opcional)</label>
            <input type="tel" id="claimTelefono"
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors" />
          </div>
          <div>
            <label for="claimRelacion" class="block text-sm font-semibold text-steel-700 mb-1">Relación con la empresa</label>
            <select id="claimRelacion" required
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors">
              <option value="">Seleccionar...</option>
              <option value="propietario">Propietario / Fundador</option>
              <option value="director">Director / Gerente</option>
              <option value="responsable">Responsable de marketing</option>
              <option value="empleado">Empleado autorizado</option>
            </select>
          </div>
          <div>
            <label for="claimMensaje" class="block text-sm font-semibold text-steel-700 mb-1">Mensaje (opcional)</label>
            <textarea id="claimMensaje" rows="3"
              class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none transition-colors"
              placeholder="Información adicional que quieras compartir..."></textarea>
          </div>
          <button type="submit" id="submitBtn"
            class="w-full bg-accent-500 hover:bg-accent-600 text-white font-bold py-3 rounded-lg transition-colors">
            Enviar Solicitud de Verificación
          </button>
        </form>
      </div>
    </div>

    <!-- Already claimed message -->
    <div id="alreadyClaimed" class="hidden">
      <div class="bg-green-50 border border-green-200 rounded-2xl p-8 text-center">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-green-800 mb-2">Ficha ya verificada</h2>
        <p class="text-green-600">Esta ficha ya ha sido reclamada y verificada por su propietario.</p>
        <a href={`/directorio/${entry.slug}`} class="inline-block mt-4 text-accent-600 hover:text-accent-700 font-semibold">
          Ver ficha →
        </a>
      </div>
    </div>

    <!-- Benefits section -->
    <div class="mt-8 bg-white rounded-2xl shadow-lg p-8">
      <h2 class="text-xl font-bold text-primary-900 mb-6">Beneficios de la ficha verificada</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-steel-800">Badge verificado</p>
            <p class="text-sm text-steel-500">Icono de verificación visible para todos</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-steel-800">Editar tu ficha</p>
            <p class="text-sm text-steel-500">Actualiza servicios, contacto y descripción</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-steel-800">Mayor confianza</p>
            <p class="text-sm text-steel-500">Los visitantes saben que es tu ficha oficial</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-steel-800">50€/año</p>
            <p class="text-sm text-steel-500">Renovación automática, cancela cuando quieras</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { onAuthStateChanged, auth } from '../../lib/auth';

  const slug = window.location.pathname.split('/').filter(Boolean).pop();
  const notAuthWarning = document.getElementById('notAuthWarning')!;
  const claimSection = document.getElementById('claimSection')!;
  const claimForm = document.getElementById('claimForm') as HTMLFormElement;
  const alertEl = document.getElementById('alert')!;
  const submitBtn = document.getElementById('submitBtn')!;
  const alreadyClaimed = document.getElementById('alreadyClaimed')!;

  function showAlert(msg: string, type: 'error' | 'success' = 'error') {
    alertEl.textContent = msg;
    alertEl.className = `mb-4 p-3 rounded-lg text-sm ${type === 'error' ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700'}`;
    alertEl.classList.remove('hidden');
  }

  // Check if already claimed
  async function checkClaimed() {
    try {
      // Check the listing's ownerUid via a lightweight check
      // For prerendered pages, we'll check client-side
    } catch {}
  }

  onAuthStateChanged(auth, (user) => {
    if (!user) {
      notAuthWarning.classList.remove('hidden');
      return;
    }
    claimSection.classList.remove('hidden');
    // Pre-fill email
    const emailInput = document.getElementById('claimEmail') as HTMLInputElement;
    if (user.email && emailInput) emailInput.value = user.email;
    const nombreInput = document.getElementById('claimNombre') as HTMLInputElement;
    if (user.displayName && nombreInput) nombreInput.value = user.displayName;
  });

  claimForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Enviando...';
    submitBtn.setAttribute('disabled', 'true');

    try {
      const resp = await fetch('/api/ficha/claim', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          slug,
          nombre: (document.getElementById('claimNombre') as HTMLInputElement).value,
          email: (document.getElementById('claimEmail') as HTMLInputElement).value,
          telefono: (document.getElementById('claimTelefono') as HTMLInputElement).value,
          relacion: (document.getElementById('claimRelacion') as HTMLSelectElement).value,
          mensaje: (document.getElementById('claimMensaje') as HTMLTextAreaElement).value,
        }),
      });

      const data = await resp.json();
      if (resp.ok) {
        showAlert(data.message || 'Solicitud enviada correctamente', 'success');
        claimForm.reset();
      } else {
        showAlert(data.error || 'Error enviando solicitud');
      }
    } catch (err: any) {
      showAlert('Error de conexión. Inténtalo de nuevo.');
    }

    submitBtn.textContent = 'Enviar Solicitud de Verificación';
    submitBtn.removeAttribute('disabled');
  });
</script>
