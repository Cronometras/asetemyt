---
import Layout from '../../layouts/Layout.astro';
import { getDirectoryEntries } from '../../lib/firebase';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getDirectoryEntries();
  return entries.map((entry: any) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
if (!entry) return Astro.redirect('/directorio');
---

<Layout title={`Reclamar ${entry.nombre}`} description={`Verifica y reclama la ficha de ${entry.nombre} en ASETEMYT.`}>
  <section class="max-w-xl mx-auto px-4 py-12">
    <a href={`/directorio/${entry.slug}`} class="text-accent-600 hover:text-accent-700 text-sm font-medium mb-6 inline-block">← Volver a la ficha</a>

    <!-- Header -->
    <div class="bg-white rounded-2xl shadow-lg p-8 mb-6">
      <div class="flex items-center gap-4 mb-4">
        {entry.logo && <img src={entry.logo} alt={entry.nombre} class="w-14 h-14 rounded-lg object-contain bg-steel-50 p-1" />}
        <div>
          <h1 class="text-2xl font-bold text-primary-900">Reclamar ficha</h1>
          <p class="text-steel-500">{entry.nombre}</p>
        </div>
      </div>
      <p class="text-steel-600 text-sm">Verifica que eres el propietario de esta empresa usando tu email corporativo. Se te enviará un código de 6 dígitos.</p>
    </div>

    <!-- Already verified -->
    <div id="alreadyVerified" class="hidden bg-green-50 border border-green-200 rounded-2xl p-8 text-center">
      <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
      </div>
      <h2 class="text-xl font-bold text-green-800 mb-2">Ficha ya verificada</h2>
      <p class="text-green-700">Esta ficha ya está verificada por su propietario.</p>
    </div>

    <!-- Login required -->
    <div id="loginRequired" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-8 text-center">
      <h2 class="text-xl font-bold text-amber-800 mb-2">Inicia sesión</h2>
      <p class="text-amber-700 mb-4">Necesitas iniciar sesión para reclamar una ficha.</p>
      <a href="/login" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-6 py-3 rounded-lg transition-colors">Iniciar Sesión</a>
    </div>

    <!-- STEP 1: Form -->
    <div id="step1" class="hidden bg-white rounded-2xl shadow-lg p-8">
      <h2 class="text-lg font-bold text-primary-900 mb-4">Paso 1 — Datos de contacto</h2>
      <form id="claimForm" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-steel-700 mb-1">Nombre completo *</label>
          <input type="text" id="nombre" required class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none" placeholder="Tu nombre" />
        </div>
        <div>
          <label class="block text-sm font-medium text-steel-700 mb-1">Email corporativo *</label>
          <input type="email" id="email" required class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none" placeholder="tu@empresa.com" />
          <p class="text-xs text-steel-400 mt-1">Debe ser un email con dominio propio (no Gmail, Outlook, etc.)</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-steel-700 mb-1">Mensaje (opcional)</label>
          <textarea id="mensaje" rows="3" class="w-full px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none resize-none" placeholder="¿Por qué quieres verificar esta ficha?"></textarea>
        </div>

        <!-- Coupon code -->
        <div class="border-t border-steel-100 pt-4">
          <label class="block text-sm font-medium text-steel-700 mb-1">¿Tienes un cupón?</label>
          <div class="flex gap-2">
            <input type="text" id="couponInput" class="flex-1 px-4 py-3 rounded-lg border border-steel-200 focus:border-accent-500 focus:ring-2 focus:ring-accent-200 outline-none uppercase" placeholder="CÓDIGO" />
            <button type="button" id="btnValidateCoupon" class="px-4 py-3 bg-steel-100 hover:bg-steel-200 text-steel-700 font-medium rounded-lg transition-colors text-sm whitespace-nowrap">
              Aplicar
            </button>
          </div>
          <div id="couponResult" class="hidden mt-2 text-sm p-3 rounded-lg"></div>
        </div>

        <div id="error1" class="hidden text-red-600 text-sm bg-red-50 p-3 rounded-lg"></div>
        <button type="submit" id="btnSend" class="w-full bg-accent-500 hover:bg-accent-600 text-white font-bold py-3 px-6 rounded-lg transition-colors">
          Enviar código de verificación
        </button>
      </form>
    </div>

    <!-- STEP 2: Code entry -->
    <div id="step2" class="hidden bg-white rounded-2xl shadow-lg p-8">
      <h2 class="text-lg font-bold text-primary-900 mb-2">Paso 2 — Introduce el código</h2>
      <p class="text-steel-500 text-sm mb-6">Hemos enviado un código de 6 dígitos a <strong id="emailDisplay" class="text-primary-900"></strong></p>

      <!-- Coupon info in step 2 -->
      <div id="couponInfo2" class="hidden mb-4 p-3 bg-accent-50 border border-accent-200 rounded-lg text-sm text-accent-800"></div>

      <form id="codeForm" class="space-y-4">
        <div class="flex justify-center gap-2">
          <input type="text" maxlength="1" class="code-input w-12 h-14 text-center text-2xl font-bold rounded-lg border-2 border-steel-200 focus:border-accent-500 outline-none" inputmode="numeric" pattern="[0-9]" />
          <input type="text" maxlength="1" class="code-input w-12 h-14 text-center text-2xl font-bold rounded-lg border-2 border-steel-200 focus:border-accent-500 outline-none" inputmode="numeric" pattern="[0-9]" />
          <input type="text" maxlength="1" class="code-input w-12 h-14 text-center text-2xl font-bold rounded-lg border-2 border-steel-200 focus:border-accent-500 outline-none" inputmode="numeric" pattern="[0-9]" />
          <input type="text" maxlength="1" class="code-input w-12 h-14 text-center text-2xl font-bold rounded-lg border-2 border-steel-200 focus:border-accent-500 outline-none" inputmode="numeric" pattern="[0-9]" />
          <input type="text" maxlength="1" class="code-input w-12 h-14 text-center text-2xl font-bold rounded-lg border-2 border-steel-200 focus:border-accent-500 outline-none" inputmode="numeric" pattern="[0-9]" />
          <input type="text" maxlength="1" class="code-input w-12 h-14 text-center text-2xl font-bold rounded-lg border-2 border-steel-200 focus:border-accent-500 outline-none" inputmode="numeric" pattern="[0-9]" />
        </div>
        <div id="error2" class="hidden text-red-600 text-sm bg-red-50 p-3 rounded-lg"></div>
        <button type="submit" id="btnVerify" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-lg transition-colors">
          Verificar y pagar
        </button>
        <button type="button" id="btnResend" class="w-full text-accent-600 hover:text-accent-700 font-medium py-2 text-sm underline">
          Reenviar código
        </button>
      </form>
    </div>

    <!-- STEP 3: Redirecting to payment -->
    <div id="step3" class="hidden bg-white rounded-2xl shadow-lg p-8 text-center">
      <div class="inline-block w-8 h-8 border-4 border-green-500 border-t-transparent rounded-full animate-spin mb-4"></div>
      <h2 class="text-lg font-bold text-primary-900 mb-2">¡Código verificado!</h2>
      <p class="text-steel-500">Redirigiendo al pago...</p>
    </div>

    <!-- STEP 4: Free coupon success -->
    <div id="step4" class="hidden bg-green-50 border border-green-200 rounded-2xl p-8 text-center">
      <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
      </div>
      <h2 class="text-xl font-bold text-green-800 mb-2">¡Ficha verificada!</h2>
      <p class="text-green-700 mb-4">Tu cupón ha activado la verificación gratuita. Tu ficha ya aparece como verificada.</p>
      <a href={`/directorio/${entry.slug}`} class="inline-block bg-green-600 hover:bg-green-700 text-white font-bold px-6 py-3 rounded-lg transition-colors">
        Ver mi ficha
      </a>
    </div>
  </section>
</Layout>

<div id="claim-data" data-slug={entry.slug} data-verificado={entry.verificado ? '1' : ''} class="hidden"></div>

<script>
  import { auth } from '../../lib/auth';
  import { onAuthStateChanged } from 'firebase/auth';

  const dataEl = document.getElementById('claim-data')!;
  const slug = dataEl.dataset.slug!;
  const verificado = dataEl.dataset.verificado === '1';

  const $ = (s) => document.querySelector(s);
  const $$ = (s) => document.querySelectorAll(s);

  let appliedCoupon: string | null = null;
  let currentUser: any = null;

  // Check state
  const unsub = onAuthStateChanged(auth, async (user) => {
    unsub();
    currentUser = user;
    if (verificado) {
      $('#alreadyVerified').classList.remove('hidden');
      return;
    }
    if (!user) {
      $('#loginRequired').classList.remove('hidden');
      return;
    }
    // Pre-fill email with auth email
    const emailInput = $('#email') as HTMLInputElement;
    if (emailInput && user.email) {
      emailInput.value = user.email;
    }
    $('#step1').classList.remove('hidden');
  });

  // Validate coupon
  $('#btnValidateCoupon').addEventListener('click', async () => {
    const code = $('#couponInput').value.trim();
    const resultEl = $('#couponResult');
    if (!code) {
      resultEl.textContent = 'Introduce un código de cupón';
      resultEl.className = 'mt-2 text-sm p-3 rounded-lg bg-red-50 text-red-700';
      resultEl.classList.remove('hidden');
      return;
    }

    $('#btnValidateCoupon').disabled = true;
    $('#btnValidateCoupon').textContent = 'Validando...';

    try {
      const resp = await fetch(`/api/coupon/validate?code=${encodeURIComponent(code)}`);
      const data = await resp.json();
      if (data.valid) {
        appliedCoupon = data.code;
        resultEl.innerHTML = `✅ <strong>${data.code}</strong> — ${data.description}`;
        resultEl.className = 'mt-2 text-sm p-3 rounded-lg bg-green-50 text-green-700';
        // Update button text based on coupon type
        if (data.type === 'free') {
          $('#btnSend').textContent = 'Enviar código y verificar gratis';
        } else if (data.type === 'discount') {
          $('#btnSend').textContent = `Enviar código (${data.value}% descuento)`;
        } else if (data.type === 'trial') {
          $('#btnSend').textContent = `Enviar código (${data.value} meses gratis)`;
        }
      } else {
        appliedCoupon = null;
        resultEl.textContent = `❌ ${data.error}`;
        resultEl.className = 'mt-2 text-sm p-3 rounded-lg bg-red-50 text-red-700';
        $('#btnSend').textContent = 'Enviar código de verificación';
      }
    } catch {
      resultEl.textContent = '❌ Error validando el cupón';
      resultEl.className = 'mt-2 text-sm p-3 rounded-lg bg-red-50 text-red-700';
    } finally {
      $('#btnValidateCoupon').disabled = false;
      $('#btnValidateCoupon').textContent = 'Aplicar';
      resultEl.classList.remove('hidden');
    }
  });

  // Allow Enter key in coupon input
  $('#couponInput').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      $('#btnValidateCoupon').click();
    }
  });

  // STEP 1 — Send code
  $('#claimForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const nombre = $('#nombre').value.trim();
    const email = $('#email').value.trim();
    const mensaje = $('#mensaje').value.trim();
    const errEl = $('#error1');
    errEl.classList.add('hidden');
    $('#btnSend').disabled = true;

    try {
      const resp = await fetch('/api/ficha/send-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, nombre, email, mensaje, uid: currentUser?.uid || '' }),
      });
      const data = await resp.json();
      if (!resp.ok) {
        errEl.textContent = data.error || 'Error enviando el código.';
        errEl.classList.remove('hidden');
        return;
      }
      // Move to step 2
      $('#emailDisplay').textContent = email;
      $('#step1').classList.add('hidden');
      $('#step2').classList.remove('hidden');

      // Show coupon info in step 2
      if (appliedCoupon) {
        const couponInfoEl = $('#couponInfo2');
        const resultText = $('#couponResult').innerHTML;
        couponInfoEl.innerHTML = resultText;
        couponInfoEl.classList.remove('hidden');
      }

      // Update verify button text
      if (appliedCoupon) {
        const couponResultEl = $('#couponResult');
        if (couponResultEl.textContent.includes('gratuita')) {
          $('#btnVerify').textContent = 'Verificar gratis';
        } else if (couponResultEl.textContent.includes('descuento')) {
          $('#btnVerify').textContent = 'Verificar y pagar con descuento';
        }
      }

      $$('.code-input')[0].focus();
    } catch {
      errEl.textContent = 'Error de conexión.';
      errEl.classList.remove('hidden');
    } finally {
      $('#btnSend').disabled = false;
      if (!appliedCoupon) {
        $('#btnSend').textContent = 'Enviar código de verificación';
      }
    }
  });

  // Code inputs — auto-advance
  const codeInputs = $$('.code-input');
  codeInputs.forEach((input, i) => {
    input.addEventListener('input', (e) => {
      const val = e.target.value.replace(/[^0-9]/g, '');
      e.target.value = val;
      if (val && i < 5) codeInputs[i + 1].focus();
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace' && !e.target.value && i > 0) codeInputs[i - 1].focus();
    });
    input.addEventListener('paste', (e) => {
      e.preventDefault();
      const pasted = (e.clipboardData.getData('text') || '').replace(/[^0-9]/g, '').slice(0, 6);
      pasted.split('').forEach((ch, j) => { if (codeInputs[j]) codeInputs[j].value = ch; });
      if (pasted.length > 0) codeInputs[Math.min(pasted.length, 5)].focus();
    });
  });

  // STEP 2 — Verify code
  $('#codeForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const code = Array.from(codeInputs).map(i => i.value).join('');
    if (code.length !== 6) return;
    const email = $('#emailDisplay').textContent;
    const errEl = $('#error2');
    errEl.classList.add('hidden');
    $('#btnVerify').disabled = true;
    $('#btnVerify').textContent = 'Verificando...';

    try {
      const body: any = { slug, email, code };
      if (appliedCoupon) body.couponCode = appliedCoupon;

      const resp = await fetch('/api/ficha/verify-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await resp.json();
      if (!resp.ok) {
        errEl.textContent = data.error || 'Código incorrecto.';
        errEl.classList.remove('hidden');
        return;
      }

      // Free coupon → show success directly
      if (data.free) {
        $('#step2').classList.add('hidden');
        $('#step4').classList.remove('hidden');
        return;
      }

      // Redirect to Stripe Checkout
      if (data.checkoutUrl) {
        $('#step2').classList.add('hidden');
        $('#step3').classList.remove('hidden');
        window.location.href = data.checkoutUrl;
      }
    } catch {
      errEl.textContent = 'Error de conexión.';
      errEl.classList.remove('hidden');
    } finally {
      $('#btnVerify').disabled = false;
      $('#btnVerify').textContent = 'Verificar y pagar';
    }
  });

  // Resend code
  $('#btnResend').addEventListener('click', async () => {
    const email = $('#emailDisplay').textContent;
    const nombre = $('#nombre')?.value || '';
    const mensaje = $('#mensaje')?.value || '';
    $('#btnResend').textContent = 'Reenviando...';
    try {
      await fetch('/api/ficha/send-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, nombre, email, mensaje, uid: currentUser?.uid || '' }),
      });
      $('#btnResend').textContent = '✓ Código reenviado';
      setTimeout(() => { $('#btnResend').textContent = 'Reenviar código'; }, 3000);
    } catch {
      $('#btnResend').textContent = 'Error, inténtalo de nuevo';
    }
  });
</script>

<style>
  .code-input { font-family: 'Courier New', monospace; }
  .code-input:focus { box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2); }
</style>
