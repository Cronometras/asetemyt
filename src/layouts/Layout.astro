---
export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Directorio de técnicos, consultores y empresas de cronometraje industrial e ingeniería de métodos y tiempos.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title} | ASETEMYT</title>
  </head>
  <body class="bg-steel-50 text-steel-800 font-sans min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="bg-primary-900 text-white shadow-lg sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-9 h-9 bg-accent-500 rounded-lg flex items-center justify-center font-bold text-lg tracking-tight">
              A
            </div>
            <span class="text-xl font-bold tracking-tight">ASETEMYT</span>
          </a>
          <div class="hidden md:flex items-center gap-8">
            <a href="/" class="hover:text-accent-400 transition-colors font-medium">Inicio</a>
            <a href="/directorio" class="hover:text-accent-400 transition-colors font-medium">Directorio</a>
            <a href="/blog" class="hover:text-accent-400 transition-colors font-medium">Blog</a>
            <a
              href="/anadir"
              class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded-lg font-semibold transition-colors"
            >
              Añadir Empresa
            </a>
          </div>
          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <a href="/" class="block py-2 hover:text-accent-400">Inicio</a>
          <a href="/directorio" class="block py-2 hover:text-accent-400">Directorio</a>
          <a href="/blog" class="block py-2 hover:text-accent-400">Blog</a>
          <a href="/anadir" class="block py-2 text-accent-400 font-semibold">Añadir Empresa</a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-primary-900 text-steel-300 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 bg-accent-500 rounded-lg flex items-center justify-center font-bold text-white">
                A
              </div>
              <span class="text-lg font-bold text-white">ASETEMYT</span>
            </div>
            <p class="text-sm">
              Directorio de técnicos, consultores y empresas especializadas en cronometraje industrial e ingeniería de métodos y tiempos.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-3">Enlaces</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/directorio" class="hover:text-accent-400 transition-colors">Directorio</a></li>
              <li><a href="/blog" class="hover:text-accent-400 transition-colors">Blog</a></li>
              <li><a href="/anadir" class="hover:text-accent-400 transition-colors">Añadir Empresa</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-3">Proyectos Relacionados</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="https://cronometras.com" target="_blank" rel="noopener" class="hover:text-accent-400 transition-colors">Cronometras.com</a></li>
              <li><a href="https://induly.com" target="_blank" rel="noopener" class="hover:text-accent-400 transition-colors">Induly.com</a></li>
              <li><a href="https://worksamp.com" target="_blank" rel="noopener" class="hover:text-accent-400 transition-colors">Worksamp.com</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-steel-700 mt-8 pt-8 text-center text-sm">
          <p>&copy; {new Date().getFullYear()} ASETEMYT.com — Directorio de Cronometraje Industrial</p>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
