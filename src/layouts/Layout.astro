---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Directorio de técnicos, consultores y empresas de cronometraje industrial e ingeniería de métodos y tiempos.',
  image = 'https://asetemyt.com/favicon.svg',
} = Astro.props;
const canonicalUrl = `https://asetemyt.com${Astro.url.pathname}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | ASETEMYT`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="ASETEMYT" />
    <meta property="og:locale" content="es_ES" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={`${title} | ASETEMYT`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} | ASETEMYT</title>
  </head>
  <body class="bg-steel-50 text-steel-800 font-sans min-h-screen flex flex-col">
    <nav class="bg-primary-900 text-white shadow-lg sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-9 h-9 bg-accent-500 rounded-lg flex items-center justify-center font-bold text-lg tracking-tight">A</div>
            <span class="text-xl font-bold tracking-tight">ASETEMYT</span>
          </a>
          <div class="hidden md:flex items-center gap-6">
            <a href="/" class="hover:text-accent-400 transition-colors font-medium" data-nav="home">Inicio</a>
            <a href="/directorio" class="hover:text-accent-400 transition-colors font-medium" data-nav="dir">Directorio</a>
            <a href="/blog" class="hover:text-accent-400 transition-colors font-medium" data-nav="blog">Blog</a>
            <a href="/anadir" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded-lg font-semibold transition-colors" data-nav="add">
              Añadir Empresa
            </a>
            <!-- Language switcher -->
            <div class="flex items-center border border-steel-600 rounded-lg overflow-hidden text-sm">
              <button id="lang-es" class="px-2.5 py-1 bg-accent-500 text-white font-semibold transition-colors">ES</button>
              <button id="lang-en" class="px-2.5 py-1 hover:bg-steel-700 transition-colors">EN</button>
            </div>
            <!-- Auth links -->
            <div id="nav-auth" class="flex items-center gap-3 ml-2">
              <a href="/login" class="hover:text-accent-400 transition-colors font-medium" data-nav="login">Iniciar Sesión</a>
            </div>
          </div>
          <button id="mobile-menu-btn" class="md:hidden p-2">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <a href="/" class="block py-2 hover:text-accent-400" data-nav="home">Inicio</a>
          <a href="/directorio" class="block py-2 hover:text-accent-400" data-nav="dir">Directorio</a>
          <a href="/blog" class="block py-2 hover:text-accent-400" data-nav="blog">Blog</a>
          <a href="/anadir" class="block py-2 text-accent-400 font-semibold" data-nav="add">Añadir Empresa</a>
          <div id="mob-auth-link" class="border-t border-steel-700 mt-2 pt-2">
            <a href="/login" class="block py-2 hover:text-accent-400" data-nav="login">Iniciar Sesión</a>
          </div>
          <div class="flex items-center gap-2 mt-3 border-t border-steel-700 pt-3">
            <button id="mob-lang-es" class="px-3 py-1 bg-accent-500 text-white text-sm font-semibold rounded">ES</button>
            <button id="mob-lang-en" class="px-3 py-1 text-steel-400 text-sm rounded hover:bg-steel-700">EN</button>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-primary-900 text-steel-300 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 bg-accent-500 rounded-lg flex items-center justify-center font-bold text-white">A</div>
              <span class="text-lg font-bold text-white">ASETEMYT</span>
            </div>
            <p class="text-sm" data-text="footerDesc">
              Directorio de técnicos, consultores y empresas especializadas en cronometraje industrial e ingeniería de métodos y tiempos.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-3" data-text="links">Enlaces</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/directorio" class="hover:text-accent-400 transition-colors" data-nav="dir">Directorio</a></li>
              <li><a href="/blog" class="hover:text-accent-400 transition-colors" data-nav="blog">Blog</a></li>
              <li><a href="/anadir" class="hover:text-accent-400 transition-colors" data-nav="add">Añadir Empresa</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-3" data-text="relatedProjects">Proyectos Relacionados</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="https://cronometras.com" target="_blank" rel="noopener" class="hover:text-accent-400 transition-colors">Cronometras.com</a></li>
              <li><a href="https://induly.com" target="_blank" rel="noopener" class="hover:text-accent-400 transition-colors">Induly.com</a></li>
              <li><a href="https://worksamp.com" target="_blank" rel="noopener" class="hover:text-accent-400 transition-colors">Worksamp.com</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-steel-700 mt-8 pt-8 text-center text-sm">
          <p>&copy; {new Date().getFullYear()} ASETEMYT.com — Directorio de Cronometraje Industrial</p>
        </div>
      </div>
    </footer>

    <script>
      import { getLang, type Lang } from '../lib/firebase';

      const navLabels: Record<Lang, Record<string, string>> = {
        es: { home: 'Inicio', dir: 'Directorio', blog: 'Blog', add: 'Añadir Empresa', login: 'Iniciar Sesión', account: 'Mi Cuenta' },
        en: { home: 'Home', dir: 'Directory', blog: 'Blog', add: 'Add Company', login: 'Log In', account: 'My Account' },
      };

      const footerLabels: Record<Lang, Record<string, string>> = {
        es: {
          footerDesc: 'Directorio de técnicos, consultores y empresas especializadas en cronometraje industrial e ingeniería de métodos y tiempos.',
          links: 'Enlaces',
          relatedProjects: 'Proyectos Relacionados',
        },
        en: {
          footerDesc: 'Directory of technicians, consultants and companies specialized in industrial time study and methods engineering.',
          links: 'Links',
          relatedProjects: 'Related Projects',
        },
      };

      function setLang(lang: Lang) {
        localStorage.setItem('asetemyt-lang', lang);

        // Update nav links
        document.querySelectorAll('[data-nav]').forEach((el) => {
          const key = (el as HTMLElement).dataset.nav!;
          const label = navLabels[lang][key];
          if (label) el.textContent = label;
        });

        // Update footer texts
        document.querySelectorAll('[data-text]').forEach((el) => {
          const key = (el as HTMLElement).dataset.text!;
          const label = footerLabels[lang][key];
          if (label) el.textContent = label;
        });

        // Update buttons
        const esBtn = document.getElementById('lang-es')!;
        const enBtn = document.getElementById('lang-en')!;
        const mobEsBtn = document.getElementById('mob-lang-es')!;
        const mobEnBtn = document.getElementById('mob-lang-en')!;

        [esBtn, mobEsBtn].forEach((b) => {
          b.className = lang === 'es'
            ? 'px-2.5 py-1 bg-accent-500 text-white font-semibold transition-colors'
            : 'px-2.5 py-1 hover:bg-steel-700 transition-colors';
        });
        [enBtn, mobEnBtn].forEach((b) => {
          b.className = lang === 'en'
            ? 'px-2.5 py-1 bg-accent-500 text-white font-semibold transition-colors'
            : 'px-2.5 py-1 hover:bg-steel-700 transition-colors';
        });

        // Broadcast to page scripts
        window.dispatchEvent(new CustomEvent('langChange', { detail: lang }));
      }

      document.getElementById('lang-es')?.addEventListener('click', () => setLang('es'));
      document.getElementById('lang-en')?.addEventListener('click', () => setLang('en'));
      document.getElementById('mob-lang-es')?.addEventListener('click', () => setLang('es'));
      document.getElementById('mob-lang-en')?.addEventListener('click', () => setLang('en'));

      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });

      // Init on load
      setLang(getLang());

      // Auth state — update nav links
      import { onAuthStateChanged, auth } from '../lib/auth';
      const lang = () => (localStorage.getItem('asetemyt-lang') as Lang) || 'es';

      onAuthStateChanged(auth, (user) => {
        const navAuth = document.getElementById('nav-auth');
        const mobAuth = document.getElementById('mob-auth-link');
        if (!navAuth || !mobAuth) return;

        if (user) {
          navAuth.innerHTML = `<a href="/mi-cuenta" class="hover:text-accent-400 transition-colors font-medium" data-nav="account">${navLabels[lang()]['account']}</a>`;
          mobAuth.innerHTML = `<a href="/mi-cuenta" class="block py-2 hover:text-accent-400" data-nav="account">${navLabels[lang()]['account']}</a>`;
        } else {
          navAuth.innerHTML = `<a href="/login" class="hover:text-accent-400 transition-colors font-medium" data-nav="login">${navLabels[lang()]['login']}</a>`;
          mobAuth.innerHTML = `<a href="/login" class="block py-2 hover:text-accent-400" data-nav="login">${navLabels[lang()]['login']}</a>`;
        }
      });
    </script>
  </body>
</html>
