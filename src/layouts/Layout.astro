---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  ogType?: 'website' | 'article' | 'profile' | 'book';
  noindex?: boolean;
  lang?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description = 'Directorio de técnicos, consultores y empresas de cronometraje industrial e ingeniería de métodos y tiempos.',
  image = 'https://asetemyt.com/images/og-default.webp',
  canonical: canonicalProp,
  ogType = 'website',
  noindex = false,
  lang = 'es',
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  articleTags = [],
} = Astro.props;

import Analytics from '../components/Analytics.astro';
import CookieConsent from '../components/CookieConsent.astro';

const SITE = 'https://asetemyt.com';
const canonicalUrl = canonicalProp || `${SITE}${Astro.url.pathname.replace(/\/$/, '') || ''}`;

// ASETEMYT organization schema (site-wide, also emitted on home page)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE}#organization`,
  name: 'ASETEMYT',
  alternateName: 'ASETEMYT.com',
  url: SITE,
  logo: { '@type': 'ImageObject', url: `${SITE}/images/logo-asetemyt.webp`, width: 512, height: 512 },
  description: 'Directorio de profesionales, consultores y empresas de cronometraje industrial e ingeniería de métodos y tiempos (MTM, MOST, Work Sampling).',
  foundingDate: '2023',
  sameAs: [
    'https://www.linkedin.com/company/asetemyt',
    'https://twitter.com/asetemyt',
    'https://www.youtube.com/@asetemyt',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'hola@asetemyt.com',
    availableLanguage: ['Spanish', 'English'],
  },
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'ES',
    addressLocality: 'Madrid',
    addressRegion: 'Madrid',
  },
};

// ASETEMYT local business (NAP) for local SEO
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE}#localbusiness`,
  name: 'ASETEMYT',
  image: `${SITE}/images/logo-asetemyt.webp`,
  url: SITE,
  telephone: '+34-900-000-000',
  email: 'hola@asetemyt.com',
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Calle Serrano 21',
    addressLocality: 'Madrid',
    postalCode: '28001',
    addressRegion: 'Madrid',
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.4248,
    longitude: -3.6847,
  },
  areaServed: [
    { '@type': 'Country', name: 'España' },
    { '@type': 'Country', name: 'México' },
    { '@type': 'Country', name: 'Argentina' },
    { '@type': 'Country', name: 'Colombia' },
    { '@type': 'Country', name: 'Chile' },
    { '@type': 'Country', name: 'Perú' },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
  ],
  parentOrganization: { '@id': `${SITE}#organization` },
};

const fullTitle = title.includes('ASETEMYT') ? title : `${title} | ASETEMYT`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />}
    <meta name="theme-color" content="#0b2545" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="ASETEMYT" />
    <meta name="application-name" content="ASETEMYT" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="ASETEMYT" />

    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="es-ES" href={canonicalUrl} />
    <link rel="alternate" hreflang="es-MX" href={canonicalUrl} />
    <link rel="alternate" hreflang="es-AR" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />
    <meta property="og:site_name" content="ASETEMYT" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:locale:alternate" content="en_US" />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {ogType === 'article' && articleTags.map((t) => (
      <meta property="article:tag" content={t} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@asetemyt" />
    <meta name="twitter:creator" content="@asetemyt" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <!-- Preconnect / DNS prefetch -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://firestore.googleapis.com" crossorigin />
    <link rel="dns-prefetch" href="https://firestore.googleapis.com" />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{fullTitle}</title>

    <!-- ASETEMYT site-wide structured data (Organization + LocalBusiness) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <Analytics />
  </head>
  <body class="bg-steel-50 text-steel-800 font-sans min-h-screen flex flex-col">
    <nav class="bg-primary-900 text-white shadow-lg sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3 group">
            <img src="/images/logo-asetemyt-nav.webp" alt="ASETEMYT — Inicio" class="h-9 w-auto" width="51" height="40" loading="eager" />
            <span class="text-xl font-bold tracking-tight">ASETEMYT</span>
          </a>
          <div class="hidden md:flex items-center gap-6">
            <a href="/directorio" class="hover:text-accent-400 transition-colors font-medium" data-nav="prof">Profesionales</a>
            <a href="/software" class="hover:text-accent-400 transition-colors font-medium" data-nav="soft">Software</a>
            <a href="/blog" class="hover:text-accent-400 transition-colors font-medium" data-nav="blog">Blog</a>
            <a href="/glosario" class="hover:text-accent-400 transition-colors font-medium" data-nav="glossary">Glosario</a>
            <a href="/comparador" class="hover:text-accent-400 transition-colors font-medium" data-nav="compare">Comparador</a>
            <a href="/empleo" class="hover:text-accent-400 transition-colors font-medium" data-nav="jobs">Empleo</a>
            <a href="/anadir" class="bg-accent-500 hover:bg-accent-600 text-white px-4 py-2 rounded-lg font-semibold transition-colors" data-nav="add">
              Añadir Empresa
            </a>
            <div class="flex items-center border border-steel-600 rounded-lg overflow-hidden text-sm">
              <button id="lang-es" class="px-2.5 py-1 bg-accent-500 text-white font-semibold transition-colors">ES</button>
              <button id="lang-en" class="px-2.5 py-1 hover:bg-steel-700 transition-colors">EN</button>
            </div>
            <div id="nav-auth" class="flex items-center gap-3 ml-2">
              <a href="/login" class="hover:text-accent-400 transition-colors font-medium" data-nav="login">Iniciar Sesión</a>
            </div>
          </div>
          <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Abrir menú">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <a href="/directorio" class="block py-2 hover:text-accent-400" data-nav="prof">Profesionales</a>
          <a href="/software" class="block py-2 hover:text-accent-400" data-nav="soft">Software</a>
          <a href="/blog" class="block py-2 hover:text-accent-400" data-nav="blog">Blog</a>
          <a href="/glosario" class="block py-2 hover:text-accent-400" data-nav="glossary">Glosario</a>
          <a href="/comparador" class="block py-2 hover:text-accent-400" data-nav="compare">Comparador</a>
          <a href="/empleo" class="block py-2 hover:text-accent-400" data-nav="jobs">Empleo</a>
          <a href="/anadir" class="block py-2 text-accent-400 font-semibold" data-nav="add">Añadir Empresa</a>
          <div id="mob-auth-link" class="border-t border-steel-700 mt-2 pt-2">
            <a href="/login" class="block py-2 hover:text-accent-400" data-nav="login">Iniciar Sesión</a>
          </div>
          <div class="flex items-center gap-2 mt-3 border-t border-steel-700 pt-3">
            <button id="mob-lang-es" class="px-3 py-1 bg-accent-500 text-white text-sm font-semibold rounded">ES</button>
            <button id="mob-lang-en" class="px-3 py-1 text-steel-400 text-sm rounded hover:bg-steel-700">EN</button>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-primary-900 text-steel-300 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="md:col-span-1">
            <div class="flex items-center gap-2 mb-4">
              <img src="/images/logo-asetemyt-nav.webp" alt="ASETEMYT" class="h-8 w-auto" width="51" height="40" loading="lazy" />
              <span class="text-lg font-bold text-white">ASETEMYT</span>
            </div>
            <address class="not-italic text-sm space-y-1 mb-3">
              <p>Calle Serrano 21, 28001 Madrid, España</p>
              <p><a href="mailto:hola@asetemyt.com" class="hover:text-accent-400">hola@asetemyt.com</a></p>
            </address>
            <p class="text-sm" data-text="footerDesc">
              Directorio de técnicos, consultores y empresas especializadas en cronometraje industrial e ingeniería de métodos y tiempos.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-3" data-text="links">Enlaces</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/directorio" class="hover:text-accent-400 transition-colors" data-nav="prof">Profesionales</a></li>
              <li><a href="/software" class="hover:text-accent-400 transition-colors" data-nav="soft">Software</a></li>
              <li><a href="/blog" class="hover:text-accent-400 transition-colors" data-nav="blog">Blog</a></li>
              <li><a href="/anadir" class="hover:text-accent-400 transition-colors" data-nav="add">Añadir Empresa</a></li>
              <li><a href="/glosario" class="hover:text-accent-400 transition-colors" data-nav="glossary">Glosario</a></li>
              <li><a href="/comparador" class="hover:text-accent-400 transition-colors" data-nav="compare">Comparador</a></li>
              <li><a href="/empleo" class="hover:text-accent-400 transition-colors" data-nav="jobs">Empleo</a></li>
              <li><a href="/sobre" class="hover:text-accent-400 transition-colors">Sobre ASETEMYT</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-3" data-text="legal">Legal</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/politica-de-privacidad" class="hover:text-accent-400 transition-colors" data-text="privacy">Privacidad</a></li>
              <li><a href="/politica-de-cookies" class="hover:text-accent-400 transition-colors" data-text="cookies">Cookies</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-white mb-3" data-text="relatedProjects">Proyectos Relacionados</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="https://cronometras.com" target="_blank" rel="noopener noreferrer" class="hover:text-accent-400 transition-colors">Cronometras.com</a></li>
              <li><a href="https://induly.com" target="_blank" rel="noopener noreferrer" class="hover:text-accent-400 transition-colors">Induly.com</a></li>
              <li><a href="https://worksamp.com" target="_blank" rel="noopener noreferrer" class="hover:text-accent-400 transition-colors">Worksamp.com</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-steel-700 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
          <p>&copy; {new Date().getFullYear()} ASETEMYT.com — Directorio de Cronometraje Industrial</p>
        </div>
      </div>
    </footer>

    <script>
      import { getLang, type Lang } from '../lib/firebase';

      const navLabels: Record<Lang, Record<string, string>> = {
        es: { home: 'Inicio', prof: 'Profesionales', soft: 'Software', blog: 'Blog', add: 'Añadir Empresa', login: 'Iniciar Sesión', account: 'Mi Cuenta', glossary: 'Glosario', compare: 'Comparador', jobs: 'Empleo' },
        en: { home: 'Home', prof: 'Professionals', soft: 'Software', blog: 'Blog', add: 'Add Company', login: 'Log In', account: 'My Account', glossary: 'Glossary', compare: 'Compare', jobs: 'Jobs' },
      };

      const footerLabels: Record<Lang, Record<string, string>> = {
        es: {
          footerDesc: 'Directorio de técnicos, consultores y empresas especializadas en cronometraje industrial e ingeniería de métodos y tiempos.',
          links: 'Enlaces',
          legal: 'Legal',
          privacy: 'Privacidad',
          cookies: 'Cookies',
          relatedProjects: 'Proyectos Relacionados',
        },
        en: {
          footerDesc: 'Directory of technicians, consultants and companies specialized in industrial time study and methods engineering.',
          links: 'Links',
          legal: 'Legal',
          privacy: 'Privacy',
          cookies: 'Cookies',
          relatedProjects: 'Related Projects',
        },
      };

      function setLang(lang: Lang) {
        localStorage.setItem('asetemyt-lang', lang);

        document.querySelectorAll('[data-nav]').forEach((el) => {
          const key = (el as HTMLElement).dataset.nav!;
          const label = navLabels[lang][key];
          if (label) el.textContent = label;
        });

        document.querySelectorAll('[data-text]').forEach((el) => {
          const key = (el as HTMLElement).dataset.text!;
          const label = footerLabels[lang][key];
          if (label) el.textContent = label;
        });

        const esBtn = document.getElementById('lang-es')!;
        const enBtn = document.getElementById('lang-en')!;
        const mobEsBtn = document.getElementById('mob-lang-es')!;
        const mobEnBtn = document.getElementById('mob-lang-en')!;

        [esBtn, mobEsBtn].forEach((b) => {
          b.className = lang === 'es'
            ? 'px-2.5 py-1 bg-accent-500 text-white font-semibold transition-colors'
            : 'px-2.5 py-1 hover:bg-steel-700 transition-colors';
        });
        [enBtn, mobEnBtn].forEach((b) => {
          b.className = lang === 'en'
            ? 'px-2.5 py-1 bg-accent-500 text-white font-semibold transition-colors'
            : 'px-2.5 py-1 hover:bg-steel-700 transition-colors';
        });

        document.documentElement.lang = lang === 'en' ? 'en' : 'es';
        window.dispatchEvent(new CustomEvent('langChange', { detail: lang }));
      }

      document.getElementById('lang-es')?.addEventListener('click', () => setLang('es'));
      document.getElementById('lang-en')?.addEventListener('click', () => setLang('en'));
      document.getElementById('mob-lang-es')?.addEventListener('click', () => setLang('es'));
      document.getElementById('mob-lang-en')?.addEventListener('click', () => setLang('en'));

      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });

      setLang(getLang());

      (async () => {
        try {
          const { onAuthStateChanged, auth } = await import('../lib/auth');
          const lang = () => (localStorage.getItem('asetemyt-lang') as Lang) || 'es';

          onAuthStateChanged(auth, (user) => {
            const navAuth = document.getElementById('nav-auth');
            const mobAuth = document.getElementById('mob-auth-link');
            if (!navAuth || !mobAuth) return;

            if (user) {
              navAuth.innerHTML = `<a href="/mi-cuenta" class="hover:text-accent-400 transition-colors font-medium" data-nav="account">${navLabels[lang()]['account']}</a>`;
              mobAuth.innerHTML = `<a href="/mi-cuenta" class="block py-2 hover:text-accent-400" data-nav="account">${navLabels[lang()]['account']}</a>`;
            } else {
              navAuth.innerHTML = `<a href="/login" class="hover:text-accent-400 transition-colors font-medium" data-nav="login">${navLabels[lang()]['login']}</a>`;
              mobAuth.innerHTML = `<a href="/login" class="block py-2 hover:text-accent-400" data-nav="login">${navLabels[lang()]['login']}</a>`;
            }
          });
        } catch {}
      })();
    </script>
    <CookieConsent />
  </body>
</html>
