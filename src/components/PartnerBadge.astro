---
// PartnerBadge.astro — Badge for consultants who use ProdCont tools
// Props: tools (array of tool slugs the consultant uses)
export interface Props {
  tools?: string[];
  showDetail?: boolean;
}
const { tools = [], showDetail = false } = Astro.props;

const partnerTools = [
  { slug: 'cronometras', name: 'CRONOMETRAS', url: 'https://cronometras.com', desc: 'Software de Cronometraje Industrial' },
  { slug: 'induly', name: 'Induly', url: 'https://induly.com', desc: 'Control de Producción y Fichaje' },
  { slug: 'worksamp', name: 'Worksamp', url: 'https://worksamp.com', desc: 'Muestreo del Trabajo' },
  { slug: 'balanceo-prodcont', name: 'Balanceo ProdCont', url: 'https://balanceo.prodcont.com', desc: 'Balanceo de Líneas' },
];

const matchedTools = partnerTools.filter(pt => tools.includes(pt.slug));
const isPartner = matchedTools.length > 0;
---

{isPartner && (
  <div class={showDetail ? 'mt-4 p-4 bg-gradient-to-r from-blue-50 to-blue-100 rounded-xl border border-blue-200' : ''}>
    <div class="flex items-center gap-2 flex-wrap">
      <span class="inline-flex items-center gap-1.5 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
        </svg>
        Partner Tecnológico
      </span>
      {matchedTools.map(t => (
        <a href={t.url} target="_blank" rel="noopener"
          class="inline-flex items-center gap-1 bg-white text-blue-700 text-xs font-medium px-2.5 py-1 rounded-full border border-blue-200 hover:bg-blue-50 transition-colors">
          {t.name}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      ))}
    </div>
    {showDetail && (
      <p class="text-sm text-blue-700 mt-3">
        Este profesional utiliza herramientas de ProdCont en sus proyectos. 
        {matchedTools.map(t => t.desc).join(', ')}.
      </p>
    )}
  </div>
)}
