---
// Certificate.astro — Downloadable certificate for verified members (mobile-responsive)
export interface Props {
  entryName: string;
  entrySlug: string;
  tipo: string;
  verificationDate?: string;
}
const { entryName, entrySlug, tipo, verificationDate } = Astro.props;
const tipoLabel = tipo === 'empresa' ? 'Empresa' : tipo === 'consultor' ? 'Consultor' : 'Profesional';
const dateStr = verificationDate || new Date().toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<div id="certificate-section" class="p-4 sm:p-6 bg-gradient-to-r from-amber-50 to-amber-100 rounded-xl border border-amber-200">
  <div class="flex flex-col sm:flex-row items-start gap-3 sm:gap-4">
    <div class="w-9 h-9 sm:w-10 sm:h-10 bg-amber-500 rounded-lg flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
      </svg>
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-amber-900 text-sm sm:text-base mb-1">Certificado de Profesional Verificado</h3>
      <p class="text-xs sm:text-sm text-amber-700 mb-4">Descarga tu certificado para compartir en LinkedIn, tu web o con clientes.</p>

      <!-- Certificate Preview (responsive) -->
      <div id="certificate-preview" class="mb-4 bg-white rounded-lg shadow-lg overflow-hidden w-full">
        <!-- Header -->
        <div class="bg-gradient-to-br from-[#1e3a5f] via-[#2d5a87] to-[#1e3a5f] p-5 sm:p-8 text-center relative overflow-hidden">
          <div class="absolute -top-12 -right-12 w-32 h-32 sm:w-48 sm:h-48 bg-white/5 rounded-full"></div>
          <div class="absolute -bottom-8 -left-8 w-24 h-24 sm:w-36 sm:h-36 bg-white/[0.03] rounded-full"></div>

          <div class="inline-block w-10 h-10 sm:w-14 sm:h-14 bg-[#e8a838] rounded-lg sm:rounded-xl leading-[40px] sm:leading-[56px] text-center mb-3 sm:mb-4 relative z-10">
            <span class="text-white text-xl sm:text-2xl font-extrabold">A</span>
          </div>

          <p class="text-[#e8a838] text-[10px] sm:text-xs tracking-[2px] sm:tracking-[3px] uppercase font-semibold mb-1 sm:mb-2">
            Certificado de Verificación
          </p>
          <h2 class="text-white text-xl sm:text-2xl font-extrabold mb-0.5 sm:mb-1">ASETEMYT</h2>
          <p class="text-white/60 text-[10px] sm:text-[11px] tracking-wide">Directorio de Cronometraje Industrial</p>
        </div>

        <!-- Body -->
        <div class="p-4 sm:p-6 lg:p-8 text-center">
          <p class="text-gray-500 text-[10px] sm:text-xs uppercase tracking-[1.5px] sm:tracking-[2px] mb-3 sm:mb-4">
            {tipoLabel} Verificado
          </p>
          <h2 class="text-[#1e3a5f] text-base sm:text-lg lg:text-xl font-extrabold mb-4 sm:mb-5 leading-tight break-words">
            {entryName}
          </h2>

          <div class="w-12 sm:w-14 h-0.5 bg-[#e8a838] mx-auto mb-4 sm:mb-5"></div>

          <p class="text-gray-600 text-xs sm:text-sm leading-relaxed mb-4 sm:mb-5 px-2">
            Ha sido verificado como {tipoLabel.toLowerCase()} especializado en cronometraje industrial
            e ingeniería de métodos y tiempos en el directorio ASETEMYT.
          </p>

          <!-- Footer (stacks on very small screens) -->
          <div class="border-t border-gray-200 pt-3 sm:pt-4 flex flex-col sm:flex-row justify-between items-center gap-3 sm:gap-4">
            <div class="text-center sm:text-left order-2 sm:order-1">
              <p class="text-gray-400 text-[9px] sm:text-[10px] uppercase mb-0.5">Fecha verificación</p>
              <p class="text-gray-700 text-[11px] sm:text-xs font-semibold">{dateStr}</p>
            </div>
            <div class="order-1 sm:order-2">
              <span class="inline-flex items-center gap-1 bg-green-100 text-green-800 px-2.5 sm:px-3 py-1 rounded-full text-[10px] sm:text-[11px] font-semibold">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Verificado
              </span>
            </div>
            <div class="text-center sm:text-right order-3">
              <p class="text-gray-400 text-[9px] sm:text-[10px] uppercase mb-0.5">Directorio</p>
              <p class="text-gray-700 text-[11px] sm:text-xs font-semibold">asetemyt.com</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Download Buttons (responsive grid) -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 sm:gap-3">
        <button id="download-cert-svg"
          class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-3 py-2.5 rounded-lg transition-colors text-xs sm:text-sm">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Descargar SVG
        </button>
        <button id="download-cert-png"
          class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-3 py-2.5 rounded-lg transition-colors text-xs sm:text-sm">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Descargar PNG
        </button>
        <a href={`https://www.linkedin.com/profile/add?startTask=CERTIFICATION_NAME&name=Profesional+Verificado+ASETEMYT&organizationId=&issueMonth=&issueYear=&expirationMonth=&expirationYear=&certUrl=https%3A%2F%2Fasetemyt.com%2Fdirectorio%2F${entrySlug}&certId=`}
          target="_blank" rel="noopener"
          class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-3 py-2.5 rounded-lg transition-colors text-xs sm:text-sm">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Añadir a LinkedIn
        </a>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ entryName, tipoLabel, dateStr }}>
  function generateSVG() {
    return `<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="800" height="500" viewBox="0 0 800 500">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a5f"/>
      <stop offset="50%" style="stop-color:#2d5a87"/>
      <stop offset="100%" style="stop-color:#1e3a5f"/>
    </linearGradient>
  </defs>
  <rect width="800" height="500" fill="white"/>
  <rect x="0" y="0" width="800" height="200" fill="url(#bg)"/>
  <circle cx="700" cy="50" r="120" fill="rgba(255,255,255,0.05)"/>
  <circle cx="100" cy="180" r="80" fill="rgba(255,255,255,0.03)"/>
  <rect x="370" y="30" width="60" height="60" rx="12" fill="#e8a838"/>
  <text x="400" y="72" text-anchor="middle" fill="white" font-size="28" font-weight="800" font-family="Arial">A</text>
  <text x="400" y="120" text-anchor="middle" fill="#e8a838" font-size="14" font-weight="600" font-family="Arial" letter-spacing="3">CERTIFICADO DE VERIFICACION</text>
  <text x="400" y="150" text-anchor="middle" fill="white" font-size="28" font-weight="800" font-family="Arial">ASETEMYT</text>
  <text x="400" y="172" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-size="11" font-family="Arial" letter-spacing="1">Directorio de Cronometraje Industrial</text>
  <text x="400" y="240" text-anchor="middle" fill="#6b7280" font-size="12" font-family="Arial" letter-spacing="2">${tipoLabel.toUpperCase()} VERIFICADO</text>
  <text x="400" y="280" text-anchor="middle" fill="#1e3a5f" font-size="24" font-weight="800" font-family="Arial">${entryName.replace(/&/g, '&amp;').replace(/</g, '&lt;')}</text>
  <rect x="370" y="300" width="60" height="3" fill="#e8a838"/>
  <text x="400" y="335" text-anchor="middle" fill="#4b5563" font-size="13" font-family="Arial">Ha sido verificado como ${tipoLabel.toLowerCase()} especializado en cronometraje</text>
  <text x="400" y="355" text-anchor="middle" fill="#4b5563" font-size="13" font-family="Arial">industrial e ingenieria de metodos y tiempos en el directorio ASETEMYT.</text>
  <line x1="100" y1="390" x2="700" y2="390" stroke="#e5e7eb" stroke-width="1"/>
  <text x="100" y="420" fill="#9ca3af" font-size="10" font-family="Arial">FECHA DE VERIFICACION</text>
  <text x="100" y="440" fill="#374151" font-size="12" font-weight="600" font-family="Arial">${dateStr}</text>
  <rect x="340" y="408" width="120" height="28" rx="14" fill="#dcfce7"/>
  <text x="400" y="427" text-anchor="middle" fill="#166534" font-size="11" font-weight="600" font-family="Arial">Verificado</text>
  <text x="700" y="420" fill="#9ca3af" font-size="10" font-family="Arial" text-anchor="end">DIRECTORIO</text>
  <text x="700" y="440" fill="#374151" font-size="12" font-weight="600" font-family="Arial" text-anchor="end">asetemyt.com</text>
  <rect x="4" y="4" width="792" height="492" rx="8" fill="none" stroke="#e5e7eb" stroke-width="2"/>
</svg>`;
  }

  document.getElementById('download-cert-svg')?.addEventListener('click', () => {
    const svg = generateSVG();
    const blob = new Blob([svg], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `certificado-asetemyt-${entryName.toLowerCase().replace(/\s+/g, '-')}.svg`;
    a.click();
    URL.revokeObjectURL(url);
  });

  document.getElementById('download-cert-png')?.addEventListener('click', () => {
    const svg = generateSVG();
    const canvas = document.createElement('canvas');
    canvas.width = 1600;
    canvas.height = 1000;
    const ctx = canvas.getContext('2d');
    const img = new Image();
    const blob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    img.onload = () => {
      ctx.drawImage(img, 0, 0, 1600, 1000);
      canvas.toBlob((pngBlob) => {
        const pngUrl = URL.createObjectURL(pngBlob);
        const a = document.createElement('a');
        a.href = pngUrl;
        a.download = `certificado-asetemyt-${entryName.toLowerCase().replace(/\s+/g, '-')}.png`;
        a.click();
        URL.revokeObjectURL(pngUrl);
      }, 'image/png');
      URL.revokeObjectURL(url);
    };
    img.src = url;
  });
</script>
