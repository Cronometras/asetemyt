---
// Certificate.astro — Downloadable certificate for verified members
// Props: entryName, entrySlug, tipo, verificationDate
export interface Props {
  entryName: string;
  entrySlug: string;
  tipo: string;
  verificationDate?: string;
}
const { entryName, entrySlug, tipo, verificationDate } = Astro.props;
const tipoLabel = tipo === 'empresa' ? 'Empresa' : tipo === 'consultor' ? 'Consultor' : 'Profesional';
const dateStr = verificationDate || new Date().toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<div id="certificate-section" class="mt-8 p-6 bg-gradient-to-r from-amber-50 to-amber-100 rounded-xl border border-amber-200">
  <div class="flex items-start gap-4">
    <div class="w-10 h-10 bg-amber-500 rounded-lg flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
      </svg>
    </div>
    <div class="flex-1">
      <h3 class="font-bold text-amber-900 mb-1">Certificado de Profesional Verificado</h3>
      <p class="text-sm text-amber-700 mb-4">Descarga tu certificado para compartir en LinkedIn, tu web personal o con clientes.</p>

      <!-- Certificate Preview -->
      <div id="certificate-preview" class="mb-4 bg-white rounded-lg shadow-lg overflow-hidden" style="max-width: 600px;">
        <div style="background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 50%, #1e3a5f 100%); padding: 40px; text-align: center; position: relative; overflow: hidden;">
          <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>
          <div style="position: absolute; bottom: -30px; left: -30px; width: 150px; height: 150px; background: rgba(255,255,255,0.03); border-radius: 50%;"></div>

          <div style="display: inline-block; width: 60px; height: 60px; background: #e8a838; border-radius: 12px; line-height: 60px; text-align: center; margin-bottom: 16px;">
            <span style="color: white; font-size: 28px; font-weight: 800;">A</span>
          </div>

          <h2 style="color: #e8a838; font-size: 14px; letter-spacing: 3px; text-transform: uppercase; margin: 0 0 8px; font-weight: 600;">
            Certificado de Verificación
          </h2>
          <h1 style="color: white; font-size: 24px; font-weight: 800; margin: 0 0 4px; line-height: 1.3;">
            ASETEMYT
          </h1>
          <p style="color: rgba(255,255,255,0.6); font-size: 11px; margin: 0; letter-spacing: 1px;">
            Directorio de Cronometraje Industrial
          </p>
        </div>

        <div style="padding: 30px 40px; text-align: center;">
          <p style="color: #6b7280; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; margin: 0 0 16px;">
            {tipoLabel} Verificado
          </p>
          <h2 style="color: #1e3a5f; font-size: 22px; font-weight: 800; margin: 0 0 20px; line-height: 1.3;">
            {entryName}
          </h2>

          <div style="width: 60px; height: 3px; background: #e8a838; margin: 0 auto 20px;"></div>

          <p style="color: #4b5563; font-size: 13px; line-height: 1.6; margin: 0 0 20px;">
            Ha sido verificado como {tipoLabel.toLowerCase()} especializado en cronometraje industrial
            e ingeniería de métodos y tiempos en el directorio ASETEMYT.
          </p>

          <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #e5e7eb; padding-top: 16px;">
            <div style="text-align: left;">
              <p style="color: #9ca3af; font-size: 10px; text-transform: uppercase; margin: 0;">Fecha de verificación</p>
              <p style="color: #374151; font-size: 12px; font-weight: 600; margin: 0;">{dateStr}</p>
            </div>
            <div style="text-align: center;">
              <div style="display: inline-flex; align-items: center; gap: 4px; background: #dcfce7; color: #166534; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600;">
                <svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Verificado
              </div>
            </div>
            <div style="text-align: right;">
              <p style="color: #9ca3af; font-size: 10px; text-transform: uppercase; margin: 0;">Directorio</p>
              <p style="color: #374151; font-size: 12px; font-weight: 600; margin: 0;">asetemyt.com</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Download Buttons -->
      <div class="flex flex-wrap gap-3">
        <button id="download-cert-svg"
          class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-4 py-2 rounded-lg transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Descargar SVG
        </button>
        <button id="download-cert-png"
          class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-4 py-2 rounded-lg transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Descargar PNG
        </button>
        <a href="https://www.linkedin.com/profile/add?startTask=CERTIFICATION_NAME&name=Profesional+Verificado+ASETEMYT&organizationId=&issueMonth=&issueYear=&expirationMonth=&expirationYear=&certUrl=https%3A%2F%2Fasetemyt.com%2Fdirectorio%2F{entrySlug}&certId="
          target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded-lg transition-colors text-sm">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Añadir a LinkedIn
        </a>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ entryName, tipoLabel, dateStr }}>
  function generateSVG() {
    return `<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="800" height="500" viewBox="0 0 800 500">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a5f"/>
      <stop offset="50%" style="stop-color:#2d5a87"/>
      <stop offset="100%" style="stop-color:#1e3a5f"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="500" fill="white"/>
  <rect x="0" y="0" width="800" height="200" fill="url(#bg)"/>

  <!-- Decorative circles -->
  <circle cx="700" cy="50" r="120" fill="rgba(255,255,255,0.05)"/>
  <circle cx="100" cy="180" r="80" fill="rgba(255,255,255,0.03)"/>

  <!-- Logo -->
  <rect x="370" y="30" width="60" height="60" rx="12" fill="#e8a838"/>
  <text x="400" y="72" text-anchor="middle" fill="white" font-size="28" font-weight="800" font-family="Arial, sans-serif">A</text>

  <!-- Header text -->
  <text x="400" y="120" text-anchor="middle" fill="#e8a838" font-size="14" font-weight="600" font-family="Arial, sans-serif" letter-spacing="3">CERTIFICADO DE VERIFICACIÓN</text>
  <text x="400" y="150" text-anchor="middle" fill="white" font-size="28" font-weight="800" font-family="Arial, sans-serif">ASETEMYT</text>
  <text x="400" y="172" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-size="11" font-family="Arial, sans-serif" letter-spacing="1">Directorio de Cronometraje Industrial</text>

  <!-- Body -->
  <text x="400" y="240" text-anchor="middle" fill="#6b7280" font-size="12" font-family="Arial, sans-serif" letter-spacing="2">${tipoLabel.toUpperCase()} VERIFICADO</text>
  <text x="400" y="280" text-anchor="middle" fill="#1e3a5f" font-size="24" font-weight="800" font-family="Arial, sans-serif">${entryName.replace(/&/g, '&amp;').replace(/</g, '&lt;')}</text>

  <!-- Divider -->
  <rect x="370" y="300" width="60" height="3" fill="#e8a838"/>

  <!-- Description -->
  <text x="400" y="335" text-anchor="middle" fill="#4b5563" font-size="13" font-family="Arial, sans-serif">Ha sido verificado como ${tipoLabel.toLowerCase()} especializado en cronometraje</text>
  <text x="400" y="355" text-anchor="middle" fill="#4b5563" font-size="13" font-family="Arial, sans-serif">industrial e ingeniería de métodos y tiempos en el directorio ASETEMYT.</text>

  <!-- Footer -->
  <line x1="100" y1="390" x2="700" y2="390" stroke="#e5e7eb" stroke-width="1"/>

  <text x="100" y="420" fill="#9ca3af" font-size="10" font-family="Arial, sans-serif" text-transform="uppercase">FECHA DE VERIFICACIÓN</text>
  <text x="100" y="440" fill="#374151" font-size="12" font-weight="600" font-family="Arial, sans-serif">${dateStr}</text>

  <!-- Verified badge -->
  <rect x="340" y="408" width="120" height="28" rx="14" fill="#dcfce7"/>
  <text x="400" y="427" text-anchor="middle" fill="#166534" font-size="11" font-weight="600" font-family="Arial, sans-serif">✓ Verificado</text>

  <text x="700" y="420" fill="#9ca3af" font-size="10" font-family="Arial, sans-serif" text-anchor="end">DIRECTORIO</text>
  <text x="700" y="440" fill="#374151" font-size="12" font-weight="600" font-family="Arial, sans-serif" text-anchor="end">asetemyt.com</text>

  <!-- Border -->
  <rect x="4" y="4" width="792" height="492" rx="8" fill="none" stroke="#e5e7eb" stroke-width="2"/>
</svg>`;
  }

  // Download SVG
  document.getElementById('download-cert-svg')?.addEventListener('click', () => {
    const svg = generateSVG();
    const blob = new Blob([svg], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `certificado-asetemyt-${entryName.toLowerCase().replace(/\s+/g, '-')}.svg`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // Download PNG
  document.getElementById('download-cert-png')?.addEventListener('click', () => {
    const svg = generateSVG();
    const canvas = document.createElement('canvas');
    canvas.width = 1600;
    canvas.height = 1000;
    const ctx = canvas.getContext('2d');
    const img = new Image();
    const blob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    img.onload = () => {
      ctx.drawImage(img, 0, 0, 1600, 1000);
      canvas.toBlob((pngBlob) => {
        const pngUrl = URL.createObjectURL(pngBlob);
        const a = document.createElement('a');
        a.href = pngUrl;
        a.download = `certificado-asetemyt-${entryName.toLowerCase().replace(/\s+/g, '-')}.png`;
        a.click();
        URL.revokeObjectURL(pngUrl);
      }, 'image/png');
      URL.revokeObjectURL(url);
    };
    img.src = url;
  });
</script>
