---
// CasesSection.astro — UGC case studies for verified entries
export interface Props {
  slug: string;
  entryName: string;
  isOwner?: boolean;
}
const { slug, entryName, isOwner = false } = Astro.props;
---

<div id="cases-section" class="mt-8">
  <h2 class="text-lg font-bold text-primary-800 mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    Casos de Estudio
  </h2>

  <div id="cases-list" class="space-y-3 mb-4"></div>

  {isOwner && (
    <div>
      <button id="toggle-case-form"
        class="text-sm text-accent-600 hover:text-accent-700 font-semibold flex items-center gap-1 mb-3">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Añadir caso de estudio
      </button>

      <form id="case-form" class="hidden bg-steel-50 rounded-xl p-5 border border-steel-200 space-y-3">
        <div>
          <label class="block text-sm font-medium text-steel-700 mb-1">Título del caso *</label>
          <input type="text" name="title" required maxlength="200" placeholder="Ej: Reducción de tiempos en línea de montaje automotriz"
            class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none text-sm" />
        </div>
        <div>
          <label class="block text-sm font-medium text-steel-700 mb-1">Descripción *</label>
          <textarea name="description" required rows="3" maxlength="2000"
            placeholder="Describe el proyecto, el problema y la solución aplicada..."
            class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none text-sm resize-y"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-steel-700 mb-1">Resultados obtenidos</label>
          <textarea name="results" rows="2" maxlength="1000"
            placeholder="Ej: Reducción del 15% en tiempo de ciclo, ahorro de 50.000€/año..."
            class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none text-sm resize-y"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-steel-700 mb-1">Sector</label>
            <input type="text" name="industry" maxlength="100" placeholder="Automoción"
              class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium text-steel-700 mb-1">Método aplicado</label>
            <input type="text" name="method" maxlength="100" placeholder="MTM-2, Cronometraje..."
              class="w-full border border-steel-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-accent-500 outline-none text-sm" />
          </div>
        </div>
        <div class="flex items-center gap-3">
          <button type="submit" class="bg-accent-500 hover:bg-accent-600 text-white font-semibold px-4 py-2 rounded-lg text-sm transition-colors">
            Publicar caso
          </button>
          <span id="case-status" class="text-sm"></span>
        </div>
      </form>
    </div>
  )}
</div>

<script define:vars={{ slug, isOwner }}>
  // Toggle form
  document.getElementById('toggle-case-form')?.addEventListener('click', () => {
    document.getElementById('case-form')?.classList.toggle('hidden');
  });

  // Load cases
  async function loadCases() {
    try {
      const res = await fetch(`/api/cases?slug=${encodeURIComponent(slug)}`);
      if (!res.ok) return;
      const data = await res.json();
      const list = document.getElementById('cases-list');

      if (!data.cases?.length) {
        list.innerHTML = '<p class="text-sm text-steel-400">No hay casos de estudio publicados todavía.</p>';
        return;
      }

      list.innerHTML = data.cases.map(c => `
        <div class="bg-white rounded-lg border border-steel-100 p-4 hover:shadow-sm transition-shadow">
          <h4 class="font-bold text-primary-800 text-sm mb-1">${escapeHtml(c.title)}</h4>
          <p class="text-steel-600 text-sm leading-relaxed mb-2">${escapeHtml(c.description)}</p>
          ${c.results ? `<p class="text-green-700 text-xs font-medium mb-2">📊 ${escapeHtml(c.results)}</p>` : ''}
          <div class="flex flex-wrap gap-1.5">
            ${c.industry ? `<span class="text-xs bg-steel-100 text-steel-600 px-2 py-0.5 rounded">${escapeHtml(c.industry)}</span>` : ''}
            ${c.method ? `<span class="text-xs bg-primary-50 text-primary-700 px-2 py-0.5 rounded">${escapeHtml(c.method)}</span>` : ''}
          </div>
        </div>
      `).join('');
    } catch (e) {
      console.error('Error loading cases:', e);
    }
  }

  // Submit case
  document.getElementById('case-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const f = e.target;
    const statusEl = document.getElementById('case-status');
    statusEl.textContent = 'Publicando...';
    statusEl.className = 'text-sm text-steel-500';

    const payload = {
      slug,
      title: f.title.value,
      description: f.description.value,
      results: f.results.value,
      industry: f.industry.value,
      method: f.method.value,
    };

    try {
      const res = await fetch('/api/cases', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (res.ok) {
        statusEl.textContent = '✓ Publicado';
        statusEl.className = 'text-sm text-green-600';
        f.reset();
        f.classList.add('hidden');
        loadCases();
      } else {
        statusEl.textContent = data.error;
        statusEl.className = 'text-sm text-red-600';
      }
    } catch {
      statusEl.textContent = 'Error de conexión.';
      statusEl.className = 'text-sm text-red-600';
    }
  });

  function escapeHtml(str) {
    const d = document.createElement('div');
    d.textContent = str || '';
    return d.innerHTML;
  }

  loadCases();
</script>
