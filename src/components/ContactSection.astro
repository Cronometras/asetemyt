---
// ContactSection.astro — Astro island for contact data
// Server: renders blurred/locked placeholder (no contact data in HTML)
// Client: hydrates → fetches /api/ficha/contact → shows real data or CTA

export interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<div id={`contacto-${slug}`} class="contact-section" data-slug={slug}>
  <!-- Server-rendered: locked state (default) -->
  <div class="relative">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 blur-[6px] select-none pointer-events-none opacity-40">
      <div class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg">
        <div class="w-5 h-5 bg-steel-200 rounded"></div>
        <div class="h-4 w-32 bg-steel-200 rounded"></div>
      </div>
      <div class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg">
        <div class="w-5 h-5 bg-steel-200 rounded"></div>
        <div class="h-4 w-28 bg-steel-200 rounded"></div>
      </div>
      <div class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg">
        <div class="w-5 h-5 bg-steel-200 rounded"></div>
        <div class="h-4 w-40 bg-steel-200 rounded"></div>
      </div>
      <div class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg">
        <div class="w-5 h-5 bg-steel-200 rounded"></div>
        <div class="h-4 w-24 bg-steel-200 rounded"></div>
      </div>
    </div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="bg-white/95 backdrop-blur-sm rounded-xl shadow-lg p-5 border border-steel-200 max-w-sm mx-4 text-center">
        <svg class="w-8 h-8 text-amber-500 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <p class="font-bold text-primary-900 text-sm mb-1">Datos de contacto bloqueados</p>
        <p class="text-xs text-steel-500 mb-3">Los datos de contacto están disponibles solo para fichas verificadas.</p>
        <a href={`/reclamar/${slug}`} class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-4 py-2 rounded-lg text-xs transition-colors">
          Verificar ficha →
        </a>
      </div>
    </div>
  </div>

  <!-- Client: unlocked state (hidden by default, shown after fetch) -->
  <div class="contact-unlocked hidden grid grid-cols-1 sm:grid-cols-2 gap-4"></div>
</div>

<script>
  (async function() {
    const el = document.querySelector('.contact-section');
    if (!el) return;
    const slug = el.getAttribute('data-slug');
    if (!slug) return;

    /** Decode obfuscated emails: 'info at domain.com' → 'info@domain.com' */
    function decodeEmail(s: string): string {
      return s.replace(/ at /g, '@').replace(/ dot /g, '.');
    }

    /** Escape HTML to prevent XSS */
    function esc(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    try {
      const res = await fetch('/api/ficha/contact?slug=' + encodeURIComponent(slug));
      if (!res.ok) return;
      const data = await res.json();

      if (data.locked || !data.contacto) return;

      const c = data.contacto;
      const container = el.querySelector('.contact-unlocked');
      if (!container) return;

      const items: string[] = [];

      if (c.email) {
        const email = decodeEmail(c.email);
        items.push(`<a href="mailto:${esc(email)}" class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg hover:bg-steel-100 transition-colors">
          <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span class="text-sm text-steel-700">${esc(email)}</span></a>`);
      }
      if (c.telefono) {
        items.push(`<a href="tel:${esc(c.telefono)}" class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg hover:bg-steel-100 transition-colors">
          <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <span class="text-sm text-steel-700">${esc(c.telefono)}</span></a>`);
      }
      if (c.web) {
        const href = c.web.indexOf('http') === 0 ? c.web : 'https://' + c.web;
        items.push(`<a href="${esc(href)}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg hover:bg-steel-100 transition-colors">
          <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
          <span class="text-sm text-steel-700">${esc(c.web)}</span></a>`);
      }
      if (c.linkedin) {
        const lhref = c.linkedin.indexOf('http') === 0 ? c.linkedin : 'https://linkedin.com/in/' + c.linkedin;
        items.push(`<a href="${esc(lhref)}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 bg-steel-50 rounded-lg hover:bg-steel-100 transition-colors">
          <svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <span class="text-sm text-steel-700">LinkedIn</span></a>`);
      }

      if (items.length > 0) {
        container.innerHTML = items.join('');
        const lockedDiv = el.querySelector('.relative');
        if (lockedDiv) lockedDiv.remove();
        container.classList.remove('hidden');
      }
    } catch (e) {
      console.error('ContactSection fetch error:', e);
    }
  })();
</script>
